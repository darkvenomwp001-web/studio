
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Default deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow reading users, stories, and comments by anyone
    match /users/{userId} {
      allow read: if true;
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create, update: if isAuthenticated(); // Server-side checks handle permissions
    }
    
    match /comments/{commentId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated(); // Server-side checks handle permissions
    }

    match /letters/{letterId} {
        allow read, create, update: if isAuthenticated();
    }
    
    match /notifications/{notificationId} {
        allow read, update, create, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    // These rules rely on server-side actions for security checks.
    // The server first reads the doc ('get'), checks ownership in code, then deletes.
    // Thus, we only need to ensure the user is logged in to attempt the action.
    // The server-side code is the real security gatekeeper.
    match /liveFeed/{postId} {
        allow get, create, update, delete: if isAuthenticated();
        allow list: if true;
    }
    
    match /prompts/{promptId} {
        allow get, create, update, delete: if isAuthenticated();
        allow list: if true;
    }
    
    match /statusUpdates/{statusId} {
        allow get, create, delete: if isAuthenticated();
        allow list: if true;
    }
    
    match /feedPosts/{postId} {
        allow get, create, update, delete: if isAuthenticated();
        allow list: if true;
    }
  }
}
