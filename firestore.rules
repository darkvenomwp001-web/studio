
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function canUpdateFollowerCount() {
      return isSignedIn() && 
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'updatedAt']);
    }

    // USERS
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || canUpdateFollowerCount();
      allow delete: if false;
    }

    // STORIES (Books)
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' ||
                    resource.data.visibility == 'Unlisted' ||
                    (isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isOwner(request.resource.data.author.id);
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isOwner(resource.data.author.id);
    }
    
    // USER NOTES (Messenger-style)
    match /userNotes/{noteId} {
      allow read: if isSignedIn(); // Client filters for public/follower
      allow create: if isOwner(request.resource.data.authorId);
      allow update, delete: if false;
    }

    // FEED POSTS
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.authorId);
      allow update: if isSignedIn(); // For likes
      allow delete: if isOwner(resource.data.authorId);
    }

    // CONVERSATIONS and MESSAGES
    match /conversations/{conversationId} {
      allow read, create, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false;
      }
    }
    
    // LETTERS
    match /letters/{letterId} {
      allow read, update: if isSignedIn() && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.reader.id;
      allow delete: if false;
    }

    // COMMENTS
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.user.id);
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isOwner(resource.data.userId);
    }
  }
}
