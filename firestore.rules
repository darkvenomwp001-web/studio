
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is the owner of a document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      // Anyone can read a user's public profile data
      allow read: if true;
      // A user can create their own profile
      allow create: if isOwner(userId);
      // A user can only update their own profile
      allow update: if isOwner(userId);
      // Users cannot delete their profiles through the app
      allow delete: if false;
    }

    // Stories Collection
    match /stories/{storyId} {
      // Allow read if story is public/unlisted, or if user is author/collaborator
      allow read: if resource.data.visibility == 'Public' || 
                   resource.data.visibility == 'Unlisted' ||
                   (isAuthenticated() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds));
      // Only author/collaborators can create/update stories
      allow create, update: if isAuthenticated() && (isOwner(request.resource.data.author.id) || request.auth.uid in request.resource.data.collaboratorIds);
      // Only the original author can delete a story
      allow delete: if isAuthenticated() && isOwner(resource.data.author.id);
    }
    
    // Comments Collection
    match /comments/{commentId} {
      // Anyone can read comments
      allow read: if true;
      // Only authenticated users can create comments
      allow create: if isAuthenticated() && isOwner(request.resource.data.user.id);
      // Users can only update/delete their own comments
      allow update, delete: if isAuthenticated() && isOwner(resource.data.user.id);
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      // Users can only read/update their own notifications
      allow read, update: if isAuthenticated() && isOwner(resource.data.userId);
      // Any authenticated user can create a notification (e.g., follow action triggers one for another user)
      allow create: if isAuthenticated();
      // Users cannot delete notifications
      allow delete: if false;
    }
    
    // Conversations Collection
    match /conversations/{conversationId} {
      // Participants can read/update conversation metadata
      allow read, update: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      // Participants can create conversations
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participantIds;
      
      // Messages Sub-collection
      match /messages/{messageId} {
        // Participants can read and create messages
        allow read, create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        // Users cannot update/delete messages
        allow update, delete: if false;
      }
    }
    
    // Letters Collection
    match /letters/{letterId} {
        // Only sender (reader) or receiver (author) can read
        allow read: if isAuthenticated() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
        // Only readers can create letters
        allow create: if isAuthenticated() && isOwner(request.resource.data.reader.id);
        // Only the author can update (respond/pin)
        allow update: if isAuthenticated() && isOwner(resource.data.authorId);
        // Nobody can delete letters for now
        allow delete: if false;
    }
    
    // Feed Posts Collection
    match /feedPosts/{postId} {
        // Allow read if user is the author OR if the user is following the author
        // NOTE: This rule is more complex and requires a 'get' call, which can impact performance/cost at scale.
        allow read: if isAuthenticated() && (isOwner(resource.data.authorId) || resource.data.authorId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.followingIds);
        // Only the author can create/update/delete their posts
        allow create, update, delete: if isAuthenticated() && isOwner(request.resource.data.authorId);
    }
  }
}
