
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to robustly check ownership
    function isOwner(data) {
      let uid = request.auth.uid;
      return uid != null && (
        (data.authorId != null && data.authorId == uid) ||
        (data.author.id != null && data.author.id == uid) ||
        (data.authorInfo.id != null && data.authorInfo.id == uid) ||
        (data.user.id != null && data.user.id == uid)
      );
    }
    
    // Users can read any profile, but can only create/update their own document.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      // Deletion is disallowed from the client for safety.
      allow delete: if false;
    }

    // Stories can be read if public/unlisted, or if the reader is the author/collaborator.
    // Stories can only be created/updated/deleted by the author or collaborators.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                     resource.data.visibility == 'Unlisted' ||
                     (request.auth != null && resource.data.author.id == request.auth.uid) ||
                     (request.auth != null && request.auth.uid in resource.data.collaboratorIds);
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
      allow update, delete: if request.auth != null && 
                              (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
    }
    
    // Notifications are private. A user can only access their own.
    // Any authenticated user can create a notification (e.g., for following someone).
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
    }
    
    // Comments can be read by anyone.
    // Authenticated users can create comments.
    // Users can only edit or delete their own comments.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwner(resource.data);
    }

    // LiveFeed posts can be read by anyone.
    // Users can create/update/delete their own posts.
    match /liveFeed/{postId} {
      allow read: if true;
      allow create: if request.auth != null && isOwner(request.resource.data);
      allow update, delete: if request.auth != null && isOwner(resource.data);
    }

    // Prompts can be read by anyone.
    // Users can create/update/delete their own prompts.
    match /prompts/{promptId} {
      allow read: if true;
      allow create: if request.auth != null && isOwner(request.resource.data);
      allow update, delete: if request.auth != null && isOwner(resource.data);
    }
    
    // Letters can only be read by the sender or receiver.
    // Only the reader can create one, and only the author can update it (with a response/pin).
    match /letters/{letterId} {
      allow read: if request.auth != null && 
                      (resource.data.authorId == request.auth.uid || resource.data.reader.id == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.reader.id == request.auth.uid;
      allow update: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // Status updates are public, but can only be created by the author.
    // Author can update (archive) or delete their own status.
    match /statusUpdates/{statusId} {
      allow read: if true;
      allow create: if request.auth != null && isOwner(request.resource.data);
      allow update, delete: if request.auth != null && isOwner(resource.data);
    }

    // Conversations can only be accessed by participants.
    match /conversations/{conversationId} {
        allow read, write: if request.auth != null && request.auth.uid in resource.data.participantIds;
        
        match /messages/{messageId} {
            allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
    }

    // FeedPosts can be read by anyone.
    // Users can create their own posts.
    // Users can update their own posts (e.g. for likes, which is handled server-side now but good to have).
    match /feedPosts/{postId} {
        allow read: if true;
        allow create: if request.auth != null && isOwner(request.resource.data);
        allow update: if request.auth != null && isOwner(resource.data); // Allows liking own post, but toggle is main driver
        allow delete: if request.auth != null && isOwner(resource.data);
    }
  }
}
    