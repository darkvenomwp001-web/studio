
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users collection can be read by anyone, but only the user themselves can write to their own document.
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Stories (Books)
    match /stories/{storyId} {
      // Allow anyone to read public stories
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted';
      // Allow authenticated users to read their own private stories
      allow read: if isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds);
      // Allow authenticated users to create stories
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
      // Allow author or collaborators to update
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds);
      // Only the original author can delete
      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }

    // Comments can be created by any signed-in user.
    // They can be read by anyone.
    // Users can only update or delete their own comments.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }

    // Notifications are private to the user they are for.
    match /notifications/{notificationId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
    }

    // User Stories (Instagram-style)
    match /userStories/{userStoryId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(request.resource.data.authorId);
      allow update, delete: if isSignedIn() && isOwner(resource.data.authorId);
    }

    // Feed Posts
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(request.resource.data.authorId);
      // Only author can delete, anyone can update for likes
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && isOwner(resource.data.authorId);
    }

    // Conversations
    match /conversations/{conversationId} {
      allow read, create: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      // Participants can update (e.g., last message)
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;

      // Messages within conversations
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }

    // Letters
     match /letters/{letterId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || isOwner(resource.data.reader.id));
    }
  }
}
