rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // USERS Collection
    match /users/{userId} {
      // Anyone can read a user's public profile
      allow get: if true;
      // A user can create their own profile
      allow create: if isOwner(userId);
      // A user can only update their own profile
      allow update: if isOwner(userId);
      // Deletion of users should be handled carefully, often disabled from client
      allow delete: if false; 
    }
    
    // STORIES Collection
    match /stories/{storyId} {
      // Allow reads for public/unlisted stories, or if user is owner/collaborator for private stories
      allow get: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted'
                  || (isAuthenticated() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));

      // Allow list for public stories only
      allow list: if resource.data.visibility == 'Public';

      // Allow create if user is authenticated
      allow create: if isAuthenticated() && request.resource.data.author.id == request.auth.uid;
      
      // Allow update if user is owner or collaborator
      allow update: if isAuthenticated() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      
      // Only the author can delete
      allow delete: if isAuthenticated() && resource.data.author.id == request.auth.uid;
    }
    
    // FEEDPOSTS Collection
    match /feedPosts/{postId} {
      // Anyone can read feed posts
      allow get, list: if true;
      
      // Authenticated users can create posts, if they are the author
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      
      // Only the author can update the content of their post
      // Any authenticated user can update the likes (handled in server action)
      allow update: if isAuthenticated() && 
                    ( (request.resource.data.authorId == request.auth.uid && request.resource.data.content == resource.data.content) || 
                      (request.resource.data.content == resource.data.content) );

      // Only the author can delete their post
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // COMMENTS Collection
    match /comments/{commentId} {
      allow get, list: if true;
      allow create: if isAuthenticated() && request.resource.data.user.id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user.id == request.auth.uid;
    }
    
    // NOTIFICATIONS Collection
    match /notifications/{notificationId} {
      // Users can only read, update (mark as read), or delete their own notifications.
      allow get, list, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Creation is handled by server actions.
      allow create: if isAuthenticated();
    }
    
    // CONVERSATIONS and MESSAGES
    match /conversations/{conversationId} {
      // Allow access if the user is a participant
      allow get, list, update: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      // Creation is handled by server actions to ensure participant list is correct.
      allow create: if isAuthenticated();
      
      match /messages/{messageId} {
        allow get, list, create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        // Generally, don't allow message edits/deletes from client for message integrity.
        allow update, delete: if false; 
      }
    }
    
    // STATUS UPDATES Collection
    match /statusUpdates/{statusId} {
        allow get, list, create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // All other collections can be defined here...
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
