
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isCollaborator(storyId) {
      return get(/databases/$(database)/documents/stories/$(storyId)).data.collaboratorIds.hasAny([request.auth.uid]);
    }

    function isStoryOwner(storyId) {
      return get(/databases/$(database)/documents/stories/$(storyId)).data.author.id == request.auth.uid;
    }

    // USERS Collection
    match /users/{userId} {
      // Anyone can read a user's profile
      allow read;

      // A user can create their own profile document
      allow create: if isOwner(userId);
      
      // A user can update their own document, but cannot change protected fields.
      allow update: if isOwner(userId)
                    // Users cannot change their own follower count; this is handled by server-side logic/transactions.
                    && request.resource.data.followersCount == resource.data.followersCount
                    // Email and creation date are immutable.
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.createdAt == resource.data.createdAt;
    }

    // STORIES Collection
    match /stories/{storyId} {
      // Allow read if story is public, unlisted, or if user is owner/collaborator for private/drafts
      allow read: if resource.data.visibility == 'Public'
                   || resource.data.visibility == 'Unlisted'
                   || (isAuthenticated() && (isStoryOwner(storyId) || isCollaborator(storyId)));

      // Allow create if the user is the author of the new story
      allow create: if isOwner(request.resource.data.author.id);

      // Allow update if user is the author or a collaborator
      allow update: if isAuthenticated() && (isStoryOwner(storyId) || isCollaborator(storyId));
      
      // Only the original author can delete a story
      allow delete: if isAuthenticated() && isStoryOwner(storyId);
    }
    
    // COMMENTS Collection
    match /comments/{commentId} {
      allow read;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isOwner(resource.data.user.id);
    }

    // NOTIFICATIONS Collection
    match /notifications/{notificationId} {
      // User can only read, update (isRead), or delete their own notifications.
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
      // Notifications are created by server actions (or trusted clients)
      allow create: if isAuthenticated();
    }
    
    // QUESTIONS Collection
    match /questions/{questionId} {
        allow read;
        // Any authenticated user can ask a question
        allow create: if isAuthenticated()
                      && request.resource.data.asker.id == request.auth.uid;
        
        // No updates or deletes allowed for now to keep it simple.
        allow update, delete: if false;
    }
    
    // LETTERS Collection
    match /letters/{letterId} {
        // Can read if you are the sender (reader) or receiver (author)
        allow read: if isAuthenticated() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
        // Can create if you are the authenticated sender
        allow create: if isAuthenticated() && isOwner(request.resource.data.reader.id);
        // Can update (for response/pin) only if you are the author
        allow update: if isAuthenticated() && isOwner(resource.data.authorId);
        
        allow delete: if false; // Letters are not deletable
    }
  }
}
