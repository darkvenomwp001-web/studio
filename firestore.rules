
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users Collection
    // Users can read anyone's public profile.
    // Users can only write to their own document.
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Don't allow users to delete their own accounts from the client
    }
    
    // Stories Collection (Books)
    match /stories/{storyId} {
      // Anyone can read a story if it's public.
      // The author/collaborator can read it even if it's private/unlisted.
      allow read: if resource.data.visibility == 'Public' || 
                   (isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds));
      
      // Only signed-in users can create stories. The author ID must match the creator's ID.
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);

      // Only author or collaborators can update.
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds);
      
      // Only the author can delete.
      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }
    
    // UserStories Collection (Instagram-style)
    match /userStories/{userStoryId} {
      // The client query filters securely, so we only need to check for authentication here.
      allow read: if isSignedIn();
      
      // Allow create if the user is the author of the story they are creating.
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
      
      // Only the author can update or delete their own story.
      allow update, delete: if isSignedIn() && isOwner(resource.data.author.id);
    }
    
    // Comments Collection
    match /comments/{commentId} {
        allow read: if true;
        // User must be signed in to create.
        // User ID in the comment must match their own.
        allow create: if isSignedIn() && isOwner(request.resource.data.user.id);
        
        // Only the comment owner can update or delete.
        allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }
    
    // Notifications Collection
    match /notifications/{notificationId} {
        // Only the user the notification is for can read, update or delete it.
        allow read, update, delete: if isSignedIn() && isOwner(resource.data.userId);
        
        // This rule allows any signed-in user to create a notification, which is what `addNotification` does.
        allow create: if isSignedIn();
    }
    
    // FeedPosts Collection
    match /feedPosts/{postId} {
        allow read: if isSignedIn(); // Client-side query filters by followers
        allow create: if isSignedIn() && isOwner(request.resource.data.authorId);
        allow update: if isSignedIn(); // For liking
        allow delete: if isSignedIn() && isOwner(resource.data.authorId);
    }

    // Letters Collection
    match /letters/{letterId} {
        // Only the author of the story or the reader who sent the letter can read it.
        allow read: if isSignedIn() && (isOwner(resource.data.authorId) || isOwner(resource.data.reader.id));
        allow create: if isSignedIn() && isOwner(request.resource.data.reader.id); // Only the reader can create a letter
        allow update: if isSignedIn() && isOwner(resource.data.authorId); // Only the author can update (respond, pin)
        allow delete: if false;
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      // Only participants can read/update the conversation document
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      // Participants must be in the conversation to create it.
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;

      match /messages/{messageId} {
        // Only participants can read messages
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        // Only the sender can create a message, and they must be a participant.
        allow create: if isSignedIn() && isOwner(request.resource.data.senderId) && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
  }
}
