
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // --- Stories (Books) ---
    match /stories/{storyId} {
      function isAuthorOrCollaborator(checkResource) {
        let authorId = checkResource.data.author.id;
        let collaborators = checkResource.data.collaboratorIds;
        return isOwner(authorId) || (collaborators != null && collaborators.hasAny([request.auth.uid]));
      }

      allow read: if isSignedIn() && (
        resource.data.visibility == 'Public' ||
        resource.data.visibility == 'Unlisted' ||
        isAuthorOrCollaborator(resource)
      );
      
      // Anyone can create a story for themselves
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);

      // Only author/collaborators can update
      allow update: if isSignedIn() && isAuthorOrCollaborator(resource);

      // Only the original author can delete
      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }

    // --- Comments ---
    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(request.resource.data.user.id);
      allow update: if isSignedIn() && isOwner(resource.data.user.id);
      
      function isStoryAuthor() {
        let storyDoc = get(/databases/$(database)/documents/stories/$(resource.data.storyId));
        return storyDoc.data.author.id == request.auth.uid;
      }
      
      allow delete: if isSignedIn() && (isOwner(resource.data.user.id) || isStoryAuthor());
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && isOwner(resource.data.userId);
      // Notifications are created server-side, no client writes.
      allow create, delete: if false; 
    }

    // --- Letters ---
    match /letters/{letterId} {
      allow read, update: if isSignedIn() && (isOwner(resource.data.authorId) || isOwner(resource.data.reader.id));
      allow create: if isSignedIn() && isOwner(request.resource.data.reader.id);
    }

    // --- Ephemeral User Stories ---
    match /userStories/{storyId} {
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow read: if isSignedIn(); // App logic filters to show only followed users' stories
      allow delete, update: if isSignedIn() && isOwner(resource.data.userId);
    }
    
    // --- Live Feed Posts ---
    match /feedPosts/{postId} {
      // Any signed-in user can read the feed. The query has its own constraints.
      // This rule must be broad enough to allow the query to be attempted.
      allow read: if isSignedIn();
      
      // A user can create a post if their UID matches the post's authorId.
      allow create: if isSignedIn() && isOwner(request.resource.data.authorId);
      
      // Any signed-in user can like/unlike a post.
      allow update: if isSignedIn();
      
      // Only the author can delete their own post.
      allow delete: if isSignedIn() && isOwner(resource.data.authorId);
    }
    
    // --- Conversations & Messages ---
    match /conversations/{conversationId} {
      function isInConversation() {
        return resource.data.participantIds.hasAny([request.auth.uid]);
      }
      
      allow read, update: if isSignedIn() && isInConversation();
      allow create: if isSignedIn() && request.resource.data.participantIds.hasAny([request.auth.uid]);

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid]);
      }
    }
  }
}
