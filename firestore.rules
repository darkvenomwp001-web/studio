rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================

    function isAuthor(docData) {
      return request.auth.uid == docData.author.id;
    }
    
    function isAuthorOrCollaborator(storyData) {
      let isAuthor = request.auth.uid == storyData.author.id;
      let isCollaborator = request.auth.uid in storyData.collaboratorIds;
      return isAuthor || isCollaborator;
    }
    
    function isAuthorOfStatus(statusData) {
        let isAuthorById = request.auth.uid == statusData.authorId;
        let isAuthorByInfo = request.auth.uid == statusData.authorInfo.id;
        return isAuthorById || isAuthorByInfo;
    }
    
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // New Helper for Admins - exciting feature #4
    function isAdmin() {
      // In a real app, this list would be managed in a secure collection.
      // For now, you can manually add your own UID here for testing.
      let adminUIDs = [];
      return request.auth.uid in adminUIDs;
    }

    // New Helper for rate limiting - exciting feature #2
    function isRateLimited() {
      // Prevent updates more than once every 2 seconds.
      return request.time > resource.data.updatedAt + duration.value(2, 's');
    }

    // =================================
    // Collections
    // =================================

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId;
      // Rule #1: Lock Down User Profiles
      // Rule #4 (partial): Only admins can change roles
      // Rule #5: Prevent Self-Following
      allow update: if request.auth.uid == userId
                    && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin())
                    && !(userId in request.resource.data.followingIds);
    }
    
    match /stories/{storyId} {
      // Rule for premium chapter access
      allow read: if resource.data.visibility == 'Public' || 
                   (resource.data.visibility == 'Unlisted' && isSignedIn()) ||
                   (isAuthorOrCollaborator(resource.data));
                   
      allow create: if isAuthor(request.resource.data);
      // Rule #2: Secure Story Ownership
      allow update: if isAuthorOrCollaborator(resource.data);
      allow delete: if isAuthor(resource.data);

      match /chapters/{chapterId} {
        // This is a virtual rule for data inside the story document, not a real subcollection
        // The logic for reading chapters is handled by the parent story's read rule.
        // Exciting feature #1: enforce premium access logic.
        allow read: if resource.data.accessType != 'premium' || 
                     (isSignedIn() && (
                       isAuthorOrCollaborator(get(/databases/$(database)/documents/stories/$(storyId)).data) ||
                       (chapterId in get(/databases/$(database)/documents/stories/$(storyId)).data.chapters &&
                        get(/databases/$(database)/documents/stories/$(storyId)).data.chapters[chapterId].allowedUsers[request.auth.uid].expiresAt > request.time)
                     ));
      }
    }

    match /feedPosts/{postId} {
      allow read: if true;
      // Rule #3 (partial): Enforce data integrity on creation
      allow create: if isAuthor(request.resource.data);
      allow update, delete: if isAuthor(resource.data);
    }

    match /prompts/{promptId} {
      allow read: if resource.data.isArchived == false;
      // Rule #3 (partial): Enforce data integrity on creation
      allow create: if isAuthor(request.resource.data);
      allow update, delete: if isAuthor(resource.data);
    }

    match /statusUpdates/{statusId} {
      allow read: if true;
      // Rule #5: Enforce Required Fields
      allow create: if isAuthorOfStatus(request.resource.data)
                    && request.resource.data.authorId == request.auth.uid
                    && 'mediaUrl' in request.resource.data
                    && 'expiresAt' in request.resource.data
                    && request.resource.data.isArchived == false
                    && request.resource.data.isTrashed == false;

      // Rule #1 & #3 & #4: Secure & Logical Updates
      allow update: if isAuthorOfStatus(resource.data)
                    // Rule #2: Immutable fields
                    && request.resource.data.authorId == resource.data.authorId
                    && request.resource.data.createdAt == resource.data.createdAt
                    // Rule #3: Logical state flow (can't trash if not archived)
                    && (!('isTrashed' in request.resource.data && request.resource.data.isTrashed == true) || resource.data.isArchived == true);
      
      // Rule #4: Secure Deletion
      allow delete: if isAuthorOfStatus(resource.data) && resource.data.isTrashed == true;
    }

    match /conversations/{conversationId} {
      allow read, update: if request.auth.uid in resource.data.participantIds;
      allow create: if request.auth.uid in request.resource.data.participantIds;
      
      // Rule #4: Protect Private Conversations
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if request.auth.uid == resource.data.senderId;
      }
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.user.id;
    }
    
    match /notifications/{notificationId} {
        allow read, update, delete: if request.auth.uid == resource.data.userId;
        allow create: if isSignedIn(); // Server-side logic should validate this further
    }

    match /letters/{letterId} {
        allow read, update: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.reader.id;
        allow delete: if false; // Letters cannot be deleted by clients
    }
    
    // New Collection for enforcing "one like per user" - for exciting feature #3
    match /likes/{likeId} {
        // A like document ID could be `${userId}_${postId}`
        allow read: if true;
        allow create: if request.auth.uid == request.resource.data.userId;
        allow delete: if request.auth.uid == resource.data.userId;
        allow update: if false; // Likes cannot be updated
    }
  }
}
