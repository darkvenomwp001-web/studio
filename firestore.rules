
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if a user is the owner of a resource
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // USERS collection
    match /users/{userId} {
      // Anyone can read a user's public profile
      allow read: if true;
      // Only the user themselves can create their own document or update it
      allow create, update: if isOwner(userId);
    }

    // STORIES collection
    match /stories/{storyId} {
        // Read access control based on story visibility
        allow read: if resource.data.visibility == 'Public'
                    || resource.data.visibility == 'Unlisted'
                    || (isAuthenticated() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds));
        
        // Create access: Must be authenticated
        allow create: if isAuthenticated() && isOwner(request.resource.data.author.id);

        // Update access: Must be the author or a collaborator
        allow update: if isAuthenticated() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds);

        // Delete access: Only the author can delete their story
        allow delete: if isAuthenticated() && isOwner(resource.data.author.id);
    }
    
    // NOTIFICATIONS collection
    match /notifications/{notificationId} {
        // Users can only read their own notifications
        allow read: if isAuthenticated() && isOwner(resource.data.userId);
        // Notifications are created by server-side actions, but we can allow users to update the 'isRead' status
        allow update: if isAuthenticated() && isOwner(resource.data.userId);
        // No one can create/delete notifications from the client
        allow create, delete: if false;
    }

    // COMMENTS collection
    match /comments/{commentId} {
      // Anyone can read comments
      allow read: if true;
      // Authenticated users can create comments
      allow create: if isAuthenticated() && isOwner(request.resource.data.user.id);
      // Only the author of the comment can update or delete it
      allow update, delete: if isAuthenticated() && isOwner(resource.data.user.id);
    }
    
    // LETTERS collection
    match /letters/{letterId} {
      // Reader and author can read.
      allow read: if isAuthenticated() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
      // Only the reader can create a letter
      allow create: if isAuthenticated() && isOwner(request.resource.data.reader.id);
      // Only the author can update (e.g. to respond, pin)
      allow update: if isAuthenticated() && isOwner(resource.data.authorId);
      // No one can delete letters from the client.
      allow delete: if false;
    }

    // CONVERSATIONS collection
    match /conversations/{conversationId} {
        // Only participants can read the conversation document
        allow read: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
        // Participants can create conversations
        allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participantIds;
        // Only participants can update (e.g. lastMessage, updatedAt)
        allow update: if isAuthenticated() && request.auth.uid in resource.data.participantIds;

        // MESSAGES subcollection
        match /messages/{messageId} {
             // Only participants can read messages
            allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
            // Only participants can create messages
            allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
            // Users cannot update or delete messages from the client
            allow update, delete: if false;
        }
    }
    
    // STATUS UPDATES collection
    match /statusUpdates/{statusId} {
      // Anyone can read status updates
      allow read: if true;
      // Only authenticated users can create their own status updates
      allow create: if isAuthenticated() && isOwner(request.resource.data.authorId);
      // Nobody can update or delete status updates from the client
      allow update, delete: if false;
    }

    // FEED POSTS collection
    match /feedPosts/{postId} {
      // Anyone can read feed posts
      allow read: if true;
      // Authenticated users can create posts
      allow create: if isAuthenticated() && isOwner(request.resource.data.authorId);
      // Allow authenticated users to update only the 'likedBy' and 'likesCount' fields
      allow update: if isAuthenticated() && request.auth.uid != null;
      // Nobody can delete feed posts from the client
      allow delete: if false;
    }

    // LIVE FEED collection
    match /liveFeed/{postId} {
      // Anyone can read the live feed
      allow read: if true;
      // Authenticated users can create posts
      allow create: if isAuthenticated() && isOwner(request.resource.data.authorId);
      // No client-side updates or deletes
      allow update, delete: if false;
    }

    // PROMPTS collection
    match /prompts/{promptId} {
      // Anyone can read prompts
      allow read: if true;
      // Authenticated users can create prompts
      allow create: if isAuthenticated() && isOwner(request.resource.data.author.id);
       // No client-side updates or deletes
      allow update, delete: if false;
    }
  }
}
