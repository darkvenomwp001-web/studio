rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isStoryAuthor(storyId) {
      return get(/databases/$(database)/documents/stories/$(storyId)).data.author.id == request.auth.uid;
    }
    function isStoryCollaborator(storyId) {
      return request.auth.uid in get(/databases/$(database)/documents/stories/$(storyId)).data.collaboratorIds;
    }
    
    // User Profiles
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && request.resource.data.username is string;
      allow update: if isOwner(userId);
    }
    
    // Stories
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || (isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || isStoryCollaborator(storyId));
      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }

    // Comments
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn(); // Can be created by server actions
    }

    // Letters
    match /letters/{letterId} {
      allow read: if isSignedIn() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
      allow create: if isSignedIn() && isOwner(request.resource.data.reader.id);
      allow update: if isSignedIn() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
    }
    
    // Simplified Q&A Rules for Testing
    match /questions/{questionId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.questionText is string
                    && request.resource.data.questionText.size() > 9
                    && request.resource.data.questionText.size() < 1001
                    && request.resource.data.asker.id == request.auth.uid
                    && request.resource.data.status == 'unanswered'
                    && !('answerText' in request.resource.data);

      // Disable update/delete for this test to isolate the creation issue.
      allow update, delete: if false;
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read, update, create: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
  }
}
