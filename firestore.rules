rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (
        // Case 1: The user is updating their own profile.
        isOwner(userId) ||
        // Case 2: Another user is following/unfollowing this user.
        (
          // Ensure ONLY followersCount and updatedAt are being changed.
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount', 'updatedAt']) &&
          // Logic for a valid follow/unfollow action.
          (
            // Follow: Incrementing by 1
            request.resource.data.followersCount == resource.data.followersCount + 1 ||
            // Unfollow: Decrementing by 1, but only if the count is already > 0
            (request.resource.data.followersCount == resource.data.followersCount - 1 && resource.data.followersCount > 0)
          )
        )
      );
    }

    // Stories collection rules
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                   || resource.data.visibility == 'Unlisted' 
                   || (isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }
    
    // Comments collection rules
    match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }
    
    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read, create, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn(); // Allow any signed-in user to create a notification (e.g. for following someone)
    }
  }
}
