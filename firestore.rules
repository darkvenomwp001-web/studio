
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // Core Helper Functions
    // ========================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isDocumentOwner(doc, ownerField) {
      return isSignedIn() && request.auth.uid == doc[ownerField];
    }
    
    function isAuthor(doc) {
      return isSignedIn() && 
             (('author' in doc && 'id' in doc.author && request.auth.uid == doc.author.id) ||
              ('authorId' in doc && request.auth.uid == doc.authorId));
    }

    function isAuthorOrCollaborator(storyDoc) {
      return isSignedIn() && 
             (isAuthor(storyDoc) ||
              ('collaboratorIds' in storyDoc && request.auth.uid in storyDoc.collaboratorIds));
    }
    
    function isAdmin() {
      // Add your admin UIDs here for testing
      return isSignedIn() && request.auth.uid in [];
    }

    // ========================================
    // Collection Rules
    // ========================================

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId || isAdmin();
    }
    
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' ||
                   (resource.data.visibility == 'Unlisted' && isSignedIn()) ||
                   isAuthorOrCollaborator(resource.data);
      allow create: if isAuthor(request.resource.data);
      allow update: if isAuthorOrCollaborator(resource.data);
      allow delete: if isAuthor(resource.data);
    }

    match /statusUpdates/{statusId} {
      allow read: if resource.data.status == 'published' || 
                   (isSignedIn() && request.auth.uid == resource.data.authorId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.authorId;
    }

    match /prompts/{promptId} {
      allow read: if true;
      allow create: if isAuthor(request.resource.data);
      allow update, delete: if isAuthor(resource.data);
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.user.id;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.user.id;
    }
    
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isAuthor(request.resource.data);
      allow update, delete: if isAuthor(resource.data);
    }
    
    match /notifications/{notificationId} {
      allow read, update, delete: if isDocumentOwner(resource.data, 'userId');
      allow create: if isSignedIn(); // Allow server/other users to create notifications for a user
    }
    
    match /letters/{letterId} {
      allow read, update: if isSignedIn() && 
                            (request.auth.uid == resource.data.authorId || 
                             request.auth.uid == resource.data.reader.id);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.reader.id;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.reader.id;
    }
    
    match /conversations/{conversationId} {
      allow read, create, update, delete: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create, update, delete: if isSignedIn() && 
                                               request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
  }
}
