
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can read any profile, but only write to their own.
    match /users/{userId} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Public stories are readable by anyone.
    // Private/unlisted stories are only readable by author/collaborators.
    // Authors/collaborators can write to their stories.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                    || (request.auth != null && request.auth.uid in resource.data.collaboratorIds)
                    || (request.auth != null && request.auth.uid == resource.data.author.id);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.author.id;
      allow update, delete: if request.auth != null && 
                              (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds);
    }
    
    // Authenticated users can create posts.
    // Users can only delete their own posts. (No updates allowed for simplicity).
    match /feedPosts/{postId} {
        allow read;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Authenticated users can create live feed posts.
    match /liveFeed/{postId} {
        allow read;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
        // No updates/deletes for live feed
    }
    
    // Authenticated users can create prompts.
    match /prompts/{promptId} {
        allow read;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.author.id;
    }
    
    // Authenticated users can create comments.
    // Users can edit/delete their own comments.
    match /comments/{commentId} {
        allow read;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.user.id;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.user.id;
    }
    
    // Users can create letters.
    // The author of the story can update the letter (to respond or pin).
    match /letters/{letterId} {
        allow read;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.reader.id;
        allow update: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Users can read/write to conversations they are part of.
    match /conversations/{conversationId} {
      allow read, update: if request.auth.uid in resource.data.participantIds;
      allow create: if request.auth.uid in request.resource.data.participantIds;
      
      // Users can read/write messages in conversations they are part of.
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
    
    // Users can read their own notifications.
    // Authenticated users can create notifications for others.
    // Users can update their own notifications (e.g., mark as read).
    match /notifications/{notificationId} {
      allow read, update: if request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.actor.id;
    }

    // Status updates are public for 24 hours. Only owner can create.
    match /statusUpdates/{statusId} {
        allow read: if resource.data.expiresAt > request.time;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
    }

  }
}
