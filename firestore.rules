
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isOwnerOfStatus() {
        return request.auth.uid == resource.data.authorId;
    }
    
    function isCreatingOwnStatus() {
        return request.auth.uid == request.resource.data.authorId;
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // USERS
    match /users/{userId} {
      allow read: if true;
      allow create, update, delete: if isOwner(userId);
    }
    
    // STORIES
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                  || resource.data.visibility == 'Unlisted'
                  || (request.auth != null && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds));
      allow create: if request.auth != null && isOwner(request.resource.data.author.id);
      allow update: if request.auth != null && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if request.auth != null && isOwner(resource.data.author.id);
    }
    
    // COMMENTS
    match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && isOwner(request.resource.data.user.id);
        allow update, delete: if request.auth != null && isOwner(resource.data.user.id);
    }

    // NOTIFICATIONS
     match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && isOwner(resource.data.userId);
        // Create is handled by server-side actions (backend function or another rule)
        allow create: if true; // Simplification for now, should be locked down in prod
    }

    // CONVERSATIONS
    match /conversations/{conversationId} {
        allow read, update, create: if request.auth != null && request.auth.uid in resource.data.participantIds;

        match /messages/{messageId} {
            allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
    }
    
    // FEED
    match /feedPosts/{postId} {
        allow read: if true;
        allow create: if request.auth != null && isOwner(request.resource.data.author.id);
        allow update: if request.auth != null; // Liking is an update
        allow delete: if request.auth != null && isOwner(resource.data.author.id);
    }
    
    // PROMPTS
    match /prompts/{promptId} {
        allow read: if resource.data.isArchived == false;
        allow create: if request.auth != null && isOwner(request.resource.data.author.id);
        allow update, delete: if request.auth != null && isOwner(resource.data.author.id);
    }
    
    // LETTERS
    match /letters/{letterId} {
        allow read: if resource.data.visibility == 'public' || (request.auth != null && (isOwner(resource.data.authorId) || isOwner(resource.data.reader.id)));
        allow create: if request.auth != null && isOwner(request.resource.data.reader.id);
        allow update: if request.auth != null && isOwner(resource.data.authorId); // Only author can pin/respond
        allow delete: if request.auth != null && isOwner(resource.data.reader.id); // Only reader can delete
    }

    // STATUS UPDATES
    match /statusUpdates/{statusId} {
      allow read: if resource.data.status == 'published' && resource.data.expiresAt > request.time;
      allow create: if request.auth != null && isCreatingOwnStatus();
      allow update: if request.auth != null && isOwnerOfStatus();
      allow delete: if request.auth != null && isOwnerOfStatus();
    }
  }
}
