rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthor(docId) {
      return request.auth.uid == docId;
    }

    function isAuthorOf(docData) {
      return request.auth.uid == docData.author.id || request.auth.uid == docData.authorId;
    }

    // Correctly handles both read (resource) and write (request.resource) operations.
    function isAuthorOrCollaborator(storyId) {
      let storyData = get(/databases/$(database)/documents/stories/$(storyId)).data;
      return request.auth.uid == storyData.author.id || request.auth.uid in storyData.collaboratorIds;
    }

    function isAdmin() {
      // Define a list of admin UIDs here.
      let admins = [];
      return request.auth.uid in admins;
    }
    
    // --- Collection Rules ---

    // Users: Can only be read by anyone, but only the user themselves can update their own profile.
    // Cannot delete users from the client.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if isAuthor(userId)
                    // Protect against direct follower/following count manipulation from client
                    && !('followersCount' in request.resource.data)
                    // Prevent self-follow
                    && !(userId in request.resource.data.followingIds);
      allow create: if isAuthor(userId);
      allow delete: if false; 
    }

    // Stories: Public stories are readable by anyone. Only author/collaborators can update.
    match /stories/{storyId} {
      allow get: if resource.data.visibility == 'Public' 
                  || resource.data.visibility == 'Unlisted' 
                  || isAuthorOrCollaborator(storyId);
      allow list: if request.auth != null; // Allow querying the collection
      allow create: if isAuthorOf(request.resource.data);
      allow update: if isAuthorOrCollaborator(storyId);
      allow delete: if isAuthorOf(resource.data);
    }
    
    // Status Updates: Readable by any authenticated user. Writable only by the author.
    match /statusUpdates/{statusId} {
      allow read: if request.auth != null;
      allow create: if isAuthorOf(request.resource.data);
      allow update: if isAuthorOf(resource.data)
                    // Prevent changing author or creation time
                    && request.resource.data.authorId == resource.data.authorId
                    && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthorOf(resource.data) && resource.data.isTrashed == true;
    }

    // Notifications: Only readable and updatable by the recipient.
    match /notifications/{notificationId} {
      allow read, update: if request.auth.uid == resource.data.userId;
      allow create: if request.auth != null; // Can be created by server actions/other users
    }

    // Feed Posts: Readable by any user, writable only by the author. No direct like manipulation.
    match /feedPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if isAuthorOf(request.resource.data);
      allow update: if isAuthorOf(resource.data) && !('likesCount' in request.resource.data);
    }

    // Comments: Readable by anyone, writable only by authenticated users.
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isAuthorOf(request.resource.data);
      allow update, delete: if isAuthorOf(resource.data);
    }

    // Letters: Readable by author or reader. Writable only by reader on creation. Updatable by author.
    match /letters/{letterId} {
      allow read: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
      allow create: if request.auth.uid == request.resource.data.reader.id;
      allow update: if request.auth.uid == resource.data.authorId;
    }

    // Prompts: Readable by anyone, writable by any authenticated user.
    match /prompts/{promptId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && isAuthorOf(request.resource.data);
        allow update, delete: if isAuthorOf(resource.data);
    }
    
    // Conversations: Only participants can access.
    match /conversations/{conversationId} {
      allow read, update, delete: if request.auth.uid in resource.data.participantIds;
      allow create: if request.auth.uid in request.resource.data.participantIds;

      // Messages subcollection
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false; // Messages are immutable
      }
    }
  }
}
