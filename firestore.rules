
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is an author or collaborator of a story
    function isAuthorOrCollaborator(storyId, userId) {
      let story = get(/databases/$(database)/documents/stories/$(storyId)).data;
      return story.author.id == userId || (userId in story.collaboratorIds);
    }
    
    // Helper function to check if a chapter in a story is published
    function isChapterPublished(storyId, chapterId) {
        let story = get(/databases/$(database)/documents/stories/$(storyId)).data;
        let chapter = story.chapters[chapterId]; // This is not how to access array elements by ID
        // This helper is too complex for security rules without direct map access.
        // Logic will be handled client-side and via read rules.
        return true; 
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      // Deny deletion of user documents for data integrity
      allow delete: if false;
    }

    match /stories/{storyId} {
      // Anyone can read public or unlisted stories
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted';
      
      // Logged-in users can read their own private stories or stories they collaborate on
      allow get: if request.auth != null && (isAuthorOrCollaborator(storyId, request.auth.uid));

      // Anyone can list public stories
      allow list: if resource.data.visibility == 'Public';
      
      // Only authenticated users who are authors or collaborators can create/update
      allow create, update: if request.auth != null && isAuthorOrCollaborator(storyId, request.auth.uid);
      
      // Only the original author can delete
      allow delete: if request.auth != null && resource.data.author.id == request.auth.uid;
    }

    match /comments/{commentId} {
        // Anyone can read comments
        allow read: if true;
        // Only authenticated users can create comments
        allow create: if request.auth != null && request.auth.uid == request.resource.data.user.id;
        // Only the user who created the comment can update or delete it
        allow update, delete: if request.auth != null && resource.data.user.id == request.auth.uid;
    }
    
    match /notifications/{notificationId} {
        // A user can only read or update their own notifications
        allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
        // Anyone can create a notification (e.g., system, other users following)
        // More specific rules can be added later if needed.
        allow create: if request.auth != null;
    }

    match /letters/{letterId} {
      // Can read if you are the sender (reader) or receiver (author)
      allow read: if request.auth != null && (request.auth.uid == resource.data.reader.id || request.auth.uid == resource.data.authorId);
      // Can create if you are the sender
      allow create: if request.auth != null && request.auth.uid == request.resource.data.reader.id;
      // Author can update to add a response or pin. Reader cannot update.
      allow update: if request.auth != null && request.auth.uid == resource.data.authorId;
      // No one can delete letters to preserve history. Can be changed if needed.
      allow delete: if false;
    }

    // Feed Posts
    match /feedPosts/{postId} {
      // Anyone authenticated can read posts. Client-side queries will filter for followers.
      allow read: if request.auth.uid != null;
      // Only the author can create a post
      allow create: if request.auth.uid != null && request.resource.data.authorId == request.auth.uid;
      // Only author can delete.
      allow delete: if request.auth.uid != null && resource.data.authorId == request.auth.uid;
      // Allow updates only for liking/unliking fields by any authenticated user.
      // The server action will enforce that a user can only add/remove their own ID.
      allow update: if request.auth.uid != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount']);
    }
  }
}
