
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to simplify conditions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isFollowing(targetUserId) {
      // Check if the user is following the target user
      // Note: This rule can be read-intensive on the client. For large scale apps, a separate 'followers' subcollection is better.
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             targetUserId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.followingIds;
    }

    // ===== USERS COLLECTION =====
    // Public read is allowed for profiles, only the user can update their own profile.
    match /users/{userId} {
      allow read: if true; // Public profiles
      allow create: if isOwner(userId); // Only the user can create their own profile
      allow update: if isOwner(userId); // Only the user can update their profile
      allow delete: if false; // Don't allow account deletion from the client
    }

    // ===== STORIES COLLECTION (Books) =====
    // Public can read if the story is 'Public' or 'Unlisted'. Only author/collaborators can create/update.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                    resource.data.visibility == 'Unlisted' || 
                    (isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid; // Author can create
      allow update: if isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isSignedIn() && resource.data.author.id == request.auth.uid; // Author can delete
    }

    // ===== USER NOTES COLLECTION (Messenger-style Notes) =====
    match /userNotes/{noteId} {
      allow read: if resource.data.expiresAt > request.time; // Anyone can read non-expired notes
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid; // Author can create
      allow update, delete: if false; // No updates or deletes from the client
    }

    // ===== COMMENTS COLLECTION =====
    // Public read is allowed. Only the user who created the comment can update or delete it.
    match /comments/{commentId} {
      allow read: if true; // Comments are public
      allow create: if isSignedIn(); // Any signed-in user can create comments
      allow update, delete: if isSignedIn() && resource.data.user.id == request.auth.uid; // Only the comment creator can update/delete
    }

    // ===== LETTERS COLLECTION =====
    // Can only be read by the author or the reader. Only the reader can create it. Only the author can update.
    match /letters/{letterId} {
      allow read, update: if isSignedIn() && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.reader.id; // Reader can create a letter
      allow delete: if false; // No delete access from the client
    }

    // ===== FEED POSTS COLLECTION =====
    match /feedPosts/{postId} {
      allow read: if true; // Public can read posts
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid; // Only the author can create a post
      allow update: if isSignedIn(); // Anyone signed in can like/unlike a post
      allow delete: if isSignedIn() && resource.data.author.id == request.auth.uid; // Only author can delete
    }

    // ===== NOTIFICATIONS COLLECTION =====
    // Notifications can only be accessed/modified by the user they are for.
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if true; // Typically created by server-side logic or trusted client actions
    }
  }
}
