
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check ownership across different data structures
    function isAuthor(userId, data) {
      return userId != null && (
        userId == data.authorId ||
        userId == data.author.id ||
        userId == data.user.id ||
        userId == data.authorInfo.id
      );
    }

    match /users/{userId} {
      allow read;
      allow write: if request.auth.uid == userId;
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                   (resource.data.visibility == 'Unlisted' && request.auth != null) ||
                   (request.auth.uid == resource.data.author.id) ||
                   (resource.data.collaboratorIds.hasAny([request.auth.uid]));

      allow create: if request.auth.uid == request.resource.data.author.id;

      allow update: if request.auth.uid == resource.data.author.id || 
                     (resource.data.collaboratorIds.hasAny([request.auth.uid]));
                     
      allow delete: if request.auth.uid == resource.data.author.id;
    }

    match /comments/{commentId} {
      allow read;
      allow create: if request.auth.uid == request.resource.data.user.id;
      allow update, delete: if request.auth.uid == resource.data.user.id;
    }
    
    match /notifications/{notificationId} {
        allow read, update, delete: if request.auth.uid == resource.data.userId;
        allow create: if request.auth.uid != null; // More specific rules might be needed depending on who can create notifications
    }
    
    match /conversations/{conversationId} {
        allow read, update, delete: if request.auth.uid in resource.data.participantIds;
        allow create: if request.auth.uid in request.resource.data.participantIds;
    }

    match /conversations/{conversationId}/messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if request.auth.uid == resource.data.senderId;
    }
    
    match /letters/{letterId} {
        allow read, update: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
        allow create: if request.auth.uid == request.resource.data.reader.id;
        allow delete: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
    }

    match /feedPosts/{postId} {
      allow read;
      allow create: if isAuthor(request.auth.uid, request.resource.data);
      allow update: if isAuthor(request.auth.uid, resource.data);
      allow delete: if isAuthor(request.auth.uid, resource.data);
    }

    match /liveFeed/{postId} {
      allow read;
      allow create: if isAuthor(request.auth.uid, request.resource.data);
      
      // Allow the owner to update specific fields: content, isArchived, isTrashed
      allow update: if isAuthor(request.auth.uid, resource.data) &&
                     (request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['content', 'isArchived', 'isTrashed', 'archivedAt', 'trashedAt']));

      allow delete: if isAuthor(request.auth.uid, resource.data);
    }

    match /prompts/{promptId} {
      allow read;
      allow create: if isAuthor(request.auth.uid, request.resource.data);
      allow update, delete: if isAuthor(request.auth.uid, resource.data);
    }
    
    match /statusUpdates/{statusId} {
        allow read: if request.auth != null;
        allow create: if isAuthor(request.auth.uid, request.resource.data);
        allow update, delete: if isAuthor(request.auth.uid, resource.data);
    }
    
    match /pendingDeletions/{deletionId} {
        allow read: if request.auth.uid == resource.data.requestedBy;
        allow create: if request.auth.uid == request.resource.data.requestedBy;
        // No one can update or delete these logs directly
        allow update, delete: if false;
    }
  }
}
