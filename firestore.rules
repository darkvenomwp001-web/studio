rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // USER PROFILES
    match /users/{userId} {
      allow read;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // STORIES
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || isOwner(resource.data.author.id) || (resource.data.collaboratorIds != null && request.auth.uid in resource.data.collaboratorIds);
      allow create, update: if isOwner(resource.data.author.id) || (resource.data.collaboratorIds != null && request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isOwner(resource.data.author.id);
    }

    // COMMENTS
    match /comments/{commentId} {
      allow read;
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (isOwner(resource.data.user.id));
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(resource.data.userId);
        allow create: if isAuthenticated();
    }
    
    // CONVERSATIONS
    match /conversations/{conversationId} {
      allow read, update: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read, create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }

    // LETTERS
    match /letters/{letterId} {
        allow read, create: if isAuthenticated();
        allow update: if isAuthenticated() && (isOwner(resource.data.authorId) || isOwner(resource.data.reader.id));
    }
    
    // FEED POSTS
    match /feedPosts/{postId} {
        allow read, create: if isAuthenticated();
        // Rely on server action for security check. Action needs read+delete permission.
        allow get, update, delete: if request.auth != null;
    }

    // LIVE FEED
    match /liveFeed/{postId} {
      allow read, create: if isAuthenticated();
      // Rely on server action for security check. Action needs read+delete permission.
      allow get, delete, update: if request.auth != null;
    }
    
    // PROMPTS
    match /prompts/{promptId} {
      allow read, create: if isAuthenticated();
      // Rely on server action for security check. Action needs read+delete permission.
      allow get, delete, update: if request.auth != null;
    }

    // STATUS UPDATES
    match /statusUpdates/{statusId} {
      allow read, create: if isAuthenticated();
      // Rely on server action for security check. Action needs read+delete permission.
      allow get, delete: if request.auth != null;
    }
  }
}
