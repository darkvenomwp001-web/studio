
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Universal helper function to check for ownership across different data structures
    function isAuthor(userId, data) {
      return userId == data.authorId || userId == data.author.id || userId == data.authorInfo.id || userId == data.user.id;
    }
    
    // User profiles: Can only be created by the user themselves.
    // Can only be read by anyone.
    // Can only be updated by the owner.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
    }

    // Stories: Can be created by any authenticated user.
    // Public stories can be read by anyone.
    // Stories can only be updated/deleted by their author or a collaborator.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                  || (request.auth.uid == resource.data.author.id)
                  || (request.auth.uid in resource.data.collaboratorIds);
      allow create: if request.auth != null;
      allow update, delete: if isAuthor(request.auth.uid, resource.data);
    }
    
    // Comments: Can be created by any authenticated user.
    // Can be read by anyone.
    // Can only be updated/deleted by their original author.
    match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if isAuthor(request.auth.uid, resource.data);
    }
    
    // Notifications: Can only be read, created, or updated by the user they are intended for.
    match /notifications/{notificationId} {
        allow read, create, update: if request.auth.uid == resource.data.userId;
    }

    // Letters: Can be created by any authenticated user.
    // Can only be read by the sender (reader) or receiver (author).
    // Can only be updated by the author (to respond or pin).
    match /letters/{letterId} {
      allow read: if request.auth.uid == resource.data.reader.id || request.auth.uid == resource.data.author.id;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.author.id;
    }

    // Conversations & Messages: Can only be accessed by participants.
    match /conversations/{conversationId} {
      allow read, create, update: if request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
    
    // Prompts: Can be read by anyone.
    // Can be created by any authenticated user.
    // Can only be updated (archived/deleted) by the original author.
     match /prompts/{promptId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAuthor(request.auth.uid, resource.data);
    }
    
    // Status Updates: Can be read and created by any authenticated user.
    // Any authenticated user can archive, trash, restore, or delete them.
    match /statusUpdates/{statusId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

  }
}
