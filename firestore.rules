
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // General user profiles
    match /users/{userId} {
      allow read;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Stories and their chapters
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || (request.auth != null && request.auth.uid in resource.data.collaboratorIds) || (request.auth != null && request.auth.uid == resource.data.author.id);
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if request.auth != null && request.auth.uid == resource.data.author.id;
    }

    // Comments on chapters
    match /comments/{commentId} {
      allow read;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.user.id;
      allow delete: if request.auth.uid == resource.data.user.id;
    }

    // Live Feed posts
    match /liveFeed/{postId} {
      allow read;
      allow create: if request.auth != null;
      // Robust rule: check for new top-level authorId OR old nested author.id
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.author.id);
    }

    // Writing Prompts
    match /prompts/{promptId} {
      allow read;
      allow create: if request.auth != null;
      // Robust rule: check for new top-level authorId OR old nested author.id
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.author.id);
    }
    
    // Status Updates
    match /statusUpdates/{statusId} {
      allow read;
      allow create: if request.auth != null;
      // Robust rule: check for authorId field to ensure ownership
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // User-to-user private messages
    match /conversations/{conversationId} {
      allow read, create, update: if request.auth != null && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }

    // Notifications for users
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
    
    // Letters between users and authors
    match /letters/{letterId} {
      allow read, create, update: if request.auth != null && (request.auth.uid == resource.data.reader.id || request.auth.uid == resource.data.author.id);
    }
  }
}
