
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthor(userId, data) {
      return userId == data.authorId ||
             (exists(data.author) && userId == data.author.id) ||
             (exists(data.authorInfo) && userId == data.authorInfo.id);
    }
    
    function isUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Collection Rules
    match /users/{userId} {
      allow read;
      allow create: if isUser(userId);
      allow update: if isUser(userId) && !(displayName in request.resource.data);
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || isUser(resource.data.author.id) || (resource.data.collaboratorIds != null && request.auth.uid in resource.data.collaboratorIds);
      allow create: if isUser(request.resource.data.author.id);
      allow update: if isUser(resource.data.author.id) || (resource.data.collaboratorIds != null && request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isUser(resource.data.author.id);
    }

    match /comments/{commentId} {
      allow read;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAuthor(request.auth.uid, resource.data);
    }

    match /notifications/{notificationId} {
        allow read, update: if isUser(resource.data.userId);
        allow create: if request.auth != null;
    }

    match /conversations/{conversationId} {
      allow read, create, update: if request.auth != null && request.auth.uid in resource.data.participantIds;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read, create: if request.auth != null && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid]);
    }
    
    match /statusUpdates/{statusId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null && isAuthor(request.auth.uid, resource.data) && (
        ('isArchived' in request.resource.data && request.resource.data.isArchived != resource.data.isArchived) ||
        ('isTrashed' in request.resource.data && request.resource.data.isTrashed != resource.data.isTrashed) ||
        ('trashedAt' in request.resource.data && request.resource.data.trashedAt != resource.data.trashedAt) ||
        ('isArchived' in request.resource.data && request.resource.data.isArchived == false) 
      );
      allow delete: if request.auth != null && isAuthor(request.auth.uid, resource.data);
    }

    match /prompts/{promptId} {
        allow read;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && isAuthor(request.auth.uid, resource.data);
    }
    
    match /letters/{letterId} {
        allow read, update: if request.auth != null && (isUser(resource.data.authorId) || isUser(resource.data.reader.id));
        allow create: if request.auth != null;
    }
    
    match /feedPosts/{postId} {
      allow read, create: if request.auth != null;
      allow update, delete: if isUser(resource.data.authorId);
    }
  }
}
