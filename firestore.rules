
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId &&
                    request.resource.data.keys().hasOnly(['displayName', 'bio', 'role', 'avatarUrl', 'updatedAt', 'followingIds', 'followingCount', 'readingList']);
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                   (resource.data.visibility == 'Unlisted' && request.auth != null) ||
                   (resource.data.visibility == 'Private' && request.auth != null && request.auth.uid == resource.data.author.id) ||
                   (request.auth != null && request.auth.uid in resource.data.collaboratorIds);
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
      allow update: if request.auth != null && 
                    (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if request.auth != null && request.auth.uid == resource.data.author.id;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.user.id == request.auth.uid;
      allow update: if request.auth != null && request.auth.uid == resource.data.user.id;
      allow delete: if request.auth != null && request.auth.uid == resource.data.user.id;
    }

    match /notifications/{notificationId} {
        allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
        allow create: if request.auth != null; // Server-side logic or trusted client action handles creation.
    }

    match /letters/{letterId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
      allow create: if request.auth != null && request.resource.data.reader.id == request.auth.uid;
      allow update: if request.auth != null && 
                     (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
    }
    
    match /statusUpdates/{statusId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['authorId', 'authorInfo', 'mediaUrl', 'mediaType', 'createdAt', 'expiresAt']);
    }
    
    match /feedPosts/{postId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
        // Allow anyone to update (for liking), but ONLY the likedBy and likesCount fields.
        allow update: if request.auth != null && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount']);
    }

    match /liveFeed/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
    }

    match /prompts/{promptId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
    }
  }
}
