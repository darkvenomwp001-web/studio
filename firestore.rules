
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getRole(userId) {
        return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    function isWriter() {
        return isSignedIn() && getRole(request.auth.uid) == 'writer';
    }
    
    function isAdmin() {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == 'authorrafaelnv';
    }
    
    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isAdmin(); // Only admin can delete users
    }

    // Stories Collection
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                    || (resource.data.visibility == 'Unlisted' && isSignedIn())
                    || (isSignedIn() && request.auth.uid == resource.data.author.id)
                    || (isSignedIn() && request.auth.uid in resource.data.collaboratorIds);

      allow create: if isWriter();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.author.id;
    }

    // Comments Collection on Chapters
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.user.id;
    }
    
    // Notifications Collection
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn(); // Can be created by server-side logic or trusted client actions
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read, create: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false; // Messages are immutable
      }
    }
    
    // Global Chat
    match /globalChatMessages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && !request.auth.token.isAnonymous;
      allow update, delete: if false;
    }

    // Status Updates
    match /statusUpdates/{statusId} {
      allow read: if resource.data.status == 'published' && resource.data.expiresAt > request.time;
      allow create: if isWriter() && request.auth.uid == request.resource.data.authorId;
      allow update: if isSignedIn() && isOwner(resource.data.authorId); // For hiding
      allow delete: if isSignedIn() && isOwner(resource.data.authorId);
    }

    // Prompts
    match /prompts/{promptId} {
      allow read: if resource.data.isArchived == false;
      allow create: if isWriter();
      allow update, delete: if isSignedIn() && isOwner(resource.data.author.id);
    }
    
    // Letters
    match /letters/{letterId} {
       allow read: if isSignedIn() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
       allow create: if isSignedIn();
       allow update: if isSignedIn() && isOwner(resource.data.authorId); // Only author can pin/respond
       allow delete: if isSignedIn() && isOwner(resource.data.reader.id); // Only reader can delete
    }

    // Annotations
    match /annotations/{annotationId} {
      allow read, create, update, delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // Announcements by authors
    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if isWriter() && isOwner(request.resource.data.author.id);
      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }
    
    // Feed Posts
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && !request.auth.token.isAnonymous;
      
      // Only author can update content, but anyone can update reactionsCount
      allow update: if isSignedIn() && 
                    ( (isOwner(resource.data.author.id) && request.resource.data.content != resource.data.content)
                      || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactionsCount'])) );
                      
      allow delete: if isSignedIn() && (isOwner(resource.data.author.id) || isAdmin());

      // Feed Post Comments Subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && !request.auth.token.isAnonymous;
        allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
      }
      
      // Feed Post Reactions Subcollection
      match /reactions/{userId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && isOwner(userId);
        allow update: if false; // No updates allowed, only create/delete
      }
    }
  }
}
