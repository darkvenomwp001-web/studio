
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isValidUser() {
      return request.auth != null && request.auth.uid != null;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Generally, don't allow users to delete their own accounts directly
    }

    // Stories Collection
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                   (resource.data.visibility == 'Unlisted' && isValidUser()) ||
                   (resource.data.author.id == request.auth.uid) ||
                   (request.auth.uid in resource.data.collaboratorIds);
      allow create: if isValidUser() && request.resource.data.author.id == request.auth.uid;
      allow update: if isValidUser() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isValidUser() && resource.data.author.id == request.auth.uid;
    }

    // Comments Collection
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isValidUser() && request.auth.uid == request.resource.data.user.id;
      allow update: if isValidUser() && resource.data.user.id == request.auth.uid;
      allow delete: if isValidUser() && resource.data.user.id == request.auth.uid;
    }

    // Notifications Collection
    match /notifications/{notificationId} {
        allow read, update: if resource.data.userId == request.auth.uid;
        allow create: if isValidUser(); // Can be created by server actions or other users (e.g. for follows)
        allow delete: if false;
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
        allow read, update: if isValidUser() && request.auth.uid in resource.data.participantIds;
        allow create: if isValidUser() && request.auth.uid in request.resource.data.participantIds;

        match /messages/{messageId} {
            allow read, create: if isValidUser() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
            allow update, delete: if false;
        }
    }
    
    // Global Chat Messages
    match /globalChatMessages/{messageId} {
      allow read: if true;
      allow create: if isValidUser() && request.resource.data.author.id == request.auth.uid;
      allow update, delete: if false;
    }
    
    // Status Updates
    match /statusUpdates/{statusId} {
      allow read: if true; // Statuses are public
      allow create: if isValidUser() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isValidUser() && resource.data.authorId == request.auth.uid;
    }

    // Prompts
    match /prompts/{promptId} {
        allow read: if resource.data.isArchived == false;
        allow create: if isValidUser() && request.resource.data.author.id == request.auth.uid;
        allow update, delete: if isValidUser() && resource.data.author.id == request.auth.uid;
    }
    
    // Letters
    match /letters/{letterId} {
        // Author and Reader can read. Public letters can be read by anyone.
        allow read: if resource.data.visibility == 'public' || 
                     (isValidUser() && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id));
        allow create: if isValidUser() && request.resource.data.reader.id == request.auth.uid;
        // Author can update to pin/unpin or respond.
        allow update: if isValidUser() && request.auth.uid == resource.data.authorId;
        // Reader can delete their sent letter.
        allow delete: if isValidUser() && request.auth.uid == resource.data.reader.id;
    }
  }
}
