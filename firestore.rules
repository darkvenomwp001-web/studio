rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read any profile, but only write to their own.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Do not allow users to be deleted
    }

    // Stories can be read if public/unlisted. Can be created by any authenticated user.
    // Can only be updated/deleted by the author or a collaborator.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted';
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds);
    }

    // Comments can be read by anyone. Can be created by any authenticated user.
    // Can only be updated/deleted by the person who wrote the comment.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.user.id == request.auth.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.user.id;
    }

    // Letters can be read by the sender (reader) or receiver (author).
    // Can be created by authenticated users.
    // Can only be updated by the author (to pin or respond).
    match /letters/{letterId} {
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.reader.id || request.auth.uid == resource.data.author.id);
      allow create: if request.auth != null && request.resource.data.reader.id == request.auth.uid;
      allow delete: if false; // Letters are not deletable
    }

    // Notifications can only be read/updated by the user they are for.
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if true; // Created by server actions
      allow delete: if false;
    }

    // Conversations can be read/updated by participants.
    match /conversations/{conversationId} {
      allow read, update: if request.auth.uid in resource.data.participantIds;
      allow create: if request.auth.uid in request.resource.data.participantIds;

      // Messages within a conversation.
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }

    // Q&A Questions
    match /questions/{questionId} {
      allow read: if true;
      
      // Allow creation if the user is authenticated and the asker ID matches.
      // Basic validation on the data.
      allow create: if request.auth != null
                    && request.resource.data.asker.id == request.auth.uid
                    && request.resource.data.questionText is string
                    && request.resource.data.questionText.size() >= 10
                    && request.resource.data.questionText.size() <= 1000
                    && request.resource.data.status == 'unanswered'
                    && !('answerText' in request.resource.data);

      // Allow updates for:
      // 1. The original asker editing their own UNANSWERED question.
      // 2. The target author answering or declining the question.
      allow update: if request.auth != null && (
                      (resource.data.asker.id == request.auth.uid && resource.data.status == 'unanswered') ||
                      (resource.data.targetAuthor != null && resource.data.targetAuthor.id == request.auth.uid)
                    );

      // Allow deletion for:
      // 1. The original asker.
      // 2. The target author.
      allow delete: if request.auth != null && (
                      resource.data.asker.id == request.auth.uid ||
                      (resource.data.targetAuthor != null && resource.data.targetAuthor.id == request.auth.uid)
                    );
    }
  }
}