
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isStoryOwner(story) {
      return isOwner(story.author.id);
    }

    match /users/{userId} {
      allow read;
      allow write: if isOwner(userId);
    }
    
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted';
      allow write: if isAuthenticated() && isStoryOwner(request.resource.data);
      
      match /chapters/{chapterId} {
        allow read, write: if isAuthenticated() && isStoryOwner(get(/databases/$(database)/documents/stories/$(storyId)).data);
      }
    }

    match /comments/{commentId} {
        allow read;
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && isOwner(resource.data.user.id);
    }

    match /notifications/{notificationId} {
        allow read, write: if isAuthenticated() && isOwner(resource.data.userId);
    }

    match /conversations/{conversationId} {
        allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
        
        match /messages/{messageId} {
            allow read, write: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
    }

    match /feedPosts/{postId} {
        allow read;
        allow create: if isAuthenticated() && isOwner(request.resource.data.authorId);
        allow update: if isAuthenticated();
    }
    
    match /prompts/{promptId} {
        allow read;
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && isOwner(resource.data.author.id);
    }

    match /letters/{letterId} {
        allow read: if isAuthenticated() && (
            isOwner(resource.data.reader.id) ||
            isOwner(resource.data.authorId) ||
            resource.data.visibility == 'public'
        );
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && isOwner(resource.data.authorId);
        allow delete: if isAuthenticated() && isOwner(resource.data.reader.id);
    }

    match /statusUpdates/{statusId} {
        // Anyone can read published, non-expired statuses
        allow read: if resource.data.status == 'published' && resource.data.expiresAt > request.time;
        // The owner can read their own statuses regardless of state (draft, archived, trashed)
        allow read: if isAuthenticated() && isOwner(resource.data.authorId);

        // Any authenticated user can create a status for themselves
        allow create: if isAuthenticated() && isOwner(request.resource.data.authorId);
        
        // Only the owner can update their status (e.g., to archive or trash it)
        allow update: if isAuthenticated() && isOwner(resource.data.authorId);

        // Only the owner can permanently delete their status
        allow delete: if isAuthenticated() && isOwner(resource.data.authorId);
    }
  }
}
