rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isNotGuest() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Collections
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      // Deny deletion of user accounts through client-side requests
      allow delete: if false;
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || isOwner(resource.data.author.id) || (resource.data.collaboratorIds != null && request.auth.uid in resource.data.collaboratorIds);
      allow create: if isNotGuest() && request.auth.uid == request.resource.data.author.id;
      allow update: if isNotGuest() && (isOwner(resource.data.author.id) || (resource.data.collaboratorIds != null && request.auth.uid in resource.data.collaboratorIds));
      allow delete: if isNotGuest() && isOwner(resource.data.author.id);
    }
    
    match /comments/{commentId} {
        allow read: if true;
        allow create: if isNotGuest();
        allow update, delete: if isNotGuest() && isOwner(resource.data.user.id);
    }

    match /notifications/{notificationId} {
      allow read, update: if isOwner(resource.data.userId);
      allow create: if isNotGuest(); // More specific rules could be needed depending on who can trigger notifications
      allow delete: if false; // Generally, users shouldn't delete notifications directly
    }

    match /conversations/{conversationId} {
      allow read, update: if request.auth.uid in resource.data.participantIds;
      allow create: if isNotGuest() && request.auth.uid in request.resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false; // Disallow editing/deleting messages for integrity
      }
    }
    
    match /globalChatMessages/{messageId} {
      allow read: if true;
      allow create: if isNotGuest() && request.auth.uid == request.resource.data.author.id;
      allow update, delete: if false;
    }

    match /statusUpdates/{statusId} {
      allow read: if resource.data.status == 'published' || isOwner(resource.data.authorId);
      allow create: if isNotGuest() && request.auth.uid == request.resource.data.authorId;
      allow update: if isNotGuest() && isOwner(resource.data.authorId);
      allow delete: if isNotGuest() && isOwner(resource.data.authorId);
    }
    
    match /prompts/{promptId} {
      allow read: if resource.data.isArchived == false || isOwner(resource.data.author.id);
      allow create: if isNotGuest() && request.auth.uid == request.resource.data.author.id;
      allow update: if isNotGuest() && isOwner(resource.data.author.id);
      allow delete: if isNotGuest() && isOwner(resource.data.author.id);
    }

    match /letters/{letterId} {
      allow read: if isOwner(resource.data.reader.id) || isOwner(resource.data.authorId) || resource.data.visibility == 'public';
      allow create: if isNotGuest() && request.auth.uid == request.resource.data.reader.id;
      allow update: if isOwner(resource.data.authorId); // Only author can pin/respond
      allow delete: if isOwner(resource.data.reader.id); // Only reader can delete their letter
    }

    match /annotations/{annotationId} {
      allow read, write, delete: if isOwner(resource.data.userId);
      allow create: if isNotGuest() && isOwner(request.resource.data.userId);
    }

    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isNotGuest() && request.auth.uid == request.resource.data.author.id;
      allow update, delete: if isNotGuest() && isOwner(resource.data.author.id);
    }
  }
}
