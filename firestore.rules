
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the requesting user is the owner of a document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // ===== USERS COLLECTION =====
    // Public profiles are readable by anyone.
    // A user can only create and update their own document.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if false; // Deletion from client is disabled
    }

    // ===== STORIES COLLECTION (Books) =====
    // Public stories are readable by anyone.
    // Only authors/collaborators can create, update, or delete.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || (isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }
    
    // ===== USER STORIES COLLECTION (Instagram-style Stories) =====
    // This is the simplified rule. Anyone can read the stories collection.
    // The app's code is responsible for filtering out expired stories.
    // Only the author can create their own story.
    match /userStories/{userStoryId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(request.resource.data.authorId);
      allow update, delete: if false;
    }

    // ===== COMMENTS COLLECTION =====
    // Comments are public to read. Users can create comments.
    // Only the original commenter can edit or delete their own comment.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.user.id);
    }

    // ===== LETTERS COLLECTION =====
    // Only the sender (reader) or recipient (author) can read or update.
    // Only the sender can create a letter.
    match /letters/{letterId} {
      allow read, update: if isSignedIn() && (isOwner(resource.data.authorId) || isOwner(resource.data.reader.id));
      allow create: if isSignedIn() && isOwner(request.resource.data.reader.id);
      allow delete: if false;
    }

    // ===== FEED POSTS COLLECTION =====
    // The feed is public to read.
    // Users can only create posts for themselves.
    // Any signed-in user can update (e.g., for likes).
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.author.id);
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data.author.id);
    }
    
    // ===== NOTIFICATIONS COLLECTION =====
    // A user can only access their own notifications.
    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if true; // Created by server actions or trusted clients
    }
    
    // ===== CONVERSATIONS & MESSAGES =====
    // Users can only read/write to conversations they are a part of.
    match /conversations/{conversationId} {
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;

      // Messages can only be read/created by members of the conversation.
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false;
      }
    }
  }
}
