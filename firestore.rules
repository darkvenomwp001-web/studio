
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================================
    // AUTHENTICATION & AUTHORIZATION HELPERS
    // ============================================================================
    
    /**
     * Verifies that the request originates from an authenticated user
     * @returns {boolean} True if user is authenticated with a valid UID
     */
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }
    
    /**
     * Verifies that the authenticated user is not anonymous (guest)
     * Uses the sign_in_provider to check for anonymous authentication
     * @returns {boolean} True if user has a non-anonymous account
     */
    function isNotGuest() {
      return isAuthenticated() && 
             request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    /**
     * Checks if the authenticated user owns the specified resource
     * @param {string} userId - The user ID to check ownership against
     * @returns {boolean} True if the authenticated user matches the provided userId
     */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the authenticated user has read access to a story
     * @returns {boolean} True if story is public/unlisted, or user is author/collaborator
     */
    function canReadStory() {
      return resource.data.visibility == 'Public' 
          || resource.data.visibility == 'Unlisted'
          || isOwner(resource.data.author.id)
          || (resource.data.collaboratorIds != null && 
              request.auth.uid in resource.data.collaboratorIds);
    }
    
    /**
     * Checks if the authenticated user can write to a story
     * @returns {boolean} True if user is the author or a collaborator
     */
    function canWriteStory() {
      return isNotGuest() && 
             (isOwner(resource.data.author.id) || 
              (resource.data.collaboratorIds != null && 
               request.auth.uid in resource.data.collaboratorIds));
    }
    
    /**
     * Checks if user is a participant in a conversation
     * @param {string} conversationId - The conversation document ID
     * @returns {boolean} True if user is listed in participantIds
     */
    function isConversationParticipant(conversationId) {
      return isAuthenticated() && 
             request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
    }

    // ============================================================================
    // USERS COLLECTION
    // Purpose: Store user profiles and account information
    // ============================================================================
    
    match /users/{userId} {
      // Public read access for displaying user profiles
      allow read: if true;
      
      // Users can create and update their own profile
      allow create, update: if isOwner(userId);
      
      // Prevent direct account deletion - should be handled server-side
      allow delete: if false;
    }

    // ============================================================================
    // STORIES COLLECTION
    // Purpose: Main content repository for user-created stories
    // ============================================================================
    
    match /stories/{storyId} {
      // Read access based on visibility and ownership
      allow read: if canReadStory();
      
      // Only authenticated users can create stories with themselves as author
      allow create: if isNotGuest() && 
                      request.auth.uid == request.resource.data.author.id;
      
      // Authors and collaborators can update stories
      allow update: if canWriteStory();
      
      // Only the author can delete their story
      allow delete: if isNotGuest() && isOwner(resource.data.author.id);
    }

    // ============================================================================
    // COMMENTS COLLECTION
    // Purpose: User comments on stories and other content
    // ============================================================================
    
    match /comments/{commentId} {
      // Public read access for all comments
      allow read: if true;
      
      // Authenticated users can create comments
      allow create: if isNotGuest() && 
                      request.auth.uid == request.resource.data.user.id;
      
      // Users can only modify or delete their own comments
      allow update, delete: if isNotGuest() && isOwner(resource.data.user.id);
    }

    // ============================================================================
    // NOTIFICATIONS COLLECTION
    // Purpose: User notifications for activities and updates
    // ============================================================================
    
    match /notifications/{notificationId} {
      // Users can only read and update their own notifications
      allow read, update: if isOwner(resource.data.userId);
      
      // Allow creation by authenticated users (for system-generated notifications)
      allow create: if isNotGuest() && 
                      request.auth.uid == request.resource.data.userId;
      
      // Prevent deletion to maintain notification history
      allow delete: if false;
    }
    
    // ============================================================================
    // CONVERSATIONS COLLECTION
    // Purpose: Private messaging between users
    // ============================================================================
    
    match /conversations/{conversationId} {
      // Participants can read and update conversation metadata
      allow read, update: if isAuthenticated() && 
                            request.auth.uid in resource.data.participantIds;
      
      // Users can create conversations where they are a participant
      allow create: if isNotGuest() && 
                      request.auth.uid in request.resource.data.participantIds;
      
      // Prevent conversation deletion to preserve message history
      allow delete: if false;
      
      // ----------------------------------------------------------------------------
      // MESSAGES SUBCOLLECTION
      // Purpose: Individual messages within a conversation
      // ----------------------------------------------------------------------------
      
      match /messages/{messageId} {
        // Participants can read messages in their conversations
        allow read: if isConversationParticipant(conversationId);
        
        // Participants can send messages
        allow create: if isNotGuest() && 
                        isConversationParticipant(conversationId);
        
        // Messages are immutable once created
        allow update, delete: if false;
      }
    }
    
    // ============================================================================
    // GLOBAL CHAT MESSAGES COLLECTION
    // Purpose: Public chat room accessible to all users
    // ============================================================================
    
    match /globalChatMessages/{messageId} {
      // Public read access for community chat
      allow read: if true;
      
      // Authenticated users can post to global chat
      allow create: if isNotGuest() && 
                      request.auth.uid == request.resource.data.author.id;
      
      // Messages cannot be edited or deleted once posted
      allow update, delete: if false;
    }

    // ============================================================================
    // STATUS UPDATES COLLECTION
    // Purpose: Short-form status updates from users
    // ============================================================================
    
    match /statusUpdates/{statusId} {
      // Read access for published statuses or owner's own statuses
      allow read: if resource.data.status == 'published' || 
                    isOwner(resource.data.authorId);
      
      // Authenticated users can create status updates
      allow create: if isNotGuest() && 
                      request.auth.uid == request.resource.data.authorId;
      
      // Users can only manage their own status updates
      allow update, delete: if isNotGuest() && isOwner(resource.data.authorId);
    }
    
    // ============================================================================
    // PROMPTS COLLECTION
    // Purpose: Writing prompts created by the community
    // ============================================================================
    
    match /prompts/{promptId} {
      // Read access for non-archived prompts or owner's own prompts
      allow read: if resource.data.isArchived == false || 
                    isOwner(resource.data.author.id);
      
      // Writers can contribute new prompts
      allow create: if isNotGuest() && 
                      request.auth.uid == request.resource.data.author.id;
      
      // Only prompt creators can modify or remove their prompts
      allow update, delete: if isNotGuest() && isOwner(resource.data.author.id);
    }

    // ============================================================================
    // LETTERS COLLECTION
    // Purpose: User-to-user letters/messages with privacy controls
    // ============================================================================
    
    match /letters/{letterId} {
      // Read access for sender, recipient, or if public
      allow read: if isOwner(resource.data.reader.id) || 
                    isOwner(resource.data.authorId) || 
                    resource.data.visibility == 'public';
      
      // Users can send letters where they are the sender
      allow create: if isNotGuest() && 
                      request.auth.uid == request.resource.data.reader.id;
      
      // Only the recipient can update (e.g., mark as read, pin, respond)
      allow update: if isNotGuest() && isOwner(resource.data.authorId);
      
      // Only the sender can delete their sent letter
      allow delete: if isNotGuest() && isOwner(resource.data.reader.id);
    }

    // ============================================================================
    // ANNOTATIONS COLLECTION
    // Purpose: Private user annotations on content
    // Security: Strictly private to the creating user
    // ============================================================================
    
    match /annotations/{annotationId} {
      // Users can read, write, and delete their own annotations
      allow read, write, delete: if isOwner(resource.data.userId);
      
      // Users can create annotations for themselves
      allow create: if isNotGuest() && 
                      request.auth.uid == request.resource.data.userId;
    }

    // ============================================================================
    // FEED POSTS COLLECTION (THREADS TAB)
    // Purpose: Community forum threads and discussions
    // ============================================================================

    match /feedPosts/{postId} {
      // Public read access for all threads
      allow read: if true;
      
      // Any authenticated non-guest user can create a thread
      allow create: if isNotGuest() && 
                      request.auth.uid == request.resource.data.author.id;
      
      // Authors can update their own post content.
      // Any authenticated user can update the reaction count.
      allow update: if isNotGuest() && 
                      ( (request.auth.uid == resource.data.author.id && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content', 'updatedAt'])) ||
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactionsCount']))
                      );
      
      // Only the post author can delete their thread
      allow delete: if isNotGuest() && isOwner(resource.data.author.id);
      
      // --------------------------------------------------------------------------
      // COMMENTS SUBCOLLECTION (Thread Comments)
      // --------------------------------------------------------------------------
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isNotGuest() && 
                        request.auth.uid == request.resource.data.user.id;
        allow update: if isNotGuest() && 
                        request.auth.uid == resource.data.user.id;
        allow delete: if isNotGuest() && 
                        request.auth.uid == resource.data.user.id;
        
        // Comment reactions subcollection (for future emoji reactions)
        match /reactions/{reactionId} {
          allow read: if true;
          allow write: if isNotGuest() && request.auth.uid == reactionId;
        }
      }
      
      // --------------------------------------------------------------------------
      // POST REACTIONS SUBCOLLECTION
      // --------------------------------------------------------------------------
      
      match /reactions/{reactionId} {
        allow read: if true;
        
        // A user can create/update/delete their own reaction document,
        // where the document ID is their user ID.
        allow write: if isNotGuest() && request.auth.uid == reactionId;
      }
    }
  }
}
