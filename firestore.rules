
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to simplify conditions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===== USERS COLLECTION =====
    // Public read is allowed for profiles, only the user can update their own profile.
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Deleting users from the client is disabled for security.
    }

    // ===== STORIES COLLECTION (Books) =====
    // Public can read if 'Public' or 'Unlisted'. Only author/collaborators can create/update.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                    resource.data.visibility == 'Unlisted' || 
                    (isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isOwner(resource.data.author.id);
    }

    // ===== USER NOTES COLLECTION (Messenger-style Notes) =====
    // This rule allows the client-side query to securely fetch all active public notes.
    // The query in the app requires a composite index on (visibility, expiresAt).
    match /userNotes/{noteId} {
      allow read: if true; // Allow broad read for the query, client filters followers vs public.
      allow create: if isOwner(request.resource.data.authorId);
      allow update, delete: if isOwner(resource.data.authorId);
    }
    
    // ===== FEED POSTS COLLECTION =====
    // Defines the rules for the user-generated social feed.
    // This query requires a composite index on (authorId, timestamp).
    match /feedPosts/{postId} {
      // READ:
      // Any signed-in user can read the feed posts. The application code is responsible
      // for querying only posts from authors the current user follows. This rule
      // is designed to allow that specific query to execute and prompt for an index.
      allow read: if isSignedIn();

      // CREATE:
      // A user can only create a post if they are signed in and
      // the authorId of the new post matches their own user ID.
      // This prevents users from creating posts on behalf of others.
      allow create: if isOwner(request.resource.data.authorId);

      // UPDATE:
      // Any signed-in user can update a post.
      // This rule is intentionally broad to allow for social features
      // like 'liking' a post, which involves updating the 'likedBy' array.
      allow update: if isSignedIn();

      // DELETE:
      // A user can only delete a post if they are the original author.
      allow delete: if isOwner(resource.data.authorId);
    }

    // ===== COMMENTS COLLECTION =====
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.user.id);
    }

    // ===== LETTERS COLLECTION =====
    match /letters/{letterId} {
      allow read, update: if isSignedIn() && (isOwner(resource.data.authorId) || isOwner(resource.data.reader.id));
      allow create: if isSignedIn() && isOwner(request.resource.data.reader.id);
      allow delete: if false;
    }

    // ===== CONVERSATIONS & MESSAGES =====
    match /conversations/{conversationId} {
      allow read, create: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false;
      }
    }

    // ===== NOTIFICATIONS COLLECTION =====
    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if true; // Created by server actions or trusted client functions.
    }
  }
}
