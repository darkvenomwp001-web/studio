rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by anyone.
    // Users can only create their own user document.
    // Users can only update a specific set of fields on their own document.
    match /users/{userId} {
      allow read;
      allow create: if request.auth.uid == userId;

      function isUpdatingAllowedFields() {
        let allowedFields = [
          'displayName', 'username', 'bio', 'role', 'avatarUrl', 'updatedAt',
          'readingList', 'followingIds', 'followingCount', 'note'
        ];
        return request.resource.data.keys().hasAll(allowedFields) &&
               request.resource.data.keys().size() == allowedFields.size();
      }

      allow update: if request.auth.uid == userId;
    }

    // Stories can be created by any authenticated user.
    // Stories can be read if they are public or unlisted.
    // Private stories can only be read by the author or collaborators.
    // Stories can only be updated or deleted by the author or collaborators.
    match /stories/{storyId} {
      allow create: if request.auth.uid == request.resource.data.author.id;
      
      allow read: if resource.data.visibility == 'Public' ||
                     resource.data.visibility == 'Unlisted' ||
                     (request.auth != null && resource.data.author.id == request.auth.uid) ||
                     (request.auth != null && resource.data.collaboratorIds.hasAny([request.auth.uid]));

      allow update, delete: if request.auth != null &&
                               (resource.data.author.id == request.auth.uid ||
                                resource.data.collaboratorIds.hasAny([request.auth.uid]));
    }

    // Comments can be read by anyone.
    // Comments can be created by any authenticated user.
    // Comments can only be updated or deleted by their original author.
    match /comments/{commentId} {
      allow read;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.user.id;
    }

    // Notifications are private and can only be accessed by the user they are intended for.
    match /notifications/{notificationId} {
      allow read, write: if request.auth.uid == resource.data.userId;
    }
    
    // Letters are private between the reader and the author.
    match /letters/{letterId} {
      allow read, write: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
    }

    // Questions are public to read.
    // Authenticated users can create questions.
    // Questions can only be deleted by the user who asked them.
    match /questions/{questionId} {
      allow read;
      allow create: if request.auth.uid == request.resource.data.asker.id;
      allow delete: if request.auth.uid == resource.data.asker.id;
    }

    // Conversations are private to participants.
    match /conversations/{conversationId} {
      allow read, write: if request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
         allow read, write: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
  }
}
