rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Reusable helper function to robustly check ownership of any document
    // that has an author summary object or a direct authorId string.
    function isAuthor(resource) {
      let authorId = resource.data.authorId;
      let authorInfoId = resource.data.get(['author', 'id'], null) || resource.data.get(['authorInfo', 'id'], null);
      
      return request.auth.uid == authorId || request.auth.uid == authorInfoId;
    }
    
    // == STATUS UPDATES ==
    // New, more robust rules for the entire StatusUpdate lifecycle.
    
    // New Rule #1: Definitive ownership check for status updates.
    function isAuthorOfStatus(resource) {
      let authorId = resource.data.get('authorId', null);
      let authorInfoId = resource.data.get(['authorInfo', 'id'], null);
      return request.auth.uid == authorId || request.auth.uid == authorInfoId;
    }
    
    // New Rule #2: Fields that should NEVER change after creation.
    function areImmutableFieldsUnchanged() {
      return request.resource.data.authorId == resource.data.authorId &&
             request.resource.data.authorInfo.id == resource.data.authorInfo.id &&
             request.resource.data.createdAt == resource.data.createdAt &&
             request.resource.data.mediaUrl == resource.data.mediaUrl;
    }

    match /statusUpdates/{statusId} {
      // Anyone can read a status update. Access control is handled by client-side queries (e.g., checking expiration).
      allow read: if true;

      // New Rule #5: Strict rules for creating a new status.
      allow create: if request.auth != null && 
                       isAuthorOfStatus(request.resource) &&
                       request.resource.data.isArchived == false &&
                       request.resource.data.isTrashed == false &&
                       request.resource.data.authorId == request.auth.uid &&
                       request.resource.data.authorInfo.id == request.auth.uid &&
                       request.resource.data.mediaUrl is string &&
                       request.resource.data.expiresAt is timestamp;

      // Update rule covers Archiving, Trashing, and Restoring.
      allow update: if request.auth != null && isAuthor(resource) && areImmutableFieldsUnchanged() && (
        // Scenario A: Archiving a status
        (request.resource.data.isArchived == true && resource.data.isArchived == false) ||
        // Scenario B: Moving an ARCHIVED status to trash
        (request.resource.data.isTrashed == true && resource.data.isArchived == true && resource.data.isTrashed == false) ||
        // Scenario C: Restoring a TRASHED status
        (request.resource.data.isTrashed == false && resource.data.isTrashed == true)
      );

      // New Rule #4: Secure Deletion - only allow deleting if it's already in the trash.
      allow delete: if request.auth != null && isAuthor(resource) && resource.data.isTrashed == true;
    }
    
    // == PROMPTS ==
    // Secure rules for Prompts.
    match /prompts/{promptId} {
      allow read: if true;
      allow create: if request.auth != null && isAuthor(request.resource) && request.resource.data.isArchived == false;
      allow update, delete: if request.auth != null && isAuthor(resource);
    }
    
    // == STORIES, COMMENTS, LETTERS, etc. ==
    // Standard secure rules for other collections.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || (request.auth != null && (isAuthor(resource) || request.auth.uid in resource.data.collaboratorIds));
      allow create: if request.auth != null && isAuthor(request.resource);
      allow update, delete: if request.auth != null && (isAuthor(resource) || request.auth.uid in resource.data.collaboratorIds);
    }
    
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }
    
    match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
        allow create: if request.auth != null; // Allow any authenticated user to trigger a notification creation
    }

    match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && isAuthor(request.resource);
        allow update, delete: if request.auth != null && isAuthor(resource);
    }

    match /letters/{letterId} {
        allow read, create, update, delete: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
    }

    match /conversations/{conversationId} {
        allow read, create, update, delete: if request.auth != null && request.auth.uid in resource.data.participantIds;
        match /messages/{messageId} {
            allow read, create, update, delete: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
    }
    
    match /feedPosts/{postId} {
        allow read: if true;
        allow create: if request.auth != null && isAuthor(request.resource);
        allow update, delete: if request.auth != null && isAuthor(resource);
    }

  }
}
