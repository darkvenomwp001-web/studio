
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read;
      allow create, update: if request.auth.uid == userId;
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                   (resource.data.visibility == 'Unlisted' && request.auth != null) ||
                   (request.auth != null && request.auth.uid == resource.data.author.id) ||
                   (request.auth != null && request.auth.uid in resource.data.collaboratorIds);
      allow create: if request.auth.uid == request.resource.data.author.id;
      allow update: if (request.auth.uid == resource.data.author.id) || (request.auth.uid in resource.data.collaboratorIds);
      allow delete: if request.auth.uid == resource.data.author.id;
    }

    match /comments/{commentId} {
      allow read;
      allow create: if request.auth.uid == request.resource.data.user.id;
      allow update, delete: if request.auth.uid == resource.data.user.id;
    }

    match /notifications/{notificationId} {
        allow read, update, delete: if request.auth.uid == resource.data.userId;
        allow create: if request.auth.uid != null;
    }

    match /conversations/{conversationId} {
        allow read, update, create: if request.auth.uid in resource.data.participantIds;
        match /messages/{messageId} {
            allow read, create: if get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid]);
        }
    }

    match /liveFeed/{postId} {
      allow read;
      allow create: if request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.author.id;
    }

    match /letters/{letterId} {
        allow read: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
        allow create: if request.auth.uid == request.resource.data.reader.id;
        allow update: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
    }

    match /prompts/{promptId} {
      allow read;
      allow create: if request.auth.uid == request.resource.data.author.id;
      allow update, delete: if request.auth.uid == resource.data.author.id || request.auth.uid == resource.data.authorId;
    }

    match /statusUpdates/{statusId} {
      allow read;
      allow create: if request.auth.uid == request.resource.data.authorId;
      allow delete: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.authorInfo.id;
    }
  }
}
