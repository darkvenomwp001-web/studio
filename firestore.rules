rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper Functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAuthorOrCollaborator(storyId) {
      let storyData = get(/databases/$(database)/documents/stories/$(storyId)).data;
      return isOwner(storyData.author.id) || request.auth.uid in storyData.collaboratorIds;
    }

    function isAdmin() {
      // In a real app, this would be a list of admin UIDs
      // For now, it's empty, so no one is an admin.
      return request.auth.uid in [];
    }

    // USER PROFILES
    match /users/{userId} {
      // Anyone can read a user's public profile
      allow read;
      // Only the owner can create or update their own profile
      allow create, update: if isOwner(userId);
      // Prevent users from following themselves
      allow update: if ! (request.resource.data.followingIds.hasAny([userId]));
      // Prevent direct manipulation of follower counts
      allow update: if ! ('followersCount' in request.resource.data) || request.resource.data.followersCount == resource.data.followersCount;
    }

    // STORIES
    match /stories/{storyId} {
      // Read access is determined by visibility
      allow read: if resource.data.visibility == 'Public' 
                  || resource.data.visibility == 'Unlisted' 
                  || isAuthorOrCollaborator(storyId);
                  
      // Only authenticated users can create stories
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
      
      // Only the author or a collaborator can update
      allow update: if isAuthorOrCollaborator(storyId);
      
      // Only the author can delete
      allow delete: if isOwner(get(/databases/$(database)/documents/stories/$(storyId)).data.author.id);
    }
    
    // COMMENTS
    match /comments/{commentId} {
      // Anyone can read comments
      allow read;
      // Only authenticated users can create comments
      allow create: if request.auth != null && isOwner(request.resource.data.user.id);
      // Only the comment owner can update or delete
      allow update, delete: if isOwner(resource.data.user.id);
    }
    
    // NOTIFICATIONS
    match /notifications/{notificationId} {
        // Users can only access their own notifications
        allow read, update, delete: if isOwner(resource.data.userId);
        // Only trusted server logic can create notifications
        allow create: if false; 
    }

    // CONVERSATIONS & MESSAGES
    match /conversations/{conversationId} {
      allow read, create, update: if request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
         allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
         allow update, delete: if isOwner(resource.data.senderId);
      }
    }
    
    // FEED POSTS
    match /feedPosts/{postId} {
        allow read;
        allow create: if isOwner(request.resource.data.authorId);
        // Prevent direct manipulation of like counts, let server actions handle it
        allow update: if ! ('likesCount' in request.resource.data) || request.resource.data.likesCount == resource.data.likesCount;
        allow delete: if isOwner(resource.data.authorId);
    }

    // LETTERS
    match /letters/{letterId} {
      // Only author or reader can read
      allow read: if isOwner(resource.data.authorId) || isOwner(resource.data.reader.id);
      // Only reader can create
      allow create: if isOwner(request.resource.data.reader.id);
      // Only author can update (for response/pinning)
      allow update: if isOwner(resource.data.authorId);
    }
    
    // PROMPTS
    match /prompts/{promptId} {
        allow read;
        // Ensure author ID is correct on creation
        allow create: if isOwner(request.resource.data.author.id);
        // Only owner can update or delete
        allow update, delete: if isOwner(resource.data.author.id);
    }

    // STATUS UPDATES
    match /statusUpdates/{statusId} {
        // Any authenticated user can read a published status
        allow read: if request.auth != null;

        // On create, enforce ownership and default states
        allow create: if isOwner(request.resource.data.authorId)
                      && request.resource.data.isArchived == false
                      && request.resource.data.isTrashed == false;
                      
        // For updates, use specific helper function
        allow update: if isOwner(resource.data.authorId);
        
        // Secure Deletion: only allow deleting if item is already in trash
        allow delete: if isOwner(resource.data.authorId) && resource.data.isTrashed == true;
    }
  }
}