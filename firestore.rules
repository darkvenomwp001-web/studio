
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership across different data structures
    function isOwner(userId, data) {
      return userId == data.authorId || 
             userId == data.author.id || 
             userId == data.user.id || 
             userId == data.authorInfo.id;
    }

    // Users: Can read anyone's profile, but only write to their own.
    match /users/{userId} {
      allow read;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Stories: Public stories are readable. Writes are restricted to authors/collaborators.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted';
      allow get: if request.auth != null; // Allows fetching for checks
      allow create: if request.auth != null && request.auth.uid == request.resource.data.author.id;
      allow update: if request.auth != null && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if request.auth != null && request.auth.uid == resource.data.author.id;
    }

    // Comments: Users can read all comments, create comments if signed in, and only update/delete their own.
    match /comments/{commentId} {
      allow read;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user.id;
      allow update, delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }
    
    // Live Feed: Users can read all non-archived/trashed posts. Create if signed in. Update/delete own posts.
    match /liveFeed/{postId} {
      allow read: if resource.data.isArchived == false && resource.data.isTrashed == false;
      allow create: if request.auth != null && isOwner(request.auth.uid, request.resource.data);
      allow update: if request.auth != null && isOwner(request.auth.uid, resource.data);
      allow delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }

    // Prompts: Readable by all. Create if signed in. Update/delete only by author.
    match /prompts/{promptId} {
      allow read;
      allow create: if request.auth != null && isOwner(request.auth.uid, request.resource.data);
      allow update, delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }

    // Notifications: Only readable by the user they are intended for.
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Status Updates: Rules for status updates (e.g., stories).
    match /statusUpdates/{statusId} {
      allow read;
      allow create: if request.auth != null && isOwner(request.auth.uid, request.resource.data);
      allow update, delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }

    // Conversations: Only participants can read/write.
    match /conversations/{conversationId} {
      allow read, update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;

      // Messages sub-collection
      match /messages/{messageId} {
        allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
    
    // Letters: Only author and reader can access.
    match /letters/{letterId} {
        allow read, update: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.reader.id;
    }

    // Pending Deletions: Securely log deletion requests.
    match /pendingDeletions/{deletionId} {
        allow create: if request.auth != null && request.auth.uid == request.resource.data.requestedBy;
        // No one can read/update/delete these logs directly. They are processed server-side.
        allow read, update, delete: if false;
    }
  }
}
