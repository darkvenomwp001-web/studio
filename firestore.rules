
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users Collection
    // Anyone can read public user profiles.
    // A user can create their own profile.
    // A user can update their own profile.
    // Another user can only update the followersCount by +/- 1 (for following/unfollowing).
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isAuthenticated() &&
        (isOwner(userId) ||
         (request.resource.data.keys().hasOnly(['followersCount', 'updatedAt']) &&
          (request.resource.data.followersCount == resource.data.followersCount + 1 ||
           request.resource.data.followersCount == resource.data.followersCount - 1)));
    }

    // Stories Collection
    // Public/Unlisted stories are readable by anyone. Private are for author/collaborators.
    // Create/Update/Delete is restricted to author/collaborators.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' ||
                     resource.data.visibility == 'Unlisted' ||
                     (isAuthenticated() && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isAuthenticated() && request.resource.data.author.id == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.author.id;
    }

    // Comments Collection
    // All comments are public to read.
    // Only authenticated users can CUD their own comments.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.user.id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user.id == request.auth.uid;
    }

    // Notifications Collection
    // Only the recipient can read/update their notifications.
    // Any authenticated user can create a notification, but must be the actor.
    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.resource.data.actor.id == request.auth.uid;
    }
    
    // Letters Collection
    // Readable by sender or author.
    // Can only be created by the sender (reader).
    // Can only be updated by the recipient (author).
    match /letters/{letterId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.reader.id || request.auth.uid == resource.data.authorId);
      allow create: if isAuthenticated() && request.resource.data.reader.id == request.auth.uid;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.authorId;
    }
    
    // Conversations and Messages
    // Only participants can read or write.
    match /conversations/{conversationId} {
      allow read, create, update: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
  }
}
