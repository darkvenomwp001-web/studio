
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isStoryPublic(story) {
      return story.visibility == 'Public' && story.status != 'Draft';
    }
    function isStoryCollaborator(story) {
      return request.auth.uid in story.collaboratorIds;
    }
    
    // User Profiles
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; 
    }

    // Stories & Chapters
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                  || resource.data.visibility == 'Unlisted'
                  || (isAuth() && isOwner(resource.data.author.id))
                  || (isAuth() && request.auth.uid in resource.data.collaboratorIds);
                  
      allow create: if isAuth() && isOwner(request.resource.data.author.id);
      allow update: if isAuth() && (isOwner(resource.data.author.id) || isStoryCollaborator(resource.data));
      allow delete: if isAuth() && isOwner(resource.data.author.id);
    }
    
    // Comments
    match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && isOwner(resource.data.user.id);
    }

    // Letters
    match /letters/{letterId} {
      allow read: if isAuth() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
      allow create: if isAuth() && isOwner(request.resource.data.reader.id);
      allow update: if isAuth() && isOwner(resource.data.authorId); // Only author can update (pin, respond)
      allow delete: if isAuth() && isOwner(resource.data.reader.id); // Only reader can delete
    }

    // Notifications (Users can only read their own)
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuth() && isOwner(resource.data.userId);
      allow create: if isAuth(); // Actions in the backend (e.g. cloud functions) will be used to create notifications securely
    }

    // Status Updates
    match /statusUpdates/{statusId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth() && isOwner(resource.data.authorId);
    }

    // Writing Prompts
    match /prompts/{promptId} {
      allow read: if true;
      allow create: if isAuth() && isOwner(request.resource.data.author.id);
      allow update, delete: if isAuth() && isOwner(resource.data.author.id);
    }

    // Live Public Chat
    match /globalChatMessages/{messageId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
    }
  }
}
