
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthor(doc) {
      return request.auth.uid == doc.authorId ||
             (doc.author != null && request.auth.uid == doc.author.id) ||
             (doc.authorInfo != null && request.auth.uid == doc.authorInfo.id);
    }
    
    function isRequestingUser(userId) {
      return request.auth.uid == userId;
    }

    // Collection rules
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && isRequestingUser(userId);
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' ||
                   resource.data.visibility == 'Unlisted' ||
                   (request.auth != null && isAuthor(resource.data)) ||
                   (request.auth != null && request.auth.uid in resource.data.collaboratorIds);
      allow create: if request.auth != null && isAuthor(request.resource.data);
      allow update, delete: if request.auth != null && 
                              (isAuthor(resource.data) || request.auth.uid in resource.data.collaboratorIds);
    }
    
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
    }
    
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.user.id;
    }

    match /conversations/{conversationId} {
        allow read, write: if request.auth != null && request.auth.uid in resource.data.participantIds;

        match /messages/{messageId} {
            allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
            allow update, delete: if request.auth != null && request.auth.uid == resource.data.senderId;
        }
    }
    
    match /feedPosts/{postId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
        allow update, delete: if request.auth != null && isAuthor(resource.data);
    }
    
    match /liveFeed/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth != null && isAuthor(resource.data);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.user.id;
      }
    }
    
    match /prompts/{promptId} {
        allow read: if true;
        allow create: if request.auth != null && isAuthor(request.resource.data);
        allow update, delete: if request.auth != null && isAuthor(resource.data);
    }
    
    match /letters/{letterId} {
        allow read, update: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.reader.id;
    }
    
    match /statusUpdates/{statusId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
        allow update, delete: if request.auth != null && isAuthor(resource.data);
    }

    match /notes/{noteId} {
        allow read: if request.auth.uid == resource.data.author_id;
        allow create: if request.auth.uid == request.resource.data.author_id;
        allow delete: if request.auth.uid == resource.data.author_id;
    }
  }
}
