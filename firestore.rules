
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read;
      allow create: if isOwner(userId);

      function canUpdateProfile() {
        let allowedFields = ['displayName', 'bio', 'role', 'avatarUrl', 'updatedAt', 'followingIds', 'followingCount', 'readingList', 'note'];
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
      }

      function isValidNoteUpdate() {
        // If note doesn't exist in the request, it's not being updated, which is fine.
        if (!request.resource.data.keys().has('note')) {
          return true;
        }
        // If the note is being deleted (set to null), that's allowed.
        if (request.resource.data.note == null) {
          return true;
        }
        // If the note exists, it must be valid.
        let note = request.resource.data.note;
        return note.keys().hasAll(['content', 'expiresAt']) &&
               note.content is string &&
               note.content.size() > 0 && note.content.size() <= 90 &&
               note.expiresAt is timestamp &&
               note.expiresAt > request.time;
      }

      allow update: if isOwner(userId) && canUpdateProfile() && isValidNoteUpdate();
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || (isUserAuthenticated() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isUserAuthenticated() && request.resource.data.author.id == request.auth.uid;
      allow update: if isUserAuthenticated() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isUserAuthenticated() && resource.data.author.id == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read;
      allow create: if isUserAuthenticated() && request.resource.data.user.id == request.auth.uid;
      allow update: if isUserAuthenticated() && resource.data.user.id == request.auth.uid;
      allow delete: if isUserAuthenticated() && resource.data.user.id == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read, delete: if isUserAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isUserAuthenticated();
      allow update: if isUserAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.keys().hasOnly(['isRead']);
    }

    match /conversations/{conversationId} {
        allow read, create: if isUserAuthenticated() && request.auth.uid in resource.data.participantIds;
        allow update: if isUserAuthenticated() && request.auth.uid in resource.data.participantIds;
        
        match /messages/{messageId} {
            allow read, create: if isUserAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
    }

    match /letters/{letterId} {
        allow read: if isUserAuthenticated() && (resource.data.reader.id == request.auth.uid || resource.data.authorId == request.auth.uid || resource.data.visibility == 'public');
        allow create: if isUserAuthenticated() && request.resource.data.reader.id == request.auth.uid;
        allow update: if isUserAuthenticated() && resource.data.authorId == request.auth.uid;
    }
    
    match /questions/{questionId} {
      allow read;
      
      function isAsker() {
      	return request.auth.uid == request.resource.data.asker.id;
      }
      
      function isValidAskerData() {
      	return request.resource.data.asker.id == request.auth.uid &&
        			 request.resource.data.asker.keys().hasAll(['id', 'username', 'displayName', 'avatarUrl']);
      }
      
      function isValidQuestionText() {
      	return request.resource.data.questionText.size() >= 10 &&
        			 request.resource.data.questionText.size() <= 1000;
      }
      
      allow create: if isUserAuthenticated() &&
      							isAsker() &&
                    isValidAskerData() &&
                    isValidQuestionText();
                    
      allow update, delete: if isUserAuthenticated() && isOwner(resource.data.asker.id);
    }
  }
}
