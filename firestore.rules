
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthor(data) {
      return request.auth.uid == data.authorId || 
             request.auth.uid == data.author.id || 
             request.auth.uid == data.user.id ||
             request.auth.uid == data.authorInfo.id;
    }

    // Users: Can read anyone's profile, but only write to their own.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Stories: Public can be read by anyone. Private/Drafts only by author/collaborators.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' ||
                   (request.auth != null && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
    }

    // Comments: Can be read by anyone. Can be created by any logged-in user.
    // Can only be updated/deleted by the comment's author.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.user.id == request.auth.uid;
    }
    
    // Notifications: Can only be read/updated by the user the notification is for.
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null; // Created via server-side logic
    }
    
    // Conversations & Messages
    match /conversations/{conversationId} {
        // Can read/write if the user is a participant.
        allow read, write: if request.auth != null && request.auth.uid in resource.data.participantIds;

        // Messages subcollection
        match /messages/{messageId} {
            allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
            // Only the sender can edit/delete their own messages
            allow update, delete: if request.auth != null && request.auth.uid == resource.data.senderId;
        }
    }
    
    // Feed posts from the main feed tab (not live feed)
    match /feedPosts/{postId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
        allow update: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    
    // LIVE FEED POSTS
    match /liveFeed/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.author.id == request.auth.uid || resource.data.authorId == request.auth.uid);
    }
    
    // Prompts from the Prompts tab
    match /prompts/{promptId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && (resource.data.author.id == request.auth.uid || resource.data.authorId == request.auth.uid);
    }
    
    // Letters between users
    match /letters/{letterId} {
        allow read, update: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
        allow create: if request.auth != null;
    }
    
    // 24-hour status updates
    match /statusUpdates/{statusId} {
        allow read, create: if request.auth != null;
        allow update, delete: if request.auth != null && (resource.data.authorId == request.auth.uid || resource.data.authorInfo.id == request.auth.uid);
    }
  }
}
