
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthor(doc) {
      return request.auth.uid == doc.authorId ||
             (doc.author != null && request.auth.uid == doc.author.id) ||
             (doc.authorInfo != null && request.auth.uid == doc.authorInfo.id);
    }
    
    function isCollaborator(storyDoc) {
        return request.auth.uid in storyDoc.collaboratorIds;
    }

    // Users: Can read anyone's profile, but only write to their own.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Stories: Public/Unlisted can be read by anyone. Private only by author/collaborators.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' ||
                   (request.auth != null && (isAuthor(resource.data) || isCollaborator(resource.data)));
      allow create: if request.auth != null && request.auth.uid == request.resource.data.author.id;
      allow update, delete: if request.auth != null && (isAuthor(resource.data) || isCollaborator(resource.data));
    }

    // Comments: Can be read by anyone. Can be created by any logged-in user.
    // Can only be updated/deleted by the comment's author.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.user.id;
    }
    
    // Notifications: Can only be read/updated by the user the notification is for.
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
    
    // Conversations & Messages
    match /conversations/{conversationId} {
        allow read, write: if request.auth != null && request.auth.uid in resource.data.participantIds;
        match /messages/{messageId} {
            allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
            allow update, delete: if request.auth != null && request.auth.uid == resource.data.senderId;
        }
    }
    
    // Main feed posts
    match /feedPosts/{postId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
        allow update, delete: if request.auth != null && isAuthor(resource.data);
    }
    
    // Live feed posts
    match /liveFeed/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      allow update: if request.auth != null && isAuthor(resource.data); // Update to archive
      allow delete: if request.auth != null && isAuthor(resource.data); // For permanent deletion
    }
    
    // Prompts
    match /prompts/{promptId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.author.id;
        allow update: if request.auth != null && isAuthor(resource.data); // Update to archive
        allow delete: if request.auth != null && isAuthor(resource.data); // For permanent deletion
    }
    
    // Letters between users
    match /letters/{letterId} {
        allow read, update: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
        allow create: if request.auth != null;
    }
    
    // 24-hour status updates
    match /statusUpdates/{statusId} {
        allow read, create: if request.auth != null;
        allow update: if request.auth != null && isAuthor(resource.data); // Rule for archiving/hiding
    }
  }
}
