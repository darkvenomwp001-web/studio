
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users can read all profiles, but only write to their own.
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Rules for written book-style stories
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                    || resource.data.visibility == 'Unlisted' 
                    || (request.auth != null && isOwner(resource.data.author.id)) 
                    || (request.auth != null && request.auth.uid in resource.data.collaboratorIds);

      allow create: if request.auth != null && isOwner(request.resource.data.author.id);
      
      allow update, delete: if request.auth != null && (isOwner(resource.data.author.id) || (request.auth.uid in resource.data.collaboratorIds));
    }

    // Rules for ephemeral, Instagram-style "My Day" stories
    match /userStories/{userStoryId} {
      // Allow anyone to read a story if it hasn't expired.
      allow read: if resource.data.expiresAt > request.time;
      
      // Allow a user to create a story if they are the author.
      allow create: if request.auth != null && isOwner(request.resource.data.authorId);
      
      // Allow a user to delete their own story.
      allow delete: if request.auth != null && isOwner(resource.data.authorId);
    }

    // Rules for the social feed
    match /feedPosts/{postId} {
      allow read: if true; // Feed is public for simplicity
      allow create: if request.auth != null && isOwner(request.resource.data.author.id);
      allow update: if request.auth != null; // Allow any logged-in user to update (for liking)
      allow delete: if request.auth != null && isOwner(resource.data.author.id);
    }

    // Rules for comments on stories
    match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && isOwner(request.resource.data.user.id);
        allow update, delete: if request.auth != null && isOwner(resource.data.user.id);
    }
    
    // Rules for private letters between users and authors
    match /letters/{letterId} {
        allow read, update: if request.auth != null && (isOwner(resource.data.authorId) || isOwner(resource.data.reader.id));
        allow create: if request.auth != null && isOwner(request.resource.data.reader.id);
    }
    
    // Rules for private messaging
    match /conversations/{conversationId} {
        allow read, update, create: if request.auth != null && request.auth.uid in resource.data.participantIds;

        match /messages/{messageId} {
            allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
    }
    
    // Rules for notifications
    match /notifications/{notificationId} {
        allow read, update: if request.auth != null && isOwner(resource.data.userId);
        // Creation is handled by trusted server actions or client-side logic where the creator is the intended recipient.
        allow create: if request.auth != null;
    }
  }
}
