
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the requester is the owner of a document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===== USERS COLLECTION =====
    // Anyone can read a user profile. Only the owner can create or update it.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if false; // Deletion from client is disabled
    }

    // ===== STORIES COLLECTION (Books) =====
    // Public/Unlisted stories are readable by anyone. Private only by author/collaborators.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' ||
                    resource.data.visibility == 'Unlisted' ||
                    (isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }

    // ===== USER STORIES COLLECTION (Instagram-style Posts/Updates) =====
    // Anyone can read stories. The application's query is responsible for
    // filtering out expired stories. Only the author can create one.
    match /userStories/{userStoryId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(request.resource.data.authorId);
      allow update, delete: if false; // Updates and deletes from client are disabled.
    }

    // ===== COMMENTS COLLECTION =====
    // Anyone can read comments. Only signed-in users can create them.
    // Only the original commenter can edit/delete their own comment.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }

    // ===== LETTERS COLLECTION =====
    // Readable/updatable by author or reader. Creatable only by the reader.
    match /letters/{letterId} {
      allow read, update: if isSignedIn() && (isOwner(resource.data.authorId) || isOwner(resource.data.reader.id));
      allow create: if isSignedIn() && isOwner(request.resource.data.reader.id);
      allow delete: if false;
    }

    // ===== FEED POSTS COLLECTION =====
    // Publicly readable. Creatable/deletable by author. Updatable (for likes) by any signed-in user.
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
      allow update: if isSignedIn(); // Allows liking/commenting
      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }

    // ===== NOTIFICATIONS COLLECTION =====
    // Only the user to whom the notification is addressed can access it.
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if true; // Created by trusted actions/server logic
    }
  }
}
