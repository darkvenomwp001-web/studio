
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users: Can read anyone's profile. Can only create/update their own.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
    }
    
    // Stories: Can read public/unlisted. Can only write to their own.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted';
      allow create, update, delete: if isOwner(resource.data.author.id);
    }
    
    // Comments: Can read/create. Can only update/delete their own.
    match /comments/{commentId} {
        allow read, create: if isAuthenticated();
        allow update, delete: if isOwner(resource.data.user.id);
    }

    // Notifications: Can only access their own.
    match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(resource.data.userId);
        allow create: if isAuthenticated();
    }

    // Letters: Complex rules for conversations between two parties.
    match /letters/{letterId} {
      allow read: if isOwner(resource.data.authorId) || isOwner(resource.data.reader.id);
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.authorId); // Only author can update (e.g., pin, respond)
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read, update: if request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }

    // Feed Posts
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.authorId) || isOwner(resource.data.author.id); // Backward compatible check
    }

    // Live Feed
    match /liveFeed/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Robust, backward-compatible check
      allow update, delete: if isOwner(resource.data.authorId) || isOwner(resource.data.author.id);
    }

    // Prompts
    match /prompts/{promptId} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Robust, backward-compatible check
      allow update, delete: if isOwner(resource.data.authorId) || isOwner(resource.data.author.id);
    }

    // Status Updates
    match /statusUpdates/{statusId} {
        allow read: if true;
        allow create: if isAuthenticated();
        // Robust check using authorId
        allow delete: if isOwner(resource.data.authorId);
    }
  }
}
