rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // USERS Collection
    match /users/{userId} {
      // Anyone can read a user's public profile
      allow read: if true;
      // Only the authenticated owner can create, update or delete their own profile
      allow create, update, delete: if isOwner(userId);
    }
    
    // STORIES Collection
    match /stories/{storyId} {
      // Read access control is complex, handled by querying filtered documents based on visibility.
      // We can allow general read here because the queries will enforce visibility.
      allow read: if true;
      
      // Anyone signed in (and not anonymous) can create a story.
      allow create: if isSignedIn() && request.auth.token.isAnonymous == false;
      
      // Only the author or a collaborator can update/delete a story.
      allow update, delete: if isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
    }

    // COMMENTS Collection
    match /comments/{commentId} {
      // Anyone can read comments
      allow read: if true;
      // Any signed-in user (not anonymous) can create a comment
      allow create: if isSignedIn() && request.auth.token.isAnonymous == false;
      // Only the comment owner can update or delete their comment
      allow update, delete: if isSignedIn() && resource.data.user.id == request.auth.uid;
    }

    // NOTIFICATIONS Collection
    match /notifications/{notificationId} {
      // A user can only read or delete their own notifications.
      allow read, delete: if isOwner(resource.data.userId);
      // Notifications are created by server-side actions (Cloud Functions or other trusted environments)
      // We disallow client-side creation and updates for security.
      allow create, update: if false; 
    }
    
    // CONVERSATIONS Collection
    match /conversations/{conversationId} {
        // A user can read, update, or delete a conversation only if they are a participant.
        allow read, update, delete: if isSignedIn() && request.auth.uid in resource.data.participantIds;
        // A user can create a conversation if they are one of the participants.
        allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
        
        // MESSAGES Subcollection
        match /messages/{messageId} {
            // A user can read messages in a conversation they are part of.
            allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
            // A user can create a message if they are a participant.
            allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
            // Messages are immutable once created.
            allow update, delete: if false;
        }
    }
    
    // GLOBAL CHAT Collection
    match /globalChatMessages/{messageId} {
        // Anyone can read the global chat
        allow read: if true;
        // Only signed-in (not anonymous) users can write messages
        allow create: if isSignedIn() && request.auth.token.isAnonymous == false;
        // Messages are immutable
        allow update, delete: if false;
    }
    
    // LETTERS Collection
    match /letters/{letterId} {
      // Read is complex: Author can read, sender can read, public letters can be read by anyone.
      // This is best handled by Firestore queries in the app logic, so a general read is okay here.
      allow read: if true;
      // Only signed-in (not anonymous) users can send letters.
      allow create: if isSignedIn() && request.auth.token.isAnonymous == false;
      // Only the author can update (e.g., pin, respond).
      allow update: if isOwner(resource.data.authorId);
      // Only the sender (reader) can delete their own letter.
      allow delete: if isOwner(resource.data.reader.id);
    }
    
    // PROMPTS Collection
    match /prompts/{promptId} {
        // Anyone can read prompts.
        allow read: if true;
        // Only signed-in writers can create prompts.
        allow create: if isSignedIn() && request.auth.token.isAnonymous == false;
        // Only the prompt author can update or delete it.
        allow update, delete: if isOwner(resource.data.author.id);
    }
    
    // STATUS UPDATES Collection
    match /statusUpdates/{statusId} {
        // Anyone can read status updates.
        allow read: if true;
        // Only signed-in writers can create them.
        allow create: if isSignedIn() && request.auth.token.isAnonymous == false;
        // Only the status author can update or delete it.
        allow update, delete: if isOwner(resource.data.authorId);
    }

    // ANNOTATIONS Collection
    match /annotations/{annotationId} {
      // An annotation is strictly private to the user who created it.
      allow read, create, update, delete: if isOwner(resource.data.userId);
    }

    // FEED POSTS (THREADS) Collection
    match /feedPosts/{postId} {
      // Anyone can read posts in the feed.
      allow read: if true;
      // Any signed-in user (not anonymous) can create a post.
      allow create: if isSignedIn() && request.auth.token.isAnonymous == false;
      // Only the author can update or delete their post.
      allow update, delete: if isOwner(resource.data.author.id);
    }
  }
}