
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: Can read anyone's public profile, but only write to their own.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }

    // Stories: Can read public/unlisted stories. Can only write if author or collaborator.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || (request.auth.uid in resource.data.collaboratorIds) || (request.auth.uid == resource.data.author.id);
      allow create: if request.auth.uid == request.resource.data.author.id;
      allow update, delete: if request.auth.uid == resource.data.author.id || (request.auth.uid in resource.data.collaboratorIds);
    }

    // Comments: Can read all, can create/edit/delete their own.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth.uid == request.resource.data.user.id;
      allow update, delete: if request.auth.uid == resource.data.user.id;
    }

    // Notifications: Can only read/write their own notifications.
    match /notifications/{notificationId} {
        allow read, write: if request.auth.uid == resource.data.userId;
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read, create, update: if request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
    
    // Letters: Read/write access based on author/reader relationship.
    match /letters/{letterId} {
      allow read, update: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
      allow create: if request.auth.uid == request.resource.data.reader.id;
    }

    // Feed Posts: Authenticated users can create. Owners can update/delete.
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if request.auth.uid == request.resource.data.author.id;
      allow update, delete: if request.auth.uid == resource.data.author.id;
    }

    // Live Feed: Authenticated users can create. Owners can update/delete.
    match /liveFeed/{postId} {
      allow read: if true;
      allow create: if request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth.uid == resource.data.authorId;
    }

    // Prompts: Authenticated users can create. Owners can update/delete.
    match /prompts/{promptId} {
      allow read: if true;
      allow create: if request.auth.uid == request.resource.data.author.id;
      allow update, delete: if request.auth.uid == resource.data.author.id;
    }

    // Status Updates: Authenticated users can create. Owners can delete. Read by all auth users.
    match /statusUpdates/{statusId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.authorId;
      allow delete: if request.auth.uid == resource.data.authorId;
    }
  }
}
