rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isCollaborator(storyId) {
        return get(/databases/$(database)/documents/stories/$(storyId)).data.collaboratorIds.hasAny([request.auth.uid]);
    }
    function isFollowing(userId) {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.followingIds.hasAny([userId]);
    }
    
    // Users collection rules
    match /users/{userId} {
      allow read;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }
    
    // Stories collection rules
    match /stories/{storyId} {
        // Anyone can read a public story
        allow read: if resource.data.visibility == 'Public'
                    // Unlisted stories are readable with a link
                    || resource.data.visibility == 'Unlisted'
                    // Owners and collaborators can read their own private stories
                    || (isSignedIn() && (isOwner(resource.data.author.id) || isCollaborator(storyId)));

        // Only owners can create stories
        allow create: if isSignedIn() && isOwner(request.resource.data.author.id);

        // Owners and collaborators can update stories
        allow update: if isSignedIn() && (isOwner(resource.data.author.id) || isCollaborator(storyId));

        // Only the owner can delete a story
        allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }
    
    // Comments collection rules
    match /comments/{commentId} {
        // Anyone can read comments on a public story
        allow read: if get(/databases/$(database)/documents/stories/$(resource.data.storyId)).data.visibility == 'Public';
        
        // Signed-in users can create comments
        allow create: if isSignedIn() && isOwner(request.resource.data.user.id);
        
        // Owners can update/delete their own comments
        allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }
    
    // Notifications collection rules
    match /notifications/{notificationId} {
        // Users can only read their own notifications
        allow read, update: if isSignedIn() && isOwner(resource.data.userId);
        // Server-side logic handles creation
        allow create: if isSignedIn();
    }

    // Letters collection rules
    match /letters/{letterId} {
      // Only the sender (reader) and receiver (author) can read the letter
      allow read: if isSignedIn() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
      // Only the sender can create the letter
      allow create: if isSignedIn() && isOwner(request.resource.data.reader.id);
      // Only the author can update the letter (to respond or pin)
      allow update: if isSignedIn() && isOwner(resource.data.authorId);
    }

    // Feed Posts collection rules
    match /feedPosts/{postId} {
        // Followers can read posts
        allow read: if isSignedIn() && isFollowing(resource.data.authorId);
        // Only owner can create
        allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
        // Only owner can delete
        allow delete: if isSignedIn() && isOwner(resource.data.authorId);
        // Allow anyone signed in to update (for likes)
        allow update: if isSignedIn();
    }

    // User Stories collection rules
    match /userStories/{storyId} {
      // Allow read if user is the author or if the reader is following the author
      allow read: if isSignedIn() && (isOwner(resource.data.author.id) || isFollowing(resource.data.author.id));
      // Allow create if user is the author of the story
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
      // Nobody can update/delete from client (handled by TTL policy or Cloud Function)
      allow update, delete: if false;
    }

  }
}
