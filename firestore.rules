
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // USERS
    match /users/{userId} {
      // Anyone can read public profile data
      allow read: if true;

      // A user can only create their own document
      allow create: if isOwner(userId);

      // A user can only update their own document, and only specific fields
      allow update: if isOwner(userId) &&
                      // Ensure required fields for note update are valid
                      (request.resource.data.note == null || (
                         request.resource.data.note.content is string &&
                         request.resource.data.note.content.size() <= 90 &&
                         request.resource.data.note.expiresAt is timestamp
                       )) &&
                      // Prevent users from updating fields they shouldn't
                      request.resource.data.keys().hasOnly([
                        'id', 'username', 'email', 'bio', 'avatarUrl', 'displayName',
                        'role', 'followersCount', 'followingCount', 'followingIds',
                        'writtenStories', 'readingList', 'createdAt', 'updatedAt',
                        'dataAiHint', 'note'
                      ]) &&
                      // Make sure critical fields are not changed
                      request.resource.data.id == resource.data.id &&
                      request.resource.data.username == resource.data.username &&
                      request.resource.data.email == resource.data.email &&
                      request.resource.data.followersCount == resource.data.followersCount &&
                      request.resource.data.createdAt == resource.data.createdAt;
    }

    // STORIES
    match /stories/{storyId} {
      // Public & Unlisted stories are readable by anyone. Private/Draft stories are only readable by the author or collaborators.
      allow read: if resource.data.visibility == 'Public' || 
                     resource.data.visibility == 'Unlisted' || 
                     (isAuthenticated() && (resource.data.author.id == request.auth.uid || resource.data.collaboratorIds.hasAny([request.auth.uid])));
      
      // Only an authenticated user can create a story where they are the author
      allow create: if isAuthenticated() && request.resource.data.author.id == request.auth.uid;
      
      // Only the author or collaborators can update a story
      allow update: if isAuthenticated() && (resource.data.author.id == request.auth.uid || resource.data.collaboratorIds.hasAny([request.auth.uid]));

      // Only the author can delete a story
      allow delete: if isOwner(resource.data.author.id);
    }
    
    // COMMENTS
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.user.id);
    }
    
    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      // Create is handled by backend actions, but we can lock it down.
      allow create: if isAuthenticated(); 
    }
    
    // LETTERS
    match /letters/{letterId} {
      allow read, update: if isOwner(resource.data.authorId) || isOwner(resource.data.reader.id);
      allow create: if isOwner(request.resource.data.reader.id);
    }

    // QUESTIONS
    match /questions/{questionId} {
        allow read: if true;
        
        // Ensure the person creating the question is the one logged in.
        allow create: if isOwner(request.resource.data.asker.id) &&
                        request.resource.data.questionText is string &&
                        request.resource.data.questionText.size() > 0 &&
                        request.resource.data.questionText.size() <= 1000 &&
                        request.resource.data.createdAt is timestamp &&
                        request.resource.data.status == 'unanswered';
                        
        allow update, delete: if isOwner(resource.data.asker.id);
    }
  }
}
