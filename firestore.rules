
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isCollaborator(storyId) {
      let story = get(/databases/$(database)/documents/stories/$(storyId)).data;
      return request.auth.uid in story.collaborators.map(c => c.id);
    }
    
    function isStoryPublicOrUnlisted(storyId) {
        let story = get(/databases/$(database)/documents/stories/$(storyId)).data;
        return story.visibility == 'Public' || story.visibility == 'Unlisted';
    }

    // USERS:
    // - Anyone can read public user profiles.
    // - Only the owner can create or write to their own profile.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      // No delete for user profiles for safety.
    }

    // STORIES:
    // - Anyone can read public stories.
    // - Logged-in users can view unlisted stories (if they have the link).
    // - Only owners/collaborators can read private stories.
    // - Logged-in users can create stories.
    // - Only owners/collaborators can update stories.
    // - Only the original author can delete a story.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                      (isSignedIn() && resource.data.visibility == 'Unlisted') ||
                      (isSignedIn() && (isOwner(resource.data.author.id) || isCollaborator(storyId)));

      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
      
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || isCollaborator(storyId));

      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }

    // COMMENTS:
    // - Anyone can read comments on public/unlisted stories.
    // - Logged-in users can create comments.
    // - Only the owner of a comment can update or delete it.
    match /comments/{commentId} {
       allow read: if isStoryPublicOrUnlisted(resource.data.storyId);
       allow create: if isSignedIn();
       allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }

    // NOTIFICATIONS:
    // - Only the user the notification is for can read or write to it.
    match /notifications/{notificationId} {
      allow read, create, update: if isSignedIn() && isOwner(resource.data.userId);
    }
    
    // CONVERSATIONS & MESSAGES:
    // - Only participants of a conversation can read/write to it.
    match /conversations/{conversationId} {
      allow read, create, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        // No update/delete for messages for integrity.
      }
    }
  }
}
