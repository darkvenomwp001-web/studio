
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to simplify rule logic
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===== USERS COLLECTION =====
    // Public profiles, but only the owner can write.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if false; // Deletion not allowed from client
    }

    // ===== STORIES COLLECTION (Books) =====
    // Rules for story visibility and collaboration.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public'
                    || resource.data.visibility == 'Unlisted'
                    || (isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isOwner(resource.data.author.id);
    }

    // ===== USER NOTES (Messenger-style Notes) =====
    // This is the specific rule block you requested to be updated.
    match /userNotes/{noteId} {
      // Allow read only if the note has not expired.
      // Further filtering (public vs followers) is handled on the client for query efficiency.
      allow read: if isSignedIn() && resource.data.expiresAt > request.time;
      
      // Allow create only by the note's author, with content validation.
      allow create: if isOwner(request.resource.data.authorId)
                    && request.resource.data.content.size() <= 60
                    && request.resource.data.visibility in ['public', 'followers'];
                    
      // Notes cannot be updated or deleted by clients. They expire automatically.
      allow update, delete: if false;
    }

    // ===== COMMENTS COLLECTION =====
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.user.id);
    }

    // ===== LETTERS COLLECTION =====
    match /letters/{letterId} {
      // Only the sender (reader) or receiver (author) can read or update.
      allow read, update: if isSignedIn() && (isOwner(resource.data.authorId) || isOwner(resource.data.reader.id));
      allow create: if isOwner(request.resource.data.reader.id); // Only the reader can initiate a letter
      allow delete: if false;
    }
    
    // ===== FEED POSTS COLLECTION =====
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.authorId);
      // 'update' is for liking/unliking posts. Any signed-in user can do this.
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data.authorId);
    }
    
    // ===== NOTIFICATIONS COLLECTION =====
    match /notifications/{notificationId} {
      // Only the recipient of the notification can access it.
      allow read, update, delete: if isOwner(resource.data.userId);
      // Notifications are created by trusted server actions or authenticated client actions.
      allow create: if isSignedIn();
    }
    
    // ===== CONVERSATIONS & MESSAGES =====
    match /conversations/{conversationId} {
      // A user can read/write to a conversation if they are a participant.
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      
      // Messages subcollection
      match /messages/{messageId} {
        // A user can read messages in a conversation they are part of.
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        // A user can only create a message if they are a participant and the sender.
        allow create: if isSignedIn() 
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
                      && isOwner(request.resource.data.senderId);
        // Messages cannot be updated or deleted from the client.
        allow update, delete: if false;
      }
    }
  }
}
