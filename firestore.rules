
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthor(userId, data) {
      return userId == data.authorId 
          || userId == data.author.id 
          || userId == data.authorInfo.id 
          || userId == data.user.id;
    }
    
    // User Profiles
    match /users/{userId} {
      allow read;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
    }
    
    // Stories and Chapters
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds;
      allow create: if request.auth.uid == request.resource.data.author.id;
      allow update: if request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds;
      allow delete: if request.auth.uid == resource.data.author.id;
    }

    // Comments
    match /comments/{commentId} {
        allow read;
        allow create: if request.auth.uid == request.resource.data.user.id;
        allow update: if isAuthor(request.auth.uid, resource.data);
        allow delete: if isAuthor(request.auth.uid, resource.data);
    }

    // Notifications
    match /notifications/{notificationId} {
        allow read, update: if request.auth.uid == resource.data.userId;
        allow create: if request.auth.uid != null;
    }
    
    // Private messages
    match /conversations/{conversationId} {
        allow read, create, update: if request.auth.uid in resource.data.participantIds;

        match /messages/{messageId} {
            allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
    }

    // Letters
    match /letters/{letterId} {
        allow read: if request.auth.uid == resource.data.author.id || request.auth.uid == resource.data.reader.id;
        allow create: if request.auth.uid == request.resource.data.reader.id;
        allow update: if request.auth.uid == resource.data.author.id;
    }

    // Prompts
     match /prompts/{promptId} {
      allow read;
      allow create: if isAuthor(request.auth.uid, request.resource.data);
      allow update: if isAuthor(request.auth.uid, resource.data);
      allow delete: if isAuthor(request.auth.uid, resource.data);
    }

    // Status Updates
    match /statusUpdates/{statusId} {
        allow read: if resource.data.isArchived == false && resource.data.isTrashed == false;
        allow create: if isAuthor(request.auth.uid, request.resource.data);
        allow update: if isAuthor(request.auth.uid, resource.data);
        allow delete: if isAuthor(request.auth.uid, resource.data);
    }
  }
}
