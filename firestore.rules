
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isAuthOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAuthUser() {
      return request.auth.uid != null;
    }
    
    function isOwner(docData) {
      return isAuthOwner(docData.author.id);
    }
    
    function isCollaborator(docData) {
      return request.auth.uid in docData.collaboratorIds;
    }

    function canEditStory(docData) {
      return isOwner(docData) || isCollaborator(docData);
    }
    
    function isPubliclyVisible(docData) {
        return docData.visibility == 'Public';
    }
    
    function canViewStory(docData) {
        return isPubliclyVisible(docData) || docData.visibility == 'Unlisted' || canEditStory(docData);
    }
    
    function isAsker(questionData) {
      return isAuthOwner(questionData.asker.id);
    }
    
    function isTargetAuthor(questionData) {
      return questionData.targetAuthor != null && isAuthOwner(questionData.targetAuthor.id);
    }

    // --- Collections Rules ---

    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthOwner(userId);
      allow update: if isAuthOwner(userId);
      allow delete: if false; // Protect user data
    }

    match /stories/{storyId} {
      allow read: if canViewStory(resource.data);
      allow create: if isAuthUser() && isOwner(request.resource.data);
      allow update: if isAuthUser() && canEditStory(resource.data);
      allow delete: if isAuthUser() && isOwner(resource.data);
    }
    
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthUser() && isAuthOwner(request.resource.data.user.id);
      allow update, delete: if isAuthUser() && isAuthOwner(resource.data.user.id);
    }

    match /letters/{letterId} {
      allow read: if isAuthUser() && (isAuthOwner(resource.data.authorId) || isAuthOwner(resource.data.reader.id));
      allow create: if isAuthUser() && isAuthOwner(request.resource.data.reader.id);
      allow update: if isAuthUser() && isAuthOwner(resource.data.authorId); // Only author can update (pin, respond)
      allow delete: if false; // Letters are permanent records
    }
    
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthUser() && isAuthOwner(resource.data.userId);
      allow create: if isAuthUser(); // Server-side logic handles correct creation
    }

    match /conversations/{conversationId} {
      allow read, create, update: if isAuthUser() && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if isAuthUser() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
    
    match /questions/{questionId} {
      allow list, get: if true;

      allow create: if isAuthUser() &&
                      request.resource.data.asker.id == request.auth.uid &&
                      request.resource.data.status == 'unanswered' &&
                      !('answerText' in request.resource.data);

      allow update: if isAuthUser() && (
        // Asker editing their own UNANSWERED question
        (isAsker(resource.data) && resource.data.status == 'unanswered' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['questionText', 'isEdited', 'createdAt'])) ||
        
        // Target author answering an UNANSWERED question
        (isTargetAuthor(resource.data) && resource.data.status == 'unanswered' &&
         request.resource.data.status == 'answered' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'answerText', 'answeredAt'])) ||
         
        // Target author declining an UNANSWERED question
        (isTargetAuthor(resource.data) && resource.data.status == 'unanswered' &&
         request.resource.data.status == 'declined' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'answeredAt']))
      );

      allow delete: if isAuthUser() && (isAsker(resource.data) || isTargetAuthor(resource.data));
    }
  }
}
