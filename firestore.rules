
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users: Can read their own data, can create their own doc, can update their own doc. Public read is allowed for profiles.
    match /users/{userId} {
      allow read: if true; // Public profiles
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Generally don't allow users to delete their own accounts from the client
    }

    // Stories (Books): Public can read. Only author/collaborators can create/update.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || (isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isSignedIn() && resource.data.author.id == request.auth.uid;
    }
    
    // UserStories (Instagram-style): Public can read for 24h. Only author can create.
    match /userStories/{userStoryId} {
      // Allow reads if the story has not expired.
      allow read: if true;
      // Allow create if user is the author.
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.authorId;
      // No updates or deletes from client for simplicity.
      allow update, delete: if false;
    }
    
    // Comments: Public can read. Signed-in users can create. Owner can update/delete.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.user.id == request.auth.uid;
    }

    // Letters: Can only be read by author or reader. Can only be created by reader. Can only be updated by author (for response).
    match /letters/{letterId} {
      allow read, update: if isSignedIn() && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.reader.id;
      allow delete: if false;
    }

    // FeedPosts: Public can read. Signed-in users can create/like. Owner can delete.
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      // Anyone signed in can like/unlike a post.
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && resource.data.author.id == request.auth.uid;
    }

    // Notifications: Can only be accessed by the user the notification is for.
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if true; // Typically created by server-side logic or trusted client actions. For now, allow client creation.
    }
  }
}
