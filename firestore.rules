rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function for authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function for ownership
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper function to check for ownership in multiple possible fields
    function isDocumentOwner() {
        // New standard field
        let isOwnerById = 'authorId' in resource.data && isOwner(resource.data.authorId);
        // Legacy field from story object
        let isOwnerByAuthorObject = 'author' in resource.data && isOwner(resource.data.author.id);
        // Legacy field from status object
        let isOwnerByAuthorInfo = 'authorInfo' in resource.data && isOwner(resource.data.authorInfo.id);

        return isOwnerById || isOwnerByAuthorObject || isOwnerByAuthorInfo;
    }

    // Users: Can read any profile, can only write to their own.
    match /users/{userId} {
      allow read;
      allow write: if isOwner(userId);
    }

    // Stories: Can be read by public, only written by author/collaborators.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                   resource.data.visibility == 'Unlisted' ||
                   (isAuthenticated() && isDocumentOwner()) ||
                   (isAuthenticated() && resource.data.collaboratorIds.hasAny([request.auth.uid]));

      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isDocumentOwner() || resource.data.collaboratorIds.hasAny([request.auth.uid]));
      allow delete: if isAuthenticated() && isDocumentOwner();
    }
    
    // Comments: Can be read by public, created/updated/deleted by owners.
    match /comments/{commentId} {
        allow read;
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && isDocumentOwner();
    }
    
    // Notifications: Can only be read/written by the owner.
    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated() && isDocumentOwner();
    }
    
    // Letters: Can only be read/written by sender or receiver.
    match /letters/{letterId} {
      allow read, write: if isAuthenticated() && (isOwner(resource.data.reader.id) || isOwner(resource.data.author.id));
    }
    
    // Conversations & Messages: Can only be accessed by participants.
    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid]);
      }
    }

    // Server-Side Validated Actions: 
    // These rules allow any authenticated user to attempt the action.
    // The robust server-side code in the actions files performs the actual security check for ownership.
    match /feedPosts/{postId} {
       allow get, list, create, update: if isAuthenticated();
       allow delete: if isAuthenticated(); // For future implementation if needed
    }
    
    match /liveFeed/{postId} {
      // Allow read for everyone
      allow read;
      // Let server actions handle the security for create, update, delete
      allow create, update, delete: if isAuthenticated();
    }

    match /prompts/{promptId} {
       // Allow read for everyone
      allow read;
      // Let server actions handle the security for create, update, delete
      allow create, update, delete: if isAuthenticated();
    }

    match /statusUpdates/{statusId} {
      // Let server actions handle security. Rule just ensures user is logged in.
      // 'get' is required for the server action to read the doc before deleting.
      allow get, create, update, delete: if isAuthenticated();
      // 'list' is needed for the main query to get all statuses
      allow list: if isAuthenticated();
    }
  }
}
