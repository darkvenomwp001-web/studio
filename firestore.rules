rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for ownership across different data structures.
    // This is the single source of truth for ownership verification.
    function isOwner(data) {
      // Check for top-level authorId (used in liveFeed, prompts, statusUpdates)
      return request.auth.uid == data.get(['authorId'], '') ||
      // Check for nested author object with an id (used in liveFeed, prompts)
      request.auth.uid == data.get(['author', 'id'], '') ||
      // Check for nested user object with an id (used in comments)
      request.auth.uid == data.get(['user', 'id'], '') ||
      // Check for nested authorInfo object with an id (used in statusUpdates)
      request.auth.uid == data.get(['authorInfo', 'id'], '');
    }

    match /users/{userId} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || (request.auth != null && isOwner(resource.data));
      allow create, update: if request.auth != null && isOwner(request.resource.data);
      allow delete: if request.auth != null && isOwner(resource.data);
    }
    
    match /comments/{commentId} {
        allow read;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && isOwner(resource.data);
    }

    match /liveFeed/{postId} {
        allow read;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && isOwner(resource.data);
    }

    match /prompts/{promptId} {
        allow read;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && isOwner(resource.data);
    }
    
    match /statusUpdates/{statusId} {
        allow read: if resource.data.expiresAt > request.time;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && isOwner(resource.data);
    }

    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null; // Server-side logic should validate who can create notifs
    }

    match /letters/{letterId} {
        allow read, update: if request.auth != null && (resource.data.authorId == request.auth.uid || resource.data.reader.id == request.auth.uid);
        allow create: if request.auth != null;
    }
    
    match /conversations/{conversationId} {
        allow read, update, delete: if request.auth != null && request.auth.uid in resource.data.participantIds;
        allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;

        match /messages/{messageId} {
            allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
    }
  }
}
