rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // USERS
    // Public read for profiles, but only the owner can write.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }
    
    // STORIES
    // Public stories are readable by all. Only author/collaborators can write.
    match /stories/{storyId} {
      // Allow reads if public, or if user is author/collaborator
      allow read: if resource.data.visibility == 'Public' 
                  || resource.data.visibility == 'Unlisted'
                  || (request.auth != null && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds));
      
      // Allow writes only for author or collaborators
      allow write: if request.auth != null && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds);
    }
    
    // COMMENTS
    // Users can create comments. Only owners can delete/edit their own comments.
    match /comments/{commentId} {
        allow create: if request.auth != null;
        allow read: if true;
        allow update, delete: if request.auth.uid == resource.data.user.id;
    }
    
    // NOTIFICATIONS
    // Users can only read and write to their own notifications.
    match /notifications/{notificationId} {
        allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // CONVERSATIONS
    // Participants can read/write to conversations they are a part of.
    match /conversations/{conversationId} {
        allow read, write: if request.auth != null && request.auth.uid in resource.data.participantIds;
    }
    match /conversations/{conversationId}/messages/{messageId} {
         allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
    }

    // FEED POSTS
    match /feedPosts/{postId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == resource.data.author.id;
        allow delete: if request.auth != null && request.auth.uid == resource.data.author.id;

        match /comments/{commentId} {
          allow read: if true;
          allow create: if request.auth != null;
          allow update, delete: if request.auth != null && request.auth.uid == resource.data.user.id;
        }
    }
    
    // GLOBAL CHAT
    match /globalChatMessages/{messageId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.author.id;
    }
    
    // LETTERS
    match /letters/{letterId} {
        allow read: if resource.data.visibility == 'public' 
                    || (request.auth != null && (request.auth.uid == resource.data.reader.id || request.auth.uid == resource.data.authorId));
        allow create: if request.auth != null && request.auth.uid == request.resource.data.reader.id;
        allow update: if request.auth != null && request.auth.uid == resource.data.authorId; // Only author can pin/respond
        allow delete: if request.auth != null && request.auth.uid == resource.data.reader.id; // Only reader can delete
    }

    // STATUS UPDATES
    match /statusUpdates/{statusId} {
        allow read: if resource.data.status == 'published' && resource.data.expiresAt > request.time;
        allow create, update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // ANNOTATIONS
     match /annotations/{annotationId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // PROMPTS
     match /prompts/{promptId} {
      allow read: if resource.data.isArchived == false;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.author.id;
    }
  }
}
