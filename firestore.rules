
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isCollaborator(storyId) {
      return exists(/databases/$(database)/documents/stories/$(storyId)) &&
             get(/databases/$(database)/documents/stories/$(storyId)).data.collaborators.hasAny(['id'], [request.auth.uid]);
    }
    
    function isStoryOwner(storyId) {
        return exists(/databases/$(database)/documents/stories/$(storyId)) &&
             get(/databases/$(database)/documents/stories/$(storyId)).data.author.id == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      // Anyone can read a user's public profile info
      allow get: if true;
      
      // Only the authenticated owner can create their own user document or update it
      allow create, update: if isOwner(userId);
      
      // Users should not be able to delete their accounts through the client
      allow delete: if false;
    }

    // Stories collection
    match /stories/{storyId} {
      // Allow read access to public/unlisted stories. 
      // Private stories can only be read by the owner or a collaborator.
      allow get: if resource.data.visibility == 'Public' || 
                    resource.data.visibility == 'Unlisted' ||
                    (resource.data.visibility == 'Private' && isSignedIn() && (isStoryOwner(storyId) || isCollaborator(storyId)));

      // Allow anyone to query/list public stories
      allow list: if resource.data.visibility == 'Public';
      
      // Only authenticated users can create stories
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
      
      // Only the story owner or a collaborator can update a story
      allow update: if isSignedIn() && (isStoryOwner(storyId) || isCollaborator(storyId));
      
      // Only the story owner can delete a story
      allow delete: if isSignedIn() && isStoryOwner(storyId);
    }
    
    // Comments collection
    match /comments/{commentId} {
      // Anyone can read comments
      allow read, list: if true;
      
      // Authenticated users can create comments
      allow create: if isSignedIn() && isOwner(request.resource.data.user.id);
      
      // Only the comment owner can update or delete their own comment
      allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
        // A user can only read, update (mark as read), or delete their own notifications.
        allow read, update, delete: if isSignedIn() && isOwner(resource.data.userId);
        
        // Notifications are created server-side (or via trusted client logic), 
        // linked to a user's action (e.g., following another user).
        // Here we allow any signed-in user to create a notification,
        // assuming client logic correctly sets the target `userId`.
        allow create: if isSignedIn();
    }
    
    // Conversations and Messages
    match /conversations/{conversationId} {
      // A user can only access a conversation if they are a participant.
      allow get, list, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      
      // A user can only create a conversation if they are one of the participants.
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      
      match /messages/{messageId} {
        // A user can read messages in a conversation they are part of.
        allow read, list: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        
        // A user can create a message if they are a participant and the sender.
        allow create: if isSignedIn() && 
                         isOwner(request.resource.data.senderId) && 
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
  }
}
