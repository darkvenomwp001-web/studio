
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth.uid == userId;
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds;
      allow create: if request.auth.uid != null;
      allow update: if request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds;
    }
    
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth.uid != null;
      allow update, delete: if request.auth.uid == resource.data.user.id;
    }
    
    match /notifications/{notificationId} {
      allow read, update: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid != null;
    }

    match /conversations/{conversationId} {
      allow read, create, update: if request.auth.uid in resource.data.participantIds;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read, create: if get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid]);
    }
    
    match /feedPosts/{postId} {
        allow read: if true;
        allow create, update: if request.auth.uid != null;
    }
    
    match /letters/{letterId} {
        allow read, create, update: if request.auth.uid == resource.data.reader.id || request.auth.uid == resource.data.authorId;
    }

    match /liveFeed/{postId} {
        allow read: if true;
        allow create: if request.auth.uid != null;
        allow update: if request.auth.uid != null;
    }

    match /prompts/{promptId} {
        allow read: if true;
        allow create: if request.auth.uid != null;
        allow update: if request.auth.uid != null;
    }

    match /statusUpdates/{statusId} {
        allow read: if true;
        allow create: if request.auth.uid != null;
        allow get, update: if request.auth.uid != null;
    }
  }
}
