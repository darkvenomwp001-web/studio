
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User data is public, but only the user can write to their own document.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Users should not be able to delete their own accounts through the client.
    }

    // Stories can be read if public, but only the author/collaborator can write.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' ||
                   resource.data.visibility == 'Unlisted' ||
                   (request.auth != null && request.auth.uid == resource.data.author.id) ||
                   (request.auth != null && resource.data.collaboratorIds.hasAny([request.auth.uid]));
                   
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
      
      allow update: if request.auth != null && 
                     (request.auth.uid == resource.data.author.id || 
                      resource.data.collaboratorIds.hasAny([request.auth.uid]));

      allow delete: if request.auth != null && request.auth.uid == resource.data.author.id;
    }

    // Comments can be read by anyone, but only created/modified by the owner.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.user.id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user.id == request.auth.uid;
    }
    
    // Notifications can only be accessed by the user they are intended for.
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null; // Assumes notifications are created via trusted server actions/backend logic
    }

    // Letters can only be accessed by the sender or receiver.
    match /letters/{letterId} {
        allow read, update: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.reader.id;
    }

    // Q&A Questions can be read by anyone.
    match /questions/{questionId} {
      allow read: if true;
      
      // Creation is allowed if the user is logged in and provides valid data.
      allow create: if request.auth != null
                    && request.resource.data.asker.id == request.auth.uid
                    && request.resource.data.questionText is string
                    && request.resource.data.questionText.size() > 0 && request.resource.data.questionText.size() <= 1000
                    && request.resource.data.status == 'unanswered';

      // Updates are only allowed by the original asker.
      allow update: if request.auth != null && request.auth.uid == resource.data.asker.id;

      // Deletion is allowed by the asker or the mentioned author (if any).
      allow delete: if request.auth != null && 
                     (request.auth.uid == resource.data.asker.id || 
                       (resource.data.targetAuthor != null && request.auth.uid == resource.data.targetAuthor.id)
                     );
    }

    // Conversations can only be accessed by participants.
    match /conversations/{conversationId} {
        allow read, write: if request.auth != null && request.auth.uid in resource.data.participantIds;
        
        match /messages/{messageId} {
            allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
    }
  }
}
