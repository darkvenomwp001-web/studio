
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to robustly check ownership across different data structures
    function isOwner(uid) {
      return resource.data.authorId == uid || 
             resource.data.author.id == uid ||
             resource.data.authorInfo.id == uid ||
             resource.data.user.id == uid;
    }

    // USERS
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth.uid == userId;
    }

    // STORIES
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                     resource.data.visibility == 'Unlisted' ||
                     (request.auth != null && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
    }
    
    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
    
    // COMMENTS
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.user.id;
    }
    
    // CONVERSATIONS
    match /conversations/{conversationId} {
        allow read, write: if request.auth.uid in resource.data.participantIds;

        match /messages/{messageId} {
            allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
            allow update, delete: if request.auth.uid == resource.data.senderId;
        }
    }
    
    // FEED POSTS
    match /feedPosts/{postId} {
        allow read: if true;
        allow create: if request.auth.uid == request.resource.data.authorId;
        allow update: if request.auth.uid == resource.data.authorId;
        allow delete: if request.auth.uid == resource.data.authorId;
    }
    
    // LIVE FEED
    match /liveFeed/{postId} {
      allow read: if true;
      allow create: if request.auth.uid == request.resource.data.authorId;
      allow update, delete: if isOwner(request.auth.uid);
    }
    
    // PROMPTS
    match /prompts/{promptId} {
        allow read: if true;
        allow create: if request.auth.uid == request.resource.data.author.id;
        allow update, delete: if isOwner(request.auth.uid);
    }
    
    // LETTERS
    match /letters/{letterId} {
        allow read, update: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
        allow create: if request.auth.uid == request.resource.data.reader.id;
    }
    
    // STATUS UPDATES
    match /statusUpdates/{statusId} {
        allow read: if true;
        allow create: if request.auth.uid == request.resource.data.authorId;
        allow update, delete: if isOwner(request.auth.uid);
    }
  }
}
