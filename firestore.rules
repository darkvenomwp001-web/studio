
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
    }

    // Stories collection (long-form content)
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || (request.auth != null && (request.auth.uid == resource.data.author.id || resource.data.collaboratorIds[request.auth.uid] == true));
      allow create: if request.auth.uid == request.resource.data.author.id;
      allow update: if request.auth.uid == resource.data.author.id || resource.data.collaboratorIds[request.auth.uid] == true;
      allow delete: if request.auth.uid == resource.data.author.id;
    }
    
    // Comments on stories
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.user.id;
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth.uid == resource.data.userId;
      allow create: if request.auth != null; // Server-side logic should validate who can create what
    }

    // Letters between users and authors
    match /letters/{letterId} {
      allow read, update: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
      allow create: if request.auth.uid == request.resource.data.reader.id;
    }

    // User stories (ephemeral, like Instagram stories)
    match /userStories/{userStoryId} {
      allow read: if true; // Anyone can read stories
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Feed posts
    match /feedPosts/{postId} {
      allow read: if true; // Anyone can read the feed
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      allow update: if request.auth != null; // Liking is an update
    }
  }
}
