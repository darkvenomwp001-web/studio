
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Check if the user is the author or a collaborator of a story
    function isAuthorOrCollaborator(storyId) {
      let storyData = get(/databases/$(database)/documents/stories/$(storyId)).data;
      let collaboratorIds = storyData.get('collaboratorIds', []);
      return isOwner(storyData.author.id) || request.auth.uid in collaboratorIds;
    }
    
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);

      // A user can update their own profile document.
      // This allows them to change their bio, displayName, note, etc.
      // It prevents them from changing their username, email, or creation date.
      allow update: if isOwner(userId) &&
                       request.resource.data.username == resource.data.username &&
                       request.resource.data.email == resource.data.email &&
                       request.resource.data.createdAt == resource.data.createdAt;
    }
    
    match /stories/{storyId} {
      // Public stories are readable by anyone.
      // Unlisted stories are readable by any signed-in user.
      // Private/Draft stories are readable only by author/collaborators.
      allow read: if resource.data.visibility == 'Public' || 
                      (resource.data.visibility == 'Unlisted' && isSignedIn()) || 
                      (isSignedIn() && isAuthorOrCollaborator(storyId));
                      
      // A story can only be created by the user listed as its author.
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      
      // A story can only be updated by its author or a collaborator.
      allow update: if isSignedIn() && isAuthorOrCollaborator(storyId);
      
      // Only the original author can delete a story.
      allow delete: if isSignedIn() && isOwner(get(/databases/$(database)/documents/stories/$(storyId)).data.author.id);
    }
    
    match /comments/{commentId} {
        allow read: if true;
        // Comments must be created by the user listed in the comment data.
        allow create: if isSignedIn() && request.resource.data.user.id == request.auth.uid;
        // Comments can only be updated or deleted by their original author.
        allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }

    match /notifications/{notificationId} {
        allow read, update: if isSignedIn() && isOwner(resource.data.userId);
        // Notifications can be created by the system or other users (e.g., for follows).
        allow create: if isSignedIn();
    }

    match /letters/{letterId} {
        // Letters can only be read by the sender (reader) or receiver (author).
        allow read: if isSignedIn() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
        // Letters must be created by the user listed as the reader.
        allow create: if isSignedIn() && request.resource.data.reader.id == request.auth.uid;
        // Only the author can update a letter (to respond or pin it).
        allow update: if isSignedIn() && isOwner(resource.data.authorId);
    }

    match /feedPosts/{postId} {
        allow read: if isSignedIn();
        // Feed posts must be created by the user listed as the author.
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        // Any signed-in user can update a post (for liking).
        allow update: if isSignedIn();
    }
  }
}
