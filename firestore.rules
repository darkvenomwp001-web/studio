
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    // Universal function to check if the requesting user is the author of a document.
    // Handles various ways author data might be stored.
    function isAuthor(docData) {
      return request.auth.uid == docData.authorId ||
             request.auth.uid == docData.author.id ||
             request.auth.uid == docData.authorInfo.id;
    }

    // --- NEW RULE 1: Secure User Profiles ---
    // A user can only read all profiles, but can only update their own.
    // They cannot change their follower/following counts directly.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId
                    && !('followersCount' in request.resource.data)
                    && !('followingCount' in request.resource.data);
      allow delete: if false; // Do not allow users to delete their own accounts from the client.
    }

    // --- NEW RULE 2: Secure Story Ownership ---
    // Only the author or a collaborator can update a story.
    function isAuthorOrCollaborator(storyId) {
      let storyData = get(/databases/$(database)/documents/stories/$(storyId)).data;
      return request.auth.uid == storyData.author.id || request.auth.uid in storyData.collaboratorIds;
    }

    match /stories/{storyId} {
      // Anyone can read public stories. Unlisted/Private requires special access.
      allow read: if resource.data.visibility == 'Public' ||
                   (resource.data.visibility == 'Unlisted' && request.auth != null) ||
                   (resource.data.visibility == 'Private' && isAuthorOrCollaborator(storyId));
      
      // --- NEW RULE 3 (Part 1): Enforce Data Integrity on Create ---
      // User must be authenticated and be the author of the new story.
      allow create: if request.auth != null && isAuthor(request.resource.data);
      
      allow update: if request.auth != null && isAuthorOrCollaborator(storyId);
      allow delete: if request.auth != null && isAuthor(resource.data); // Only original author can delete.
    }

    // --- NEW RULE 4: Protect Private Conversations ---
    // Only participants can read/write messages in a conversation.
    match /conversations/{conversationId} {
      allow get, list, update: if request.auth.uid in resource.data.participantIds;
      allow create: if request.auth.uid in request.resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false; // Messages are immutable.
      }
    }
    
    // --- NEW RULE 3 (Part 2) & RULE 5: Secure Feed Posts ---
    match /feedPosts/{postId} {
      allow read: if request.auth != null;
      
      allow create: if request.auth != null && isAuthor(request.resource.data);
      
      // Allow updates only for liking/unliking, not for changing content.
      // Prevent direct manipulation of likesCount.
      allow update: if request.auth != null
                    && request.resource.data.content == resource.data.content
                    && !('likesCount' in request.resource.data);
      
      allow delete: if request.auth != null && isAuthor(resource.data);
    }
    
    // --- Secure Comments ---
    match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && isAuthor(request.resource.data);
        // Only the author of the comment can update their own comment.
        allow update: if request.auth != null && isAuthor(resource.data);
        allow delete: if request.auth != null && isAuthor(resource.data);
    }

    // --- Secure Letters ---
    match /letters/{letterId} {
      // Only the author or the reader of the letter can access it.
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.reader.id;
      allow delete: if false; // Letters cannot be deleted from the client.
    }
    
    // --- NEW RULE 3 (Part 3): Secure Prompts ---
    match /prompts/{promptId} {
      allow read: if true;
      allow create: if request.auth != null && isAuthor(request.resource.data);
      // Only the author of the prompt can update or delete it.
      allow update, delete: if request.auth != null && isAuthor(resource.data);
    }

    // --- Secure Notifications (Users can only read their own) ---
    match /notifications/{notificationId} {
        allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
        allow create: if request.auth != null; // Allow server-side logic to create notifications.
        allow delete: if false;
    }
    
    // --- Fully Secured StatusUpdates ---
    match /statusUpdates/{statusId} {
      // Allow creation if the user is authenticated and is the author.
      // Enforce required fields and correct initial state.
      allow create: if request.auth != null
                    && isAuthor(request.resource.data)
                    && request.resource.data.authorId == request.auth.uid
                    && 'mediaUrl' in request.resource.data
                    && 'expiresAt' in request.resource.data
                    && request.resource.data.isArchived == false
                    && request.resource.data.isTrashed == false;

      // Allow reads for any authenticated user (as they are public for 24h).
      allow read: if request.auth != null;

      // Allow updates only for specific, logical state transitions by the owner.
      allow update: if request.auth != null && isAuthor(resource.data)
                    // Rule: Cannot change immutable fields
                    && request.resource.data.authorId == resource.data.authorId
                    && request.resource.data.createdAt == resource.data.createdAt
                    // Rule: Archiving is allowed.
                    && (
                      (
                        'isArchived' in request.resource.data && 
                        request.resource.data.isArchived == true
                      ) ||
                    // Rule: Trashing is allowed only if already archived.
                      (
                        'isTrashed' in request.resource.data &&
                        request.resource.data.isTrashed == true &&
                        resource.data.isArchived == true
                      ) ||
                    // Rule: Restoring from trash is allowed.
                      (
                        'isTrashed' in request.resource.data &&
                        request.resource.data.isTrashed == false &&
                        resource.data.isTrashed == true
                      )
                    );
      
      // Allow deletion only by the owner AND only if it's already in the trash.
      allow delete: if request.auth != null
                    && isAuthor(resource.data)
                    && resource.data.isTrashed == true;
    }
  }
}
