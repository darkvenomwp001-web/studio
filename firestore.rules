
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }
    
    function isStoryAuthor(story) {
      return isOwner(story.author.id);
    }
    
    function isStoryCollaborator(story) {
      return isUserAuthenticated() && request.auth.uid in story.collaboratorIds;
    }

    // Users: Read-all, write-self
    match /users/{userId} {
      allow read;
      allow write: if isOwner(userId);
    }

    // Stories: Public-read, author/collaborator-write
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted';
      allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.author.id;
      allow update, delete: if isUserAuthenticated() && (isStoryAuthor(resource.data) || isStoryCollaborator(resource.data));
    }

    // Comments: Public-read, owner-write
    match /comments/{commentId} {
      allow read;
      allow create: if isOwner(request.resource.data.user.id);
      allow update, delete: if isOwner(resource.data.user.id);
    }

    // Questions: Public-read, various write permissions
    match /questions/{questionId} {
      allow read;

      function isQuestionAsker() {
        return isOwner(resource.data.asker.id);
      }

      function isTargetAuthor() {
        return resource.data.targetAuthor != null && isOwner(resource.data.targetAuthor.id);
      }
      
      // Allow creation with proper data validation
      allow create: if isUserAuthenticated() &&
                       request.resource.data.asker.id == request.auth.uid &&
                       request.resource.data.questionText is string &&
                       request.resource.data.questionText.size() > 9 &&
                       request.resource.data.questionText.size() < 1001 &&
                       request.resource.data.status == 'unanswered' &&
                       request.resource.data.createdAt == request.time &&
                       (!('targetAuthor' in request.resource.data) || (
                          request.resource.data.targetAuthor is map &&
                          request.resource.data.targetAuthor.keys().hasAll(['id', 'username', 'displayName', 'avatarUrl'])
                       )) &&
                       (!('attachedChapter' in request.resource.data) || (
                           request.resource.data.attachedChapter is map &&
                           request.resource.data.attachedChapter.keys().hasAll(['storyId', 'storyTitle', 'chapterId', 'chapterTitle'])
                       )) &&
                       !('answerText' in request.resource.data) &&
                       !('answeredAt' in request.resource.data);

      // Allow updates by asker (questionText) or target author (answerText, status)
      allow update: if isUserAuthenticated() && 
                      (isOwner(resource.data.asker.id) || isTargetAuthor());
      
      // Allow deletion by asker or target author
      allow delete: if isUserAuthenticated() && (isQuestionAsker() || isTargetAuthor());
    }

    // Letters: Only involved parties can read/write
    match /letters/{letterId} {
      allow read, write: if isUserAuthenticated() && (isOwner(resource.data.authorId) || isOwner(resource.data.reader.id));
    }

    // Notifications: owner-read/write
    match /notifications/{notificationId} {
      allow read, write, delete: if isOwner(resource.data.userId);
    }
  }
}
