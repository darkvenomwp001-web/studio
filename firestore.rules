
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: Can read anyone's public profile, but can only write to their own document.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }

    // Stories: Public stories are readable by anyone. Only authors/collaborators can write.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || (request.auth.uid != null && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds));
      allow write: if request.auth.uid != null && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds);
    }
    
    // Comments (Top-level collection for chapter comments)
    match /comments/{commentId} {
       allow read: if true;
       allow create: if request.auth.uid != null && request.resource.data.user.id == request.auth.uid;
       allow update, delete: if request.auth.uid != null && (request.auth.uid == resource.data.user.id);
    }
    
    // Notifications: Users can only read their own notifications. Creating is done via server-side logic (actions).
    match /notifications/{notificationId} {
      allow read, write: if request.auth.uid != null && request.auth.uid == resource.data.userId;
    }

    // Letters: Can be read by sender or recipient (author). Only sender can create. Only author can update (respond/pin).
    match /letters/{letterId} {
      allow read: if request.auth.uid != null && (request.auth.uid == resource.data.reader.id || request.auth.uid == resource.data.author.id);
      allow create: if request.auth.uid != null && request.resource.data.reader.id == request.auth.uid;
      allow update: if request.auth.uid != null && request.auth.uid == resource.data.author.id;
    }
    
    // Questions: Publicly readable. Creations/updates/deletes are permissioned.
    match /questions/{questionId} {
      allow read: if true;
      allow create: if request.auth.uid != null && request.resource.data.asker.id == request.auth.uid;
      allow update: if request.auth.uid != null && (request.auth.uid == resource.data.asker.id || (resource.data.targetAuthor != null && request.auth.uid == resource.data.targetAuthor.id));
      allow delete: if request.auth.uid != null && (request.auth.uid == resource.data.asker.id || (resource.data.targetAuthor != null && request.auth.uid == resource.data.targetAuthor.id));
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read, write: if request.auth.uid in resource.data.participantIds;
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false; // Disallow editing/deleting messages for now
      }
    }

  }
}
