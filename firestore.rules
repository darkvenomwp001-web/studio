rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isStoryOwner(storyId) {
      return get(/databases/$(database)/documents/stories/$(storyId)).data.author.id == request.auth.uid;
    }
    
    function isStoryCollaborator(storyId) {
      return request.auth.uid in get(/databases/$(database)/documents/stories/$(storyId)).data.collaboratorIds;
    }

    // Users Collection
    match /users/{userId} {
      // Anyone can view a user's public profile.
      allow read;
      // Only the authenticated owner can create or update their own profile.
      allow create, update: if isSignedIn() && isOwner(userId);
    }

    // Stories Collection
    match /stories/{storyId} {
      // Read access rules
      allow read: if resource.data.visibility == 'Public' || 
                   (resource.data.visibility == 'Unlisted' && isSignedIn()) ||
                   (isSignedIn() && (isOwner(storyId) || isStoryCollaborator(storyId)));

      // Write access rules
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(storyId) || isStoryCollaborator(storyId));
      allow delete: if isSignedIn() && isOwner(storyId);
    }
    
    // Comments Collection
    match /comments/{commentId} {
      // Anyone can read comments.
      allow read;
      // Any signed-in user can create a comment, as long as they are the author.
      allow create: if isSignedIn() && isOwner(request.resource.data.user.id);
      // Only the author can update or delete their own comment.
      allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      // Users can only read, create, and update their own notifications.
      allow read, create, update: if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read, create, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
    
    // Feed Posts
    match /feedPosts/{postId} {
        allow read;
        allow create: if isSignedIn() && isOwner(request.resource.data.authorId);
        allow update: if isSignedIn(); // For liking/unliking
    }

    // Status Updates
    match /statusUpdates/{statusId} {
      allow read: if resource.data.status == 'published';
      allow create: if isSignedIn() && isOwner(request.resource.data.authorId);
      // Allow the owner to update (archive, trash, restore) or delete their own status.
      allow update, delete: if isSignedIn() && isOwner(resource.data.authorId);
    }

    // Prompts
    match /prompts/{promptId} {
        allow read;
        allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
        allow update, delete: if isSignedIn() && isOwner(resource.data.author.id);
    }

    // Letters
    match /letters/{letterId} {
        allow read: if resource.data.visibility == 'public' || 
                     (isSignedIn() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId)));
        allow create: if isSignedIn() && isOwner(request.resource.data.reader.id);
        allow update: if isSignedIn() && isOwner(resource.data.authorId); // Only author can pin/respond
        allow delete: if isSignedIn() && isOwner(resource.data.reader.id); // Only reader can delete
    }
  }
}
