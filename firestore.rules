
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // USER PROFILES
    match /users/{userId} {
      allow read;
      allow create: if isOwner(userId);

      // Users can update a limited set of their own profile fields.
      // Critical fields like email, username, counts, etc., are protected.
      allow update: if isOwner(userId) &&
                       request.resource.data.keys().hasOnly([
                         'displayName', 'bio', 'avatarUrl', 'role', 'updatedAt', 'note', 'readingList'
                       ]);
    }

    // STORIES
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                    || resource.data.visibility == 'Unlisted' 
                    || (isSignedIn() && isOwner(resource.data.author.id))
                    || (isSignedIn() && resource.data.collaboratorIds.hasAny([request.auth.uid]));

      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || resource.data.collaboratorIds.hasAny([request.auth.uid]));

      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }
    
    // COMMENTS
    match /comments/{commentId} {
      allow read;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }

    // QUESTIONS
    match /questions/{questionId} {
        allow read;
        allow create: if isSignedIn() && request.resource.data.asker.id == request.auth.uid;
        allow update, delete: if isSignedIn() && isOwner(resource.data.asker.id);
    }

    // LETTERS
    match /letters/{letterId} {
        allow read: if isSignedIn() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
        allow create: if isSignedIn() && isOwner(request.resource.data.reader.id);
        allow update: if isSignedIn() && isOwner(resource.data.authorId); // Only author can respond/pin
    }
    
    // NOTIFICATIONS
    match /notifications/{notificationId} {
        allow read, update, delete: if isSignedIn() && isOwner(resource.data.userId);
        allow create: if isSignedIn(); // Server-side logic should validate this
    }
  }
}
