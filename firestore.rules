
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users collection rules
    match /users/{userId} {
      // Anyone can read a user's public profile
      allow read: if true;
      // Only the user themselves can create their own document or update it
      allow write: if isOwner(userId);
    }
    
    // Stories collection rules
    match /stories/{storyId} {
      // Allow read if the story is public, or if the user is the author or a collaborator
      allow read: if resource.data.visibility == 'Public' 
                   || (isAuthenticated() && resource.data.author.id == request.auth.uid)
                   || (isAuthenticated() && request.auth.uid in resource.data.collaboratorIds);
      // Allow create if user is authenticated
      allow create: if isAuthenticated() && request.resource.data.author.id == request.auth.uid;
      // Allow update if user is the author or a collaborator
      allow update: if isAuthenticated() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      // Allow delete only by the author
      allow delete: if isAuthenticated() && resource.data.author.id == request.auth.uid;
    }

    // Comments collection rules
    match /comments/{commentId} {
        // Anyone can read comments
        allow read: if true;
        // Authenticated users can create comments
        allow create: if isAuthenticated() && request.resource.data.user.id == request.auth.uid;
        // Only the owner of the comment can update or delete it
        allow update, delete: if isAuthenticated() && resource.data.user.id == request.auth.uid;
    }

    // Notifications collection rules
    match /notifications/{notificationId} {
        // A user can only read, create, update (mark as read), or delete their own notifications.
        allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow create: if isAuthenticated(); // Actions can create notifications for other users
    }
    
    // Letters collection rules
    match /letters/{letterId} {
      // Allow read only for the sender or the receiver (author)
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.reader.id || request.auth.uid == resource.data.authorId);
      // Allow create for any authenticated user
      allow create: if isAuthenticated() && request.resource.data.reader.id == request.auth.uid;
      // Allow update (for response, pinning) only by the author
      allow update: if isAuthenticated() && request.auth.uid == resource.data.authorId;
      // No one can delete letters for now
      allow delete: if false;
    }
    
    // Feed Posts collection rules
    match /feedPosts/{postId} {
        // Allow read for followers or the author themselves
        allow read: if isAuthenticated() && (
          resource.data.authorId == request.auth.uid || 
          resource.data.authorId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.followingIds
        );
        // Allow create for the author
        allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        // Allow update for likes, by any authenticated user
        allow update: if isAuthenticated();
        // Allow delete only for the author
        allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }
    
    // User Stories collection rules
    match /userStories/{userStoryId} {
      // Allow read if user is the author or a follower of the author
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.author.id || 
        resource.data.author.id in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.followingIds
      );
      // Allow create if user is the author
      allow create: if isAuthenticated() && request.resource.data.author.id == request.auth.uid;
      // Stories cannot be updated or deleted directly, they expire.
      allow update, delete: if false;
    }
  }
}
