rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAuthor() {
      return isOwner(resource.data.author.id);
    }
    
    function isCollaborator() {
      // Check if the user's ID is in the list of collaborator IDs.
      return isSignedIn() && request.auth.uid in resource.data.collaboratorIds;
    }

    // Stories can be read by anyone if public, but only written/edited by the author or collaborators.
    match /stories/{storyId} {
      // Allow read access based on story visibility or user role (author/collaborator)
      allow read: if resource.data.visibility == 'Public' ||
                   (resource.data.visibility == 'Unlisted' && isSignedIn()) ||
                   (isSignedIn() && (isAuthor() || isCollaborator()));
      
      // Allow create only for authenticated users, who must be the author of the new story.
      allow create: if isSignedIn() && isOwner(request.resource.data.author.id);
      
      // Allow update only for the author or collaborators.
      allow update: if isSignedIn() && (isAuthor() || isCollaborator());

      // Allow delete only for the original author.
      allow delete: if isSignedIn() && isAuthor();
      
      // Prevent access to unspecified subcollections
      match /{allChildren=**} {
        allow read, write: if false; 
      }
    }

    // User profiles are public, but can only be written by the user themselves.
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && isOwner(userId);
    }
    
    // Comments can be read by anyone, but only created/edited by authenticated users.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }
    
    // Notifications are private to each user.
    match /notifications/{notificationId} {
      allow read, write, delete: if isSignedIn() && isOwner(resource.data.userId);
    }
    
    // Conversations and messages are private to participants.
    match /conversations/{conversationId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participantIds;
      }
      
      allow read, write, update: if isSignedIn() && isParticipant();
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && isParticipant();
      }
    }
  }
}
