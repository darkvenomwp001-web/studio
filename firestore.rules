
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only be created by themselves, and can only update their own profile.
    // Public profile information is readable by anyone.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Stories can be read by anyone if public.
    // They can only be created, updated, or deleted by the author or a collaborator.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                   (request.auth != null && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds));
      allow create: if request.auth != null && request.auth.uid == request.resource.data.author.id;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds);
    }

    // User Stories ("My Day") are public to read.
    // They can only be created by the user who owns them.
    match /userStories/{userStoryId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Comments are public to read.
    // Any authenticated user can create one.
    // Only the owner of a comment can edit or delete it.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.user.id;
    }

    // Notifications can only be read or updated by the user they are intended for.
    // Any authenticated user (via a server action) can create a notification.
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Letters can be read by the author or the reader.
    // An authenticated user can create a letter.
    // Only the author can update a letter (to respond or pin it).
    match /letters/{letterId} {
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
      allow create: if request.auth != null;
    }

    // Feed posts are public to read.
    // They can only be created, updated (for likes), or deleted by the author.
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
  }
}
