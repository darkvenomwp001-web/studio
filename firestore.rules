rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // Core Helper Functions
    // ========================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidUser() {
      return request.auth != null && request.auth.uid != null;
    }

    function isDocumentOwner(resourceData, ownerField) {
      return isValidUser() && request.auth.uid == resourceData[ownerField];
    }

    function isAuthor(resourceData) {
      return isValidUser() && 
             (('author' in resourceData && 'id' in resourceData.author && request.auth.uid == resourceData.author.id) ||
              ('authorId' in resourceData && request.auth.uid == resourceData.authorId));
    }

    function isAuthorOrCollaborator(storyData) {
      return isValidUser() && 
             (('author' in storyData && 'id' in storyData.author && request.auth.uid == storyData.author.id) ||
              ('collaboratorIds' in storyData && request.auth.uid in storyData.collaboratorIds));
    }

    function isAuthorOfStatus(statusData) {
      return isValidUser() && 
             (('authorId' in statusData && request.auth.uid == statusData.authorId) ||
              ('authorInfo' in statusData && 'id' in statusData.authorInfo && request.auth.uid == statusData.authorInfo.id));
    }
    
    function isAdmin() {
      let admin_uids = []; // Add your admin UIDs here for testing
      return isValidUser() && request.auth.uid in admin_uids;
    }

    // New validation function for status updates
    function isValidStatusUpdate(data) {
      return 'authorId' in data &&
             'createdAt' in data &&
             'updatedAt' in data &&
             // Ensure required fields are not null/undefined
             data.authorId is string &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             // Optional: validate textOverlay field if present
             (!('textOverlay' in data) || data.textOverlay is string || data.textOverlay == null);
    }

    // ========================================
    // Collection Rules
    // ========================================

    // Users Collection - Fixed Authentication
    match /users/{userId} {
      // Allow reading user profiles
      allow read: if true; // Public user profiles for app functionality
      
      // Allow creating user profile during signup
      allow create: if isValidUser() && 
                    request.auth.uid == userId &&
                    request.auth.uid == request.resource.data.id;
      
      // Allow updating own profile
      allow update: if isValidUser() && 
                    request.auth.uid == userId &&
                    request.auth.uid == resource.data.id;

      // Allow deleting own profile
      allow delete: if isValidUser() && 
                    (request.auth.uid == userId || isAdmin());
    }
    
    // Stories Collection - Complete CRUD
    match /stories/{storyId} {
      // Read stories based on visibility
      allow read: if resource.data.visibility == 'Public' ||
                   (resource.data.visibility == 'Unlisted' && isValidUser()) ||
                   (isValidUser() && isAuthorOrCollaborator(resource.data));

      // Create new story
      allow create: if isValidUser() &&
                    isAuthor(request.resource.data);

      // Update story
      allow update: if isValidUser() && 
                    isAuthorOrCollaborator(resource.data);

      // Delete story
      allow delete: if isValidUser() && 
                    isAuthor(resource.data);
    }

    // Status Updates Collection - SIMPLIFIED TO WORK
    match /statusUpdates/{statusId} {
      // Read access for status updates
      allow read: if true;
      
      // Create status update - SIMPLIFIED
      allow create: if isValidUser() &&
                    request.auth.uid == request.resource.data.authorId;

      // Update own status - SIMPLIFIED
      allow update: if isValidUser() && 
                    isAuthorOfStatus(resource.data);

      // Delete own status
      allow delete: if isValidUser() && 
                    isAuthorOfStatus(resource.data);
    }

    // Prompts Collection - Simplified
    match /prompts/{promptId} {
      allow read: if true; // Public prompts
      
      allow create: if isValidUser() &&
                    isAuthor(request.resource.data);
      
      allow update: if isValidUser() && 
                    isAuthor(resource.data);
      
      allow delete: if isValidUser() && 
                    isAuthor(resource.data);
    }

    // Comments Collection - Fixed
    match /comments/{commentId} {
      allow read: if true; // Public comments
      
      allow create: if isValidUser() &&
                    request.auth.uid == request.resource.data.user.id;
      
      allow update: if isValidUser() && 
                    request.auth.uid == resource.data.user.id;
      
      allow delete: if isValidUser() && 
                    (request.auth.uid == resource.data.user.id || isAdmin());
    }
    
    // Feed Posts ("Threads") Collection - CORRECTED
    match /feedPosts/{postId} {
      // Anyone can read feed posts
      allow read: if true;

      // Authenticated users can create posts, with proper author validation
      allow create: if isValidUser()
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.author.id == request.auth.uid
                    && request.resource.data.likesCount == 0
                    && request.resource.data.commentsCount == 0
                    && request.resource.data.likedBy.size() == 0;

      // Allow any authenticated user to update for liking, but restrict other field changes.
      // This is simpler than managing likes in a subcollection for this use case.
      allow update: if isValidUser();

      // Only the author can delete their post
      allow delete: if isValidUser() && isAuthor(resource.data);
    }
    
    // Notifications Collection - User specific
    match /notifications/{notificationId} {
      allow read: if isValidUser() && 
                   request.auth.uid == resource.data.userId;

      allow create: if isValidUser(); // Server or app can create notifications
      
      allow update: if isValidUser() && 
                    request.auth.uid == resource.data.userId;
      
      allow delete: if isValidUser() && 
                    request.auth.uid == resource.data.userId;
    }
    
    // Letters Collection - Private messaging
    match /letters/{letterId} {
      allow read: if isValidUser() && 
                   (request.auth.uid == resource.data.authorId || 
                    request.auth.uid == resource.data.reader.id);

      allow create: if isValidUser() && 
                    request.auth.uid == request.resource.data.reader.id; // The reader creates the letter

      allow update: if isValidUser() &&
                    (request.auth.uid == resource.data.authorId || 
                     request.auth.uid == resource.data.reader.id);

      allow delete: if isValidUser() && 
                    request.auth.uid == resource.data.reader.id; // Only sender can delete
    }
    
    // Conversations Collection - Fixed messaging
    match /conversations/{conversationId} {
      allow read: if isValidUser() && 
                   request.auth.uid in resource.data.participantIds;

      allow create: if isValidUser() &&
                    request.auth.uid in request.resource.data.participantIds;

      allow update: if isValidUser() &&
                    request.auth.uid in resource.data.participantIds;

      allow delete: if isValidUser() && 
                    request.auth.uid in resource.data.participantIds;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isValidUser() &&
                     request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;

        allow create: if isValidUser() &&
                      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds &&
                      request.auth.uid == request.resource.data.senderId;

        allow update: if isValidUser() &&
                      request.auth.uid == resource.data.senderId;

        allow delete: if isValidUser() && 
                      request.auth.uid == resource.data.senderId;
      }
    }
  }
}
