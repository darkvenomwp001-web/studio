rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAuthor(doc) {
      return isOwner(doc.author.id);
    }
    
    function isCollaborator(doc) {
      return request.auth.uid in doc.collaboratorIds;
    }

    function canView(doc) {
      return doc.visibility == 'Public' || 
             (doc.visibility == 'Unlisted' && request.auth != null) ||
             (isOwner(doc.author.id) || isCollaborator(doc));
    }
    
    function isRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    match /users/{userId} {
      allow read;
      allow create: if request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isRole('admin'); 
    }

    match /stories/{storyId} {
      allow read: if canView(resource.data);
      allow create: if isOwner(request.resource.data.author.id);
      allow update: if isOwner(resource.data.author.id) || isCollaborator(resource.data);
      allow delete: if isOwner(resource.data.author.id);
    }

    match /comments/{commentId} {
      allow read;
      allow create: if request.auth.uid != null;
      allow update: if isOwner(resource.data.user.id);
      allow delete: if isOwner(resource.data.user.id);
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if request.auth.uid != null;
    }

    match /conversations/{conversationId} {
        allow read, create, update: if request.auth.uid in resource.data.participantIds;
        
        match /messages/{messageId} {
            allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
    }

    match /statusUpdates/{statusId} {
        allow read;
        allow create: if isOwner(request.resource.data.authorId);
        allow update, delete: if isOwner(resource.data.authorId);
    }
    
    match /globalChatMessages/{messageId} {
      allow read;
      allow create: if request.auth.uid != null;
    }

    match /feedPosts/{postId} {
      allow read;
      allow create: if request.auth.uid == request.resource.data.author.id;
      allow update: if request.auth.uid != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
      allow delete: if request.auth.uid == resource.data.author.id;
    }

    match /{path=**}/comments/{commentId} {
      allow read;
      allow create: if request.auth.uid != null;
      allow update, delete: if isOwner(resource.data.user.id);
    }

  }
}
