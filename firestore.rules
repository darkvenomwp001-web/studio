
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper functions
    function isNotGuest() {
      return request.auth != null && request.auth.token.isAnonymous == false;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // USER PROFILES
    // Everyone can read public profiles.
    // Users can only create and write to their own profile.
    match /users/{userId} {
      allow read;
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }
    
    // STORIES
    // Read: Public/Unlisted stories are readable by anyone. Private/Drafts are only readable by author/collaborators.
    // Write: Only author/collaborators can create/update stories.
    // Delete: Only the author can delete a story.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                  || resource.data.visibility == 'Unlisted'
                  || (request.auth != null && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
      allow update: if request.auth != null && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if request.auth != null && resource.data.author.id == request.auth.uid;
    }

    // COMMENTS
    // Read: Anyone can read comments.
    // Write: Authenticated (non-guest) users can create/update/delete their own comments.
    match /comments/{commentId} {
      allow read;
      allow create: if isNotGuest();
      allow update, delete: if request.auth != null && resource.data.user.id == request.auth.uid;
    }
    
    // NOTIFICATIONS
    // Read/Write: Users can only access their own notifications.
    match /notifications/{notificationId} {
        allow read, write, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // CONVERSATIONS & MESSAGES
    // Users can only read/write conversations they are a part of.
    match /conversations/{conversationId} {
      allow read, create, update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
    
    // LETTERS
    // Read: Public letters are readable by anyone. Private only by author/reader.
    // Create: Only non-guests can create letters.
    // Update: Only author can update (e.g., pin, respond).
    // Delete: Only the original reader can delete their letter.
    match /letters/{letterId} {
      allow read: if resource.data.visibility == 'public' 
                  || (request.auth != null && (resource.data.authorId == request.auth.uid || resource.data.reader.id == request.auth.uid));
      allow create: if isNotGuest();
      allow update: if request.auth != null && resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.reader.id == request.auth.uid;
    }
    
    // STATUS UPDATES
    // Read: Anyone can read published statuses.
    // Create/Update/Delete: Only the author can manage their own statuses.
    match /statusUpdates/{statusId} {
        allow read: if resource.data.status == 'published';
        allow create: if isNotGuest();
        allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // GLOBAL CHAT
    // Authenticated users can read and write. No edits or deletes.
    match /globalChatMessages/{messageId} {
        allow read: if request.auth != null;
        allow create: if isNotGuest();
    }
    
    // THREADS (FEED POSTS)
    match /feedPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if isNotGuest() && request.auth.uid == request.resource.data.author.id;
      // No one can update or delete feed posts for now to preserve thread integrity
    }
    
    // ANNOTATIONS
    // Users can only manage their own annotations.
    match /annotations/{annotationId} {
      allow read, write, create, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
