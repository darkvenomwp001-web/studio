
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isCollaborator(storyId) {
      return isSignedIn() && get(/databases/$(database)/documents/stories/$(storyId)).data.collaborators.hasAny([request.auth.uid]);
    }
    
    // USERS
    // Users can read any public profile.
    // Users can only create their own user document and can only update their own document.
    match /users/{userId} {
      allow read;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Do not allow users to delete their accounts directly through rules.
    }

    // STORIES
    // Allow anyone to read public stories.
    // Allow authenticated users to create stories.
    // Allow story owners or collaborators to update stories.
    // Allow only the original author to delete a story.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                      resource.data.visibility == 'Unlisted' ||
                      (isSignedIn() && (
                        resource.data.author.id == request.auth.uid ||
                        resource.data.collaborators.hasAny([{'id': request.auth.uid}])
                      ));
      
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      
      allow update: if isSignedIn() && (
                        resource.data.author.id == request.auth.uid ||
                        resource.data.collaborators.hasAny([{'id': request.auth.uid}])
                      );

      allow delete: if isSignedIn() && resource.data.author.id == request.auth.uid;
    }

    // COMMENTS
    // Allow anyone to read comments on public stories.
    // Allow authenticated users to create comments.
    // Allow comment owners to update or delete their comments.
    match /comments/{commentId} {
      allow read;
      allow create: if isSignedIn() && request.resource.data.user.id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user.id == request.auth.uid;
    }

    // NOTIFICATIONS
    // Users can only read, create, and update their own notifications.
    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Allow create by system/other users (e.g. for followers) - secured by Cloud Functions or app logic.
      // For direct client creation, it would be: allow create: if isSignedIn();
      allow create: if isSignedIn(); 
    }
    
    // CONVERSATIONS
    // Users can only access conversations they are a part of.
    match /conversations/{conversationId} {
      allow read, create, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
  }
}
