
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Check if the requesting user is in the story's collaborator list.
    function isCollaborator(storyId) {
      let storyData = get(/databases/$(database)/documents/stories/$(storyId)).data;
      return isSignedIn() && request.auth.uid in storyData.get('collaborators', []);
    }

    // Users Collection:
    // - Anyone can read public profile info (read).
    // - Only the authenticated owner can create their own profile document (create).
    // - Only the authenticated owner can update their profile (update).
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if false; // Generally, don't allow users to delete their own profiles.
    }

    // Stories Collection:
    // - Read access is public for 'Public' or 'Unlisted' stories.
    // - Private stories can only be read by the owner or collaborators.
    // - Any signed-in user can create a story (it will default to 'Private').
    // - Updates are restricted to the owner or collaborators.
    // - Deletion is restricted to the owner.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                     resource.data.visibility == 'Unlisted' ||
                     (isSignedIn() && (isOwner(resource.data.author.id) || isCollaborator(storyId)));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || isCollaborator(storyId));
      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }

    // Comments Collection:
    // - All comments are public to read.
    // - Only signed-in users can create comments.
    // - Only the comment's original author can update or delete it.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isOwner(resource.data.user.id);
    }

    // Notifications Collection:
    // - A user can only read or update (e.g., mark as read) their own notifications.
    // - Any signed-in user can create a notification (e.g., by following someone).
    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn();
      allow delete: if false; // Users shouldn't delete notifications.
    }

    // Conversations & Messages:
    // - A user must be a participant to read, create, or update a conversation document.
    // - A user must be a participant to read or create messages within that conversation.
    match /conversations/{conversationId} {
      allow read, create, update: if isSignedIn() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false; // Don't allow editing/deleting messages.
      }
    }
  }
}
