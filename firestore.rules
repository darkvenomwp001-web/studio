rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper function to check if a user is an author or collaborator of a story
    function isStoryEditor(storyId) {
      let story = get(/databases/$(database)/documents/stories/$(storyId)).data;
      return isOwner(story.author.id) || (story.collaborators != null && request.auth.uid in story.collaboratorIds);
    }

    match /users/{userId} {
      allow read;
      allow create: if isOwner(userId) && request.resource.data.username != null;
      allow update: if isOwner(userId);
      allow delete: if false; // Users should be disabled, not deleted
    }

    match /stories/{storyId} {
      // READ: Anyone can read public stories. Unlisted can be read with a link. Private only by owner/collaborator.
      allow read: if resource.data.visibility == 'Public' || 
                   resource.data.visibility == 'Unlisted' ||
                   (resource.data.visibility == 'Private' && isStoryEditor(storyId));

      // CREATE: Any authenticated user can create a story.
      allow create: if request.auth != null && isOwner(request.resource.data.author.id);
      
      // UPDATE: Only author or collaborator can update.
      allow update: if isStoryEditor(storyId);
      
      // DELETE: Only the author can delete.
      allow delete: if get(/databases/$(database)/documents/stories/$(storyId)).data.author.id == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read;
      allow create: if request.auth != null && isOwner(request.resource.data.user.id);
      allow update, delete: if request.auth != null && isOwner(get(/databases/$(database)/documents/comments/$(commentId)).data.user.id);
    }
    
    match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(resource.data.userId);
        allow create: if request.auth != null; // Notifications created by server actions or other users
    }

    match /conversations/{conversationId} {
      allow read, update: if request.auth.uid in resource.data.participantIds;
      allow create: if request.auth.uid in request.resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }

    match /feedPosts/{postId} {
        allow read;
        allow create: if request.auth != null && isOwner(request.resource.data.authorId);
        allow update: if request.auth != null; // For liking/unliking
        allow delete: if request.auth != null && isOwner(get(/databases/$(database)/documents/feedPosts/$(postId)).data.authorId);
    }

    match /statusUpdates/{statusId} {
        // Anyone can read published statuses
        allow read: if resource.data.status == 'published';

        // Users can read their own non-published statuses (drafts, archived, etc.)
        allow read: if request.auth.uid == resource.data.authorId;

        // Any authenticated user can create a status for themselves
        allow create: if request.auth != null && isOwner(request.resource.data.authorId);

        // Only the author can update their own status (e.g., to archive or trash it)
        allow update: if request.auth != null && isOwner(get(/databases/$(database)/documents/statusUpdates/$(statusId)).data.authorId);
      
        // Only the author can delete their own status
        allow delete: if request.auth != null && isOwner(get(/databases/$(database)/documents/statusUpdates/$(statusId)).data.authorId);
    }

    match /prompts/{promptId} {
        allow read;
        allow create: if request.auth != null && isOwner(request.resource.data.author.id);
        allow update, delete: if request.auth != null && isOwner(get(/databases/$(database)/documents/prompts/$(promptId)).data.author.id);
    }
    
    match /letters/{letterId} {
        allow read: if resource.data.visibility == 'public' || 
                     isOwner(resource.data.authorId) || 
                     isOwner(resource.data.reader.id);
        allow create: if request.auth != null && isOwner(request.resource.data.reader.id);
        allow update: if isOwner(get(/databases/$(database)/documents/letters/$(letterId)).data.authorId); // Only author can pin/respond
        allow delete: if isOwner(get(/databases/$(database)/documents/letters/$(letterId)).data.reader.id); // Only reader can delete
    }
  }
}
