
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Universal helper function to reliably check ownership
    function isAuthor(userId, data) {
      // Checks for authorId at the top level
      return userId == data.authorId ||
      // Checks for author map with an id field
      (data.author != null && userId == data.author.id) ||
      // Checks for authorInfo map with an id field (for statusUpdates)
      (data.authorInfo != null && userId == data.authorInfo.id) ||
      // Checks for user map with an id field (for comments)
      (data.user != null && userId == data.user.id);
    }

    match /users/{userId} {
      allow read;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || (request.auth != null && (isAuthor(request.auth.uid, resource.data) || request.auth.uid in resource.data.collaboratorIds));
      allow create: if request.auth != null && isAuthor(request.auth.uid, request.resource.data);
      allow update: if request.auth != null && (isAuthor(request.auth.uid, resource.data) || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if request.auth != null && isAuthor(request.auth.uid, resource.data);
    }

    match /comments/{commentId} {
      allow read;
      allow create: if request.auth != null && isAuthor(request.auth.uid, request.resource.data);
      allow update, delete: if request.auth != null && isAuthor(request.auth.uid, resource.data);
    }
    
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null; 
    }

    match /conversations/{conversationId} {
        allow read, create, update: if request.auth != null && request.auth.uid in resource.data.participantIds;
        match /messages/{messageId} {
            allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }
    }
    
    match /letters/{letterId} {
        allow read, create: if request.auth != null;
        allow update: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
    }
    
    match /feedPosts/{postId} {
        allow read;
        allow create: if request.auth != null && isAuthor(request.auth.uid, request.resource.data);
        allow update, delete: if request.auth != null && isAuthor(request.auth.uid, resource.data);
    }

    match /prompts/{promptId} {
        allow read;
        allow create: if request.auth != null && isAuthor(request.auth.uid, request.resource.data);
        // Allow update and delete only if the user is the author
        allow update, delete: if request.auth != null && isAuthor(request.auth.uid, resource.data);
    }
    
    match /statusUpdates/{statusId} {
        allow read, create: if request.auth != null;
        // Allow update and delete only if the user is the author
        allow update, delete: if request.auth != null && isAuthor(request.auth.uid, resource.data);
    }
  }
}
