
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthor(userId, data) {
      return userId == data.authorId || 
             userId == data.get('author', {}).get('id', '') || 
             userId == data.get('authorInfo', {}).get('id', '') ||
             userId == data.get('user', {}).get('id', '');
    }

    // Rules for 'users' collection
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for 'stories' collection
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                   (request.auth != null && isAuthor(request.auth.uid, resource.data)) ||
                   (resource.data.visibility == 'Unlisted' && request.auth != null) ||
                   (resource.data.collaboratorIds.hasAny([request.auth.uid]));

      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAuthor(request.auth.uid, resource.data) || request.auth.uid in resource.data.collaboratorIds;
    }
    
    // Rules for 'comments' collection
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAuthor(request.auth.uid, resource.data);
    }
    
    // Rules for 'notifications' collection
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Rules for 'letters' collection
    match /letters/{letterId} {
      allow read: if request.auth != null && (isAuthor(request.auth.uid, resource.data) || isAuthor(request.auth.uid, resource.data.get('reader', {})));
      allow create: if request.auth != null;
      allow update: if request.auth != null && isAuthor(request.auth.uid, resource.data);
    }

    // Rules for 'conversations' collection
    match /conversations/{conversationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;

      // Rules for 'messages' subcollection
      match /messages/{messageId} {
        allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.senderId;
      }
    }

    // Rules for 'statusUpdates' collection
    match /statusUpdates/{statusId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Any authenticated user can archive, trash, restore, or delete
      allow update, delete: if request.auth != null;
    }
    
    // Rules for 'prompts' collection
    match /prompts/{promptId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAuthor(request.auth.uid, resource.data);
    }
  }
}
