
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isNotGuest() {
      return request.auth.uid != null && request.auth.token.isAnonymous == false;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // USER collection
    match /users/{userId} {
      allow read;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Generally, don't allow users to delete their own accounts directly
    }

    // STORIES collection
    match /stories/{storyId} {
        // Read access
        allow read: if resource.data.visibility == 'Public' 
                    || resource.data.visibility == 'Unlisted'
                    || (request.auth != null && request.auth.uid == resource.data.author.id)
                    || (request.auth != null && resource.data.collaboratorIds.hasAny([request.auth.uid]));

        // Write access
        allow create, update: if request.auth != null && request.auth.uid == request.resource.data.author.id;
        allow delete: if request.auth != null && request.auth.uid == resource.data.author.id;
    }

    // COMMENTS collection
    match /comments/{commentId} {
      allow read;
      allow create: if isNotGuest();
      allow update: if isNotGuest() && request.auth.uid == resource.data.user.id;
      allow delete: if isNotGuest() && request.auth.uid == resource.data.user.id;
    }
    
    // NOTIFICATIONS collection
    match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(resource.data.userId);
        allow create: if isNotGuest();
    }
    
    // CONVERSATIONS collection
    match /conversations/{conversationId} {
      allow read, create, update: if request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }

    // LETTERS collection
    match /letters/{letterId} {
        allow read: if request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
        allow create: if isNotGuest() && request.auth.uid == request.resource.data.reader.id;
        allow update: if isNotGuest() && request.auth.uid == resource.data.authorId;
        allow delete: if isNotGuest() && request.auth.uid == resource.data.reader.id;
    }
    
    // PROMPTS collection
    match /prompts/{promptId} {
        allow read;
        allow create: if isNotGuest();
        allow update, delete: if isNotGuest() && request.auth.uid == resource.data.author.id;
    }
    
    // STATUS UPDATES collection
    match /statusUpdates/{statusId} {
        allow read;
        allow create: if isNotGuest();
        allow update, delete: if isNotGuest() && request.auth.uid == resource.data.authorId;
    }
    
    // FEED POSTS (Threads) collection
    match /feedPosts/{postId} {
        allow read;
        allow create: if isNotGuest() && request.auth.uid == request.resource.data.author.id;
        allow update: if isNotGuest() && request.auth.uid == resource.data.author.id;
        // Allow liking/unliking
        allow update: if isNotGuest() && request.resource.data.keys().hasOnly(['likedBy', 'likesCount']);
        allow delete: if isNotGuest() && request.auth.uid == resource.data.author.id;
    }
    
    // ANNOTATIONS collection
    match /annotations/{annotationId} {
        allow read, write: if isOwner(request.resource.data.userId);
        allow create: if isNotGuest() && isOwner(request.resource.data.userId);
        allow update, delete: if isNotGuest() && isOwner(resource.data.userId);
    }

    // Global Chat Room
    match /globalChatMessages/{messageId} {
      allow read;
      allow create: if isNotGuest();
    }
  }
}
