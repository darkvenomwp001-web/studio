
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if a user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      // Anyone can read a user's public profile
      allow read: if true;

      // Only the authenticated user can create their own document
      allow create: if isOwner(userId);

      // Only the authenticated user can update their own document
      allow update: if isOwner(userId);
      
      // Users cannot delete their own accounts through the app
      allow delete: if false;
    }

    // Stories Collection
    match /stories/{storyId} {
      // Allow read access based on story visibility
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted'
                  || (isAuthenticated() && resource.data.author.id == request.auth.uid)
                  || (isAuthenticated() && request.auth.uid in resource.data.collaboratorIds);

      // Authenticated users can create stories
      allow create: if isAuthenticated();

      // Only the author or collaborators can update a story
      allow update: if isAuthenticated() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      
      // Only the original author can delete a story
      allow delete: if isAuthenticated() && resource.data.author.id == request.auth.uid;
    }

    // Comments Collection
    match /comments/{commentId} {
      // Anyone can read comments
      allow read: if true;
      
      // Authenticated users can create comments
      allow create: if isAuthenticated();
      
      // Only the owner of the comment can update or delete it
      allow update, delete: if isAuthenticated() && resource.data.user.id == request.auth.uid;
    }
    
    // Notifications Collection
    match /notifications/{notificationId} {
        // A user can only read or update their own notifications
        allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
        // Anyone can create a notification (actions are secured in backend logic)
        allow create: if isAuthenticated();
    }
    
    // Letters Collection
    match /letters/{letterId} {
        // Only the sender (reader) or receiver (author) can read a letter
        allow read: if isAuthenticated() && (resource.data.reader.id == request.auth.uid || resource.data.author.id == request.auth.uid);
        // Only the sender can create a letter
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.reader.id;
        // Only the author can update a letter (to respond or pin it)
        allow update: if isAuthenticated() && resource.data.author.id == request.auth.uid;
        // Neither can delete letters from the app
        allow delete: if false;
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      // Only participants can access conversation data
      allow get, list, create, update: if isAuthenticated() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        // Only participants can read messages
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid]);
        // Only participants can create messages
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid]);
        // Users cannot update/delete messages
        allow update, delete: if false;
      }
    }
    
    // Live Feed Collection
    match /liveFeed/{postId} {
        // Anyone can read the live feed
        allow read: if true;
        // Any authenticated user can create a post
        allow create: if isAuthenticated();
        // Only the author can update or delete their own post
        allow update, delete: if isAuthenticated() && isOwner(resource.data.authorId);
    }
    
    // Prompts Collection
    match /prompts/{promptId} {
        // Anyone can read prompts
        allow read: if true;
        // Any authenticated user can create a prompt
        allow create: if isAuthenticated();
        // Only the author can update or delete their own prompt
        allow update, delete: if isAuthenticated() && isOwner(resource.data.authorId);
    }

    // Status Updates Collection
    match /statusUpdates/{statusId} {
        // Anyone can read status updates
        allow read: if true;
        // Authenticated users can create status updates
        allow create: if isAuthenticated();
        // Only the owner can delete their own status update
        allow delete: if isAuthenticated() && isOwner(resource.data.authorId);
        // Statuses cannot be updated
        allow update: if false;
    }
    
  }
}
