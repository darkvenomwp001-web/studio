rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership in various data structures
    function isOwner(userId, data) {
      return userId == data.authorId || 
             (data.author != null && userId == data.author.id) || 
             (data.user != null && userId == data.user.id) ||
             (data.authorInfo != null && userId == data.authorInfo.id);
    }
    
    // Users can read any profile, but only edit their own.
    match /users/{userId} {
      allow read;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Stories can be read if public/unlisted. Only author/collaborators can write.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted';
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
      allow update, delete: if request.auth != null && (isOwner(request.auth.uid, resource.data) || request.auth.uid in resource.data.collaboratorIds);
    }

    // Comments can be read by anyone. Users can create, and only owners can edit/delete.
    match /comments/{commentId} {
      allow read;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }

    // Notifications are private to each user.
    match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
        allow create: if request.auth != null;
    }
    
    // Letters are private between the reader and author.
    match /letters/{letterId} {
        allow read, create, update: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
        allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Live Feed posts can be read by anyone. Owners can update/delete.
    match /liveFeed/{postId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // Prompts can be read by anyone. Owners can update/delete.
    match /prompts/{promptId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.author.id == request.auth.uid;
    }
    
    // Status updates are public, but only owners can manage them.
    match /statusUpdates/{statusId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    
    // NEW: Secure rule for the pendingDeletions collection.
    // A user can only create a deletion request for a post they own.
    match /pendingDeletions/{deletionId} {
        allow read, write: if false; // No one can read/write directly.
        allow create: if request.auth != null && 
            get(/databases/$(database)/documents/liveFeed/$(request.resource.data.postId)).data.authorId == request.auth.uid;
    }

    // Feed posts can be read by anyone.
    match /feedPosts/{postId} {
        allow read;
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
        allow update: if request.auth != null; // Simplified for likes
        allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    match /conversations/{conversationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null;
      
      match /messages/{messageId} {
         allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
         allow update, delete: if request.auth != null && request.auth.uid == resource.data.senderId;
      }
    }
  }
}
