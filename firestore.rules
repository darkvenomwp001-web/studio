
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isNewUser() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function isStoryCollaborator(storyId) {
        return request.auth.uid in get(/databases/$(database)/documents/stories/$(storyId)).data.collaboratorIds;
    }

    // USER Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
        request.resource.data.keys().hasOnly(['displayName', 'username', 'bio', 'role', 'avatarUrl', 'updatedAt', 'readingList', 'followingCount', 'followingIds']);
    }

    // STORY Collection
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                   resource.data.visibility == 'Unlisted' || 
                   (isAuthenticated() && isOwner(resource.data.author.id)) ||
                   (isAuthenticated() && isStoryCollaborator(storyId));
                   
      allow create: if isAuthenticated() && isOwner(request.resource.data.author.id);
      
      allow update: if isAuthenticated() && (isOwner(resource.data.author.id) || isStoryCollaborator(storyId));

      allow delete: if isAuthenticated() && isOwner(resource.data.author.id);
    }

    // COMMENT Collection
    match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.user.id == request.auth.uid;
        allow update: if isAuthenticated() && isOwner(resource.data.user.id);
        allow delete: if isAuthenticated() && isOwner(resource.data.user.id);
    }
    
    // NOTIFICATION Collection
    match /notifications/{notificationId} {
        allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
        allow create: if isAuthenticated(); // Server/functions will create these
    }

    // LETTERS Collection
    match /letters/{letterId} {
        allow read, update: if isAuthenticated() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
        allow create: if isAuthenticated() && isOwner(request.resource.data.reader.id);
    }

    // CONVERSATIONS and MESSAGES Subcollection
    match /conversations/{conversationId} {
      allow read, create, update: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
        allow read, create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
    
    // STORY MEDIA (24-hour stories) Collection
    match /storyMedia/{storyMediaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    // QUESTIONS Collection (Simplified for Homepage)
    match /questions/{questionId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.asker.id == request.auth.uid;
      allow update, delete: if isAuthenticated() && isOwner(resource.data.asker.id);
    }
  }
}
