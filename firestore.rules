rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read anyone's profile, but only write to their own.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // Stories can be read if public, but only written by their author or collaborators.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                     (resource.data.visibility == 'Unlisted' && request.auth != null) ||
                     (request.auth != null && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds));

      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
      
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds);
    }

    // Comments can be read by anyone, but only created by logged-in users.
    // Users can only edit or delete their own comments.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.user.id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user.id == request.auth.uid;
    }

    // Notifications can only be accessed by the user they are for.
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Letters can be read by the sender or receiver (author), but only created by a logged-in user.
    match /letters/{letterId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.reader.id || request.auth.uid == resource.data.authorId);
      allow create: if request.auth != null && request.resource.data.reader.id == request.auth.uid;
      allow update: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Anyone can read feed posts. Authenticated users can create their own.
    // Users can only delete their own posts, but anyone can like a post.
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'likedBy']))
      );
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // Anyone can read liveFeed posts. Authenticated users can create them.
    match /liveFeed/{postId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
    }

    // Anyone can read prompts. Authenticated users can create them.
    match /prompts/{promptId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
    }
    
    // Anyone can read statuses. Authenticated users can create them.
    match /statusUpdates/{statusId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
    }

    // Conversations and their messages can only be accessed by participants.
    match /conversations/{conversationId} {
      allow read, create, update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      
      match /messages/{messageId} {
         allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
  }
}
