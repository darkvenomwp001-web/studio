
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Users Collection
    match /users/{userId} {
      allow read; 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }
    
    // Stories (Books) Collection
    match /stories/{storyId} {
      // Allow anyone to read public stories
      allow read: if resource.data.visibility == 'Public';
      // Allow logged-in users to read unlisted stories
      allow read: if isSignedIn() && resource.data.visibility == 'Unlisted';
      // Allow author and collaborators to read their private stories/drafts
      allow read: if isOwner(resource.data.author.id) || (isSignedIn() && resource.data.collaboratorIds.hasAny([request.auth.uid]));

      // Only the author can create a story
      allow create: if isOwner(resource.data.author.id);

      // Only author and collaborators can update
      allow update: if isOwner(resource.data.author.id) || (isSignedIn() && resource.data.collaboratorIds.hasAny([request.auth.uid]));
      
      // Only the author can delete
      allow delete: if isOwner(resource.data.author.id);
    }

    // UserStories (Instagram-style)
    match /userStories/{userStoryId} {
        // Anyone can view stories
        allow read;

        // A user can only create a story for themselves
        allow create: if isOwner(request.resource.data.authorId);

        // A user can only delete their own story
        allow delete: if isOwner(resource.data.authorId);
    }

    // Comments Collection
    match /comments/{commentId} {
      allow read;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.user.id);
    }
    
    // Letters Collection
    match /letters/{letterId} {
      allow read: if isOwner(resource.data.authorId) || isOwner(resource.data.reader.id);
      allow create: if isOwner(request.resource.data.reader.id);
      allow update: if isOwner(resource.data.authorId);
    }

    // Notifications Collection
    match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(resource.data.userId);
    }
    
    // Feed Posts
    match /feedPosts/{postId} {
        allow read; // Anyone can read feed posts
        allow create: if isOwner(request.resource.data.authorId);
        allow update, delete: if isOwner(resource.data.authorId);
    }
  }
}
