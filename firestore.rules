
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId, data) {
      return userId == request.auth.uid && (
        data.authorId == userId ||
        (data.author != null && data.author.id == userId) ||
        (data.user != null && data.user.id == userId) ||
        (data.authorInfo != null && data.authorInfo.id == userId)
      );
    }

    match /users/{userId} {
      allow read;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' ||
                   (resource.data.visibility == 'Unlisted') ||
                   (request.auth != null && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if request.auth != null && resource.data.author.id == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }
    
    match /notifications/{notificationId} {
        allow read, update, delete: if request.auth.uid == resource.data.userId;
        allow create: if request.auth != null;
    }
    
    match /letters/{letterId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    match /liveFeed/{postId} {
      allow read;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }
    
    match /prompts/{promptId} {
      allow read;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }

    match /statusUpdates/{statusId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.authorId;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }
  }
}
