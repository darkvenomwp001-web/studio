rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Universal helper function to check for ownership in various data structures.
    // This is the core fix to address all previous permission issues.
    function isOwner(userId) {
      let data = resource.data;
      return userId == request.auth.uid ||
             (data.hasAny(['author']) && data.author.id == request.auth.uid) ||
             (data.hasAny(['authorId']) && data.authorId == request.auth.uid) ||
             (data.hasAny(['user']) && data.user.id == request.auth.uid) ||
             (data.hasAny(['authorInfo']) && data.authorInfo.id == request.auth.uid);
    }
    
    // USERS: Users can manage their own profile.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if false; // Users should not be able to delete their own profiles.
    }

    // STORIES: Granular control based on author, collaborator, and visibility status.
    match /stories/{storyId} {
      allow get: if resource.data.visibility == 'Public' || 
                    resource.data.visibility == 'Unlisted' ||
                    (request.auth != null && (isOwner(request.auth.uid) || request.auth.uid in resource.data.collaboratorIds));
      allow list: if resource.data.visibility == 'Public';
      allow create: if request.auth != null && isOwner(request.auth.uid);
      allow update: if request.auth != null && (isOwner(request.auth.uid) || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if request.auth != null && isOwner(request.auth.uid);
    }

    // COMMENTS: Users can create comments and manage their own.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwner(request.auth.uid);
    }

    // NOTIFICATIONS: Users can only access their own notifications.
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null; // Typically handled by server actions after a triggering event.
    }
    
    // LIVE FEED POSTS: Users can create posts and manage their own.
    match /liveFeed/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwner(request.auth.uid);
    }

    // PROMPTS: Users can create prompts and manage their own.
    match /prompts/{promptId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && isOwner(request.auth.uid);
    }

    // STATUS UPDATES: Users create/manage their own. Read might be restricted to followers in a future version.
    match /statusUpdates/{statusId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwner(request.auth.uid);
    }

    // MESSAGING: Secure rules for conversations and messages.
    match /conversations/{conversationId} {
      allow read, create, update: if request.auth != null && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if request.auth != null && isOwner(request.auth.uid);
      }
    }

    // LETTERS: Secure rules for letters between users and authors.
    match /letters/{letterId} {
        allow read: if request.auth != null && (resource.data.reader.id == request.auth.uid || resource.data.author.id == request.auth.uid);
        allow create: if request.auth != null;
        allow update: if request.auth != null && resource.data.author.id == request.auth.uid; // Only author can update (pin, respond)
    }
  }
}
