
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users: Users can be read by anyone (for profiles), but only the owner can create/update their own document.
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      // Delete is not allowed to prevent accidental account removal from client.
      allow delete: if false;
    }

    // Stories: Can be read if public. Can be created/updated by the author or a collaborator.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || resource.data.visibility == 'Unlisted' || (isOwner(resource.data.author.id)) || (resource.data.collaboratorIds.hasAny([request.auth.uid]));
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(resource.data.author.id) || resource.data.collaboratorIds.hasAny([request.auth.uid]));
      allow delete: if isSignedIn() && isOwner(resource.data.author.id);
    }

    // userNotes: Public, non-expired notes can be read by anyone. Users can only create their own notes.
    // This rule is designed to work with the client-side query and will prompt for an index.
    match /userNotes/{noteId} {
      allow read: if request.query.limit <= 100; // Allow queries, client handles filtering
      allow create: if isOwner(request.resource.data.authorId);
      allow delete: if isOwner(resource.data.authorId);
      // No updates allowed, notes are ephemeral.
      allow update: if false;
    }

    // feedPosts: Any authenticated user can read the feed. Posts can only be created by their author.
    // Liking is handled by allowing any signed-in user to update the post.
    // This rule is designed to work with the client-side query and will prompt for an index.
    match /feedPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isOwner(request.resource.data.author.id);
      allow update: if isSignedIn(); // For liking posts
      allow delete: if isOwner(resource.data.author.id);
    }
    
    // Comments: Can be read by anyone. Can be created by any signed-in user. Can only be updated/deleted by the owner.
    match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isOwner(resource.data.user.id);
    }

    // Notifications: Only readable and updatable by the user they are intended for.
    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isSignedIn();
    }
    
    // Letters: Only readable/updatable by the sender (reader) or receiver (author).
    match /letters/{letterId} {
       allow read, update: if isSignedIn() && (request.auth.uid == resource.data.reader.id || request.auth.uid == resource.data.author.id);
       allow create: if isOwner(request.resource.data.reader.id);
       allow delete: if isOwner(resource.data.reader.id) || isOwner(resource.data.author.id);
    }

    // Conversations & Messages: Only participants can read or write.
    match /conversations/{conversationId} {
      allow read, create, update, delete: if isSignedIn() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if isSignedIn() && request.auth.uid == resource.data.senderId;
      }
    }
  }
}
