
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the requesting user is the owner of a document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===== USERS COLLECTION =====
    // Public read is allowed for profiles. Only the user can create/update their own profile.
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Deletion from client is disabled
    }

    // ===== STORIES COLLECTION (Books) =====
    // Public can read if story is 'Public' or 'Unlisted'. Only author/collaborators can manage content.
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                    resource.data.visibility == 'Unlisted' || 
                    (isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isSignedIn() && resource.data.author.id == request.auth.uid;
    }

    // ===== USER STORIES COLLECTION (Instagram-style Stories) =====
    // Corrected rule: Anyone can read a story if it has not expired. Only the author can create one.
    match /userStories/{userStoryId} {
      allow read: if resource.data.expiresAt > request.time;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if false;
    }

    // ===== COMMENTS COLLECTION =====
    // Comments are public to read. Only the creator can edit/delete their own comment.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.user.id);
    }

    // ===== LETTERS COLLECTION =====
    // Only the sender (reader) or receiver (author) can read/update. Only reader can create.
    match /letters/{letterId} {
      allow read, update: if isSignedIn() && (request.auth.uid == resource.data.author.id || request.auth.uid == resource.data.reader.id);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.reader.id;
      allow delete: if false;
    }

    // ===== FEED POSTS COLLECTION =====
    // Feed posts are public. Only the author can create/delete. Any signed-in user can update (for likes).
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.author.id);
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data.author.id);
    }

    // ===== NOTIFICATIONS COLLECTION =====
    // Notifications are private to the user they are intended for.
    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if true; // Created by trusted server actions
    }
  }
}
