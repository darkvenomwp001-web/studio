rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: Can only read/update their own profile. Anyone can read a public profile.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Stories: Detailed rules for visibility and collaboration.
    match /stories/{storyId} {
      // Anyone can read a public story. Unlisted can be read with a link.
      // Private/Drafts are only readable by the author or collaborators.
      allow read: if resource.data.visibility == 'Public' 
                    || resource.data.visibility == 'Unlisted'
                    || (request.auth != null && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));

      // Only authenticated users can create stories.
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;
      
      // Only the author or collaborators can update a story.
      allow update: if request.auth != null && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);

      // Only the original author can delete a story.
      allow delete: if request.auth != null && resource.data.author.id == request.auth.uid;
    }

    // Comments: Users can create comments, but only edit/delete their own.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;

      // The user who created the comment can update or delete it.
      allow update, delete: if request.auth != null && resource.data.user.id == request.auth.uid;
    }

    // LiveFeed: Users can create posts, but only edit/delete/archive their own.
    match /liveFeed/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;

      // Explicit, multi-location check for ownership.
      allow update, delete: if request.auth != null && (
        resource.data.author.id == request.auth.uid ||
        resource.data.authorId == request.auth.uid
      );
    }

    // Prompts: Users can create prompts, but only edit/delete/archive their own.
    match /prompts/{promptId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.author.id == request.auth.uid;

      // Explicit, multi-location check for ownership.
      allow update, delete: if request.auth != null && (
        resource.data.author.id == request.auth.uid ||
        resource.data.authorId == request.auth.uid
      );
    }
    
    // Status Updates: Users can create statuses, but only archive/delete their own.
    match /statusUpdates/{statusId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;

        // Explicit, multi-location check for ownership.
        allow update, delete: if request.auth != null && (
          resource.data.authorId == request.auth.uid ||
          resource.data.authorInfo.id == request.auth.uid
        );
    }

    // Notifications: Users can only read their own notifications. No direct creation/update/delete.
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, delete: if false; // Should be created by server actions only
    }
    
    // Letters: Users can only read letters they sent or received. No direct deletion.
    match /letters/{letterId} {
      allow read, update: if request.auth != null && (
        resource.data.reader.id == request.auth.uid || 
        resource.data.authorId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.reader.id == request.auth.uid;
      allow delete: if false; // Deletions handled by server logic/archive feature
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      // Can only read/update a conversation if you are a participant.
      allow read, update: if request.auth.uid in resource.data.participantIds;
      // Can only create if you are one of the participants being added.
      allow create: if request.auth.uid in request.resource.data.participantIds;

      // Messages
      match /messages/{messageId} {
        // Can read/create messages if you are part of the parent conversation.
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        // Can only update/delete your own messages.
        allow update, delete: if request.auth.uid == resource.data.senderId;
      }
    }
  }
}
