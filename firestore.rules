rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId, data) {
      return userId == data.get(['author', 'id'], null) ||
             userId == data.get(['authorId'], null) ||
             userId == data.get(['user', 'id'], null) ||
             userId == data.get(['authorInfo', 'id'], null);
    }
    
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
    }
    
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' || 
                   resource.data.visibility == 'Unlisted' ||
                   (request.auth != null && (isOwner(request.auth.uid, resource.data) || request.auth.uid in resource.data.collaboratorIds));
      allow create: if request.auth != null;
      allow update: if request.auth != null && (isOwner(request.auth.uid, resource.data) || request.auth.uid in resource.data.collaboratorIds);
      allow delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }

    match /liveFeed/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && isOwner(request.auth.uid, resource.data);
      allow delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }

    match /prompts/{promptId} {
        allow read: if true;
        allow create: if request.auth != null && isOwner(request.auth.uid, request.resource.data);
        allow update, delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }
    
    match /statusUpdates/{statusId} {
        allow read: if true;
        allow create: if request.auth != null && isOwner(request.auth.uid, request.resource.data);
        allow update, delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    match /letters/{letterId} {
      allow read, update, create, delete: if request.auth != null && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
    }
    
    match /pendingDeletions/{deletionId} {
        allow create: if request.auth != null && request.resource.data.requestedBy == request.auth.uid;
        // No other actions should be allowed on these records by clients.
        allow read, update, delete: if false;
    }

    match /conversations/{conversationId} {
      allow read, update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      match /messages/{messageId} {
        allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      }
    }
    
    match /feedPosts/{postId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
        allow update: if request.auth != null && isOwner(request.auth.uid, resource.data);
        allow delete: if request.auth != null && isOwner(request.auth.uid, resource.data);
    }
  }
}
