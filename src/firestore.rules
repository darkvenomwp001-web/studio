
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUsername(userId) {
        return get(/databases/$(database)/documents/users/$(userId)).data.username;
    }
    
    // Unified Owner Check - Recognizes both creator handles
    function isAppOwner() {
        return isSignedIn() && (getUsername(request.auth.uid) == 'authorrafaelnv' || getUsername(request.auth.uid) == 'd4rkv3nom');
    }
    
    function getRole(userId) {
        return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    function isWriter() {
        return isSignedIn() && getRole(request.auth.uid) == 'writer';
    }

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(userId);

      // App owners have full control. Users can update their own non-protected fields.
      allow update: if isAppOwner() || (
        isSignedIn() && isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isBanned', 'isVerified'])
      );

      allow delete: if isAppOwner() && request.auth.uid != userId;
    }

    // Stories Collection
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                    || (resource.data.visibility == 'Unlisted' && isSignedIn())
                    || (isSignedIn() && request.auth.uid == resource.data.author.id)
                    || (isSignedIn() && request.auth.uid in resource.data.collaboratorIds);

      allow create: if isWriter() || isAppOwner();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds || isAppOwner());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.author.id || isAppOwner());
    }

    // Comments Collection
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.user.id || isAppOwner());
    }
    
    // Notifications Collection
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn();
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read, create: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false;
      }
    }
    
    // Global Chat
    match /globalChatMessages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.token.firebase.sign_in_provider != "anonymous" && isOwner(request.resource.data.author.id);
      allow update, delete: if false;
    }

    // Status Updates
    match /statusUpdates/{statusId} {
      allow read: if resource.data.status == 'published' && resource.data.expiresAt > request.time;
      allow create: if (isWriter() || isAppOwner()) && request.auth.uid == request.resource.data.authorId;
      allow update: if isSignedIn() && isOwner(resource.data.authorId); 
      allow delete: if isSignedIn() && isOwner(resource.data.authorId);
    }

    // Prompts
    match /prompts/{promptId} {
      allow read: if resource.data.isArchived == false;
      allow create: if isWriter() || isAppOwner();
      allow update, delete: if isSignedIn() && (isOwner(resource.data.author.id) || isAppOwner());
    }
    
    // Letters
    match /letters/{letterId} {
       allow read: if isSignedIn() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId));
       allow create: if isSignedIn();
       allow update: if isSignedIn() && isOwner(resource.data.authorId);
       allow delete: if isSignedIn() && isOwner(resource.data.reader.id);
    }

    // Community Feed Posts
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      
      // Allow author/owner to update content. Allow all to update interaction counts.
      allow update: if isAppOwner() || isOwner(resource.data.author.id) || (
        isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['reactionsCount', 'commentsCount', 'repostCount'])
      );
                      
      allow delete: if isAppOwner() || isOwner(resource.data.author.id);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isOwner(request.resource.data.user.id);
        allow update, delete: if isSignedIn() && (isOwner(resource.data.user.id) || isAppOwner());
      }
      
      match /reactions/{userId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && isOwner(userId);
        allow update: if false;
      }
    }
    
    // Questions & Polls
    match /questions/{questionId} {
      allow read: if resource.data.status == 'answered' || (isSignedIn() && isOwner(resource.data.authorId));
      allow create: if isSignedIn() && isOwner(request.resource.data.asker.id);
      allow update: if isSignedIn() && isOwner(resource.data.authorId);
      allow delete: if isSignedIn() && (isOwner(resource.data.authorId) || isOwner(resource.data.asker.id));
    }

    match /polls/{pollId} {
      allow read: if true;
      allow create: if isWriter() || isAppOwner();
      allow update: if isSignedIn();
      allow delete: if isAppOwner() || isOwner(resource.data.authorId);
    }
  }
}
