
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Unified Owner Check - Recognizes the creator handle
    // Grants absolute authority based on identity or specific UID
    function isAppOwner() {
        return isSignedIn() && (
               request.auth.uid == 'rpTmIq5pnKc91aSSgMJiF26zIYy2' ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username in ['arnv', '@arnv'])
        );
    }
    
    function getRole(userId) {
        return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    function isWriter() {
        return isSignedIn() && (getRole(request.auth.uid) == 'writer' || isAppOwner());
    }

    // --- Collection Rules ---

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(userId);

      // App owners can update anything.
      // Regular users can update their own profile except administrative flags.
      allow update: if isAppOwner()
                    || (isSignedIn() && isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isBanned', 'isVerified']));

      allow delete: if isAppOwner() && request.auth.uid != userId;
    }

    // Stories Collection
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                    || (resource.data.visibility == 'Unlisted' && isSignedIn())
                    || (isSignedIn() && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds || isAppOwner()));

      allow create: if isWriter();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds || isAppOwner());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.author.id || isAppOwner());
    }

    // Comments Collection on Chapters
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.user.id || isAppOwner());
    }
    
    // Notifications Collection
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn();
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false;
      }
    }
    
    // Global Chat
    match /globalChatMessages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.token.firebase.sign_in_provider != "anonymous" && isOwner(request.resource.data.author.id);
      allow update, delete: if false;
    }

    // Status Updates
    match /statusUpdates/{statusId} {
      allow read: if isAppOwner() 
                    || (isSignedIn() && resource.data.authorId == request.auth.uid)
                    || (resource.data.status == 'published' && resource.data.isHidden == false);
      
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if isAppOwner() || (isSignedIn() && isOwner(resource.data.authorId));
    }

    // Prompts
    match /prompts/{promptId} {
      allow read: if resource.data.isArchived == false;
      allow create: if isWriter();
      allow update, delete: if isSignedIn() && (isOwner(resource.data.author.id) || isAppOwner());
    }
    
    // Letters
    match /letters/{letterId} {
       allow read: if isSignedIn() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId) || isAppOwner());
       allow create: if isSignedIn();
       allow update: if isSignedIn() && (isOwner(resource.data.authorId) || isAppOwner());
       allow delete: if isSignedIn() && (isOwner(resource.data.reader.id) || isAppOwner());
    }

    // Annotations
    match /annotations/{annotationId} {
      allow read: if resource.data.visibility == 'public' 
                    || (isSignedIn() && (isOwner(resource.data.userId) || isAppOwner()));
      
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAppOwner());
      
      allow update: if isSignedIn() && (
        isOwner(resource.data.userId) || 
        isAppOwner() || 
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['reactionsCount', 'reactionCounts'])
      );
      
      allow delete: if isSignedIn() && (isOwner(resource.data.userId) || isAppOwner());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.user.id || isAppOwner());
      }
      
      match /reactions/{userId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn() && (isOwner(userId) || isAppOwner());
      }
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if isWriter() && isOwner(request.resource.data.author.id);
      allow update: if isSignedIn() && (isOwner(request.resource.data.author.id) || isAppOwner()) 
                    && request.resource.data.author.id == resource.data.author.id;
      allow delete: if isSignedIn() && (isOwner(request.resource.data.author.id) || isAppOwner());
    }

    // Community Feed Posts
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      
      allow update: if isAppOwner() || isOwner(resource.data.author.id) || (
        isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['reactionsCount', 'commentsCount', 'repostCount'])
      );
                      
      allow delete: if isAppOwner() || isOwner(resource.data.author.id);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isOwner(request.resource.data.user.id);
        allow update, delete: if isSignedIn() && (isOwner(request.resource.data.user.id) || isAppOwner());
      }
      
      match /reactions/{userId} {
        allow read: if true;
        allow create, delete, update: if isSignedIn() && isOwner(userId);
      }
    }
    
    // Questions & Polls
    match /questions/{questionId} {
      allow read: if resource.data.status == 'answered' || (isSignedIn() && (isOwner(resource.data.authorId) || isAppOwner()));
      allow create: if isSignedIn() && isOwner(request.resource.data.asker.id);
      allow update: if isSignedIn() && (isOwner(resource.data.authorId) || isAppOwner());
      allow delete: if isSignedIn() && (isOwner(resource.data.authorId) || isOwner(request.resource.data.asker.id) || isAppOwner());
    }

    match /polls/{pollId} {
      allow read: if true;
      allow create: if isWriter();
      allow update: if isSignedIn() && (isAppOwner() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['options'])); 
      allow delete: if isAppOwner() || isOwner(resource.data.authorId);
    }
  }
}
