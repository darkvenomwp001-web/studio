
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // Core Helper Functions
    // ========================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isDocumentOwner(resourceData, ownerField) {
      return request.auth != null && request.auth.uid == resourceData[ownerField];
    }
    
    function isAdmin() {
      // In a real app, you would have a more secure way of managing admin roles
      // e.g., checking a custom claim: return request.auth.token.admin == true;
      let admin_uids = []; // Add your admin UIDs here
      return isSignedIn() && request.auth.uid in admin_uids;
    }

    // ========================================
    // Collection Rules
    // ========================================

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId; // Users can create their own profile document
      allow update: if request.auth.uid == userId; // Users can update their own profile
      allow delete: if request.auth.uid == userId || isAdmin(); // Users can delete their own account
    }
    
    // Stories Collection
    match /stories/{storyId} {
      // Read stories based on visibility
      allow read: if resource.data.visibility == 'Public' ||
                   (resource.data.visibility == 'Unlisted' && isSignedIn()) ||
                   (isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds));

      // Create new story if authenticated
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;

      // Update story if owner or collaborator
      allow update: if isSignedIn() && (resource.data.author.id == request.auth.uid || request.auth.uid in resource.data.collaboratorIds);

      // Delete story only if owner
      allow delete: if isSignedIn() && resource.data.author.id == request.auth.uid;
    }

    // Comments Collection
    match /comments/{commentId} {
      allow read: if true; // All comments are public
      allow create: if isSignedIn() && request.resource.data.user.id == request.auth.uid; // Must be signed in to comment
      allow update, delete: if isSignedIn() && resource.data.user.id == request.auth.uid; // Can only edit/delete your own comments
    }

    // Notifications Collection
    match /notifications/{notificationId} {
        // Can only read, update, or delete your own notifications
        allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
        // Anyone can create a notification (e.g. server-side functions)
        allow create: if isSignedIn();
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
        allow read, update, delete: if isSignedIn() && request.auth.uid in resource.data.participantIds;
        allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;

        match /messages/{messageId} {
            allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
            allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
            allow update, delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
        }
    }

    // Feed Posts
    match /feedPosts/{postId} {
      // Anyone can read posts
      allow read: if true;
      // Only authenticated users can create posts
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      // Any authenticated user can update a post (for liking)
      allow update: if isSignedIn();
      // Only the author can delete a post
      allow delete: if isSignedIn() && resource.data.author.id == request.auth.uid;
    }
    
    // Status Updates Collection
    match /statusUpdates/{statusId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // Prompts Collection
    match /prompts/{promptId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.author.id == request.auth.uid;
    }

    // Letters Collection
    match /letters/{letterId} {
        allow read: if isSignedIn() && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
        allow create: if isSignedIn() && request.resource.data.reader.id == request.auth.uid;
        allow update: if isSignedIn() && (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id);
        allow delete: if isSignedIn() && request.auth.uid == resource.data.reader.id; // Only sender can delete
    }

  }
}
