
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Unified Owner Check - Recognizes both creator handles
    // Uses get() for global checks, but we supplement this in the users match for efficiency
    function isAppOwner() {
        return isSignedIn() && 
               exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username in ['authorrafaelnv', 'd4rkv3nom'];
    }
    
    function getRole(userId) {
        return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    function isWriter() {
        return isSignedIn() && (getRole(request.auth.uid) == 'writer' || isAppOwner());
    }

    // A verified user is one who is signed in and has verified their email address.
    function isVerifiedUser() {
        return isSignedIn() && request.auth.token.email_verified == true;
    }

    // --- Collection Rules ---

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(userId);

      // App owners (by handle) can update anything on their own doc.
      // Regular users can update their own profile except protected fields.
      allow update: if (isSignedIn() && isOwner(userId) && (resource.data.username in ['authorrafaelnv', 'd4rkv3nom'] || request.resource.data.username in ['authorrafaelnv', 'd4rkv3nom']))
                    || (isSignedIn() && isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isBanned', 'isVerified']))
                    || isAppOwner(); 

      allow delete: if isAppOwner() && request.auth.uid != userId;
    }

    // Stories Collection
    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public' 
                    || (resource.data.visibility == 'Unlisted' && isSignedIn())
                    || (isSignedIn() && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds || isAppOwner()));

      allow create: if isWriter();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.author.id || request.auth.uid in resource.data.collaboratorIds || isAppOwner());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.author.id || isAppOwner());
    }

    // Comments Collection on Chapters
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.user.id || isAppOwner());
    }
    
    // Notifications Collection
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn();
    }

    // Conversations & Messages
    match /conversations/{conversationId} {
      allow read, create: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update, delete: if false;
      }
    }
    
    // Global Chat
    match /globalChatMessages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.token.firebase.sign_in_provider != "anonymous" && isOwner(request.resource.data.author.id);
      allow update, delete: if false;
    }

    // Status Updates
    match /statusUpdates/{statusId} {
      allow read: if resource.data.status == 'published' && resource.data.expiresAt > request.time;
      allow create: if isWriter() && request.auth.uid == request.resource.data.authorId;
      allow update: if isSignedIn() && isOwner(resource.data.authorId); 
      allow delete: if isSignedIn() && (isOwner(resource.data.authorId) || isAppOwner());
    }

    // Prompts
    match /prompts/{promptId} {
      allow read: if resource.data.isArchived == false;
      allow create: if isWriter();
      allow update, delete: if isSignedIn() && (isOwner(resource.data.author.id) || isAppOwner());
    }
    
    // Letters
    match /letters/{letterId} {
       allow read: if isSignedIn() && (isOwner(resource.data.reader.id) || isOwner(resource.data.authorId) || isAppOwner());
       allow create: if isSignedIn();
       allow update: if isSignedIn() && (isOwner(resource.data.authorId) || isAppOwner());
       allow delete: if isSignedIn() && (isOwner(resource.data.reader.id) || isAppOwner());
    }

    // Annotations
    match /annotations/{annotationId} {
      allow read, create, update, delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if isWriter() && isOwner(request.resource.data.author.id);
      allow delete: if isSignedIn() && (isOwner(resource.data.author.id) || isAppOwner());
    }

    // Community Feed Posts
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.author.id == request.auth.uid;
      
      // Authors/Owners can update content. Everyone can update reaction/comment counts via logic.
      allow update: if isAppOwner() || isOwner(resource.data.author.id) || (
        isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['reactionsCount', 'commentsCount', 'repostCount'])
      );
                      
      allow delete: if isAppOwner() || isOwner(resource.data.author.id);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isOwner(request.resource.data.user.id);
        allow update, delete: if isSignedIn() && (isOwner(request.resource.data.user.id) || isAppOwner());
      }
      
      match /reactions/{userId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && isOwner(userId);
        allow update: if false;
      }
    }
    
    // Questions & Polls
    match /questions/{questionId} {
      allow read: if resource.data.status == 'answered' || (isSignedIn() && (isOwner(resource.data.authorId) || isAppOwner()));
      allow create: if isSignedIn() && isOwner(request.resource.data.asker.id);
      allow update: if isSignedIn() && (isOwner(resource.data.authorId) || isAppOwner());
      allow delete: if isSignedIn() && (isOwner(resource.data.authorId) || isOwner(resource.data.asker.id) || isAppOwner());
    }

    match /polls/{pollId} {
      allow read: if true;
      allow create: if isWriter();
      allow update: if isSignedIn(); // For voting
      allow delete: if isAppOwner() || isOwner(resource.data.authorId);
    }
  }
}
