
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isNotGuest() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    match /users/{userId} {
      allow read;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
    }

    match /stories/{storyId} {
      allow read: if resource.data.visibility == 'Public';
      allow create, update, delete: if request.auth.uid == request.resource.data.author.id 
                                    || request.auth.uid in request.resource.data.collaboratorIds;
    }
    
    match /comments/{commentId} {
      allow read;
      allow create: if isNotGuest();
      allow update, delete: if isNotGuest() && request.auth.uid == resource.data.user.id;
    }
    
    match /globalChatMessages/{messageId} {
      allow read;
      allow create: if isNotGuest() && request.auth.uid == request.resource.data.author.id;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth.uid == resource.data.userId;
      allow create: if isNotGuest();
    }
    
    match /conversations/{conversationId} {
      allow read, update, delete: if request.auth.uid in resource.data.participantIds;
      allow create: if isNotGuest() && request.auth.uid in request.resource.data.participantIds;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read, create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
    }
    
    match /statusUpdates/{statusId} {
        allow read: if resource.data.status == 'published';
        allow create: if isNotGuest() && request.auth.uid == request.resource.data.authorId;
        allow update, delete: if request.auth.uid == resource.data.authorId;
    }
    
    match /prompts/{promptId} {
        allow read;
        allow create: if isNotGuest() && request.resource.data.author.id == request.auth.uid;
        allow update, delete: if resource.data.author.id == request.auth.uid;
    }
    
    match /letters/{letterId} {
        allow read: if resource.data.visibility == 'public' || request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.reader.id;
        allow create: if isNotGuest() && request.resource.data.reader.id == request.auth.uid;
        allow update: if request.auth.uid == resource.data.authorId; // Only author can update (pin, respond)
        allow delete: if request.auth.uid == resource.data.reader.id; // Only reader can delete
    }

    match /annotations/{annotationId} {
      allow read, create, update, delete: if request.auth.uid == resource.data.userId;
    }

    match /feedPosts/{postId} {
        allow read;
        allow create: if isNotGuest() && request.auth.uid == request.resource.data.author.id;
        allow update: if request.auth.uid == resource.data.author.id;
        allow delete: if request.auth.uid == resource.data.author.id;
    }
  }
}
